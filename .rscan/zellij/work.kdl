layout {
    cwd "/home/vr2050/RUST/rscan_codex"
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="Work" focus=true split_direction="vertical" {
        pane name="work-hub" size="42%" command="/usr/bin/zsh" {
            args "-lc" "'/home/vr2050/RUST/rscan_codex/target/debug/rscan' pane --kind work --workspace '/home/vr2050/RUST/rscan_codex'"
        }
        pane name="work-shell" size="58%"
    }
}
