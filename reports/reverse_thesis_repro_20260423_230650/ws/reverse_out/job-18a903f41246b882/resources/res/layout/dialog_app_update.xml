<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:layout_gravity="center"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@attr/container"
        android:paddingTop="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@attr/iv"
            android:background="@color/transparent"
            android:layout_width="57dp"
            android:layout_height="57dp"
            android:layout_marginBottom="10dp"
            android:src="@+id/ic_logo"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="16sp"
            android:id="@attr/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            app:render="true"/>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp">
            <ScrollView
                android:id="@attr/containerScrollView"
                android:visibility="visible"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:autoLink="phone|email|web"
                        android:id="@attr/tvContent"
                        android:paddingLeft="15dp"
                        android:paddingTop="15dp"
                        android:paddingRight="15dp"
                        android:paddingBottom="15dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="160dp"
                        android:minHeight="100dp"
                        android:lineSpacingExtra="5dp"/>
                </LinearLayout>
            </ScrollView>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:id="@attr/containerDownloadApp"
                android:paddingLeft="15dp"
                android:paddingTop="15dp"
                android:paddingRight="15dp"
                android:paddingBottom="15dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="14sp"
                    android:id="@attr/tvDownloadTips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="正在下载最新版本"/>
                <ProgressBar
                    android:id="@attr/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="15dp"
                    style="?android:attr/progressBarStyleHorizontal"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <im.uwrkaxlmjj.ui.hviews.MryTextView
                        android:textSize="13sp"
                        android:id="@attr/tvPercent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:layout_weight="1"/>
                    <im.uwrkaxlmjj.ui.hviews.MryTextView
                        android:textSize="13sp"
                        android:id="@attr/tvSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
        <im.uwrkaxlmjj.ui.cells.DividerCell
            android:id="@attr/dividerHorzontial"
            android:layout_width="match_parent"
            android:layout_height="0.1dp"/>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@attr/containerBottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="50dp">
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="14sp"
                    android:textColor="#a7a7a7"
                    android:gravity="center"
                    android:id="@attr/btnLeft"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:render="true"/>
                <View
                    android:id="@attr/divider"
                    android:layout_width="0.1dp"
                    android:layout_height="50dp"/>
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="14sp"
                    android:textColor="#017de5"
                    android:gravity="center"
                    android:id="@attr/btnRight"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:render="true"/>
            </LinearLayout>
            <im.uwrkaxlmjj.ui.hviews.MryTextView
                android:textSize="14sp"
                android:textColor="#a7a7a7"
                android:gravity="center"
                android:id="@attr/btnDownload"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:minHeight="50dp"
                app:render="true"/>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
