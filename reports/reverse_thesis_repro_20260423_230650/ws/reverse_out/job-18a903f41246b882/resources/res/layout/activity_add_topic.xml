<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tl="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@attr/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <im.uwrkaxlmjj.ui.components.RecyclerListView
        android:id="@attr/listView"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@attr/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp">
        <im.uwrkaxlmjj.ui.cells.DividerCell
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <com.tablayout.SlidingTabLayout
            android:layout_gravity="bottom|center_horizontal"
            android:id="@attr/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            tl:tl_divider_color="@android:color/transparent"
            tl:tl_indicator_color="#ffb6eafc"
            tl:tl_indicator_corner_radius="2dp"
            tl:tl_indicator_end_color="#ff36c4fd"
            tl:tl_indicator_height="6dp"
            tl:tl_indicator_margin_bottom="@dimen/dp_5"
            tl:tl_indicator_margin_top="4dp"
            tl:tl_indicator_width="17dp"
            tl:tl_tab_padding="14dp"
            tl:tl_textBold="1"
            tl:tl_textNormalSize="16sp"
            tl:tl_textSelectColor="#ff000000"
            tl:tl_textSelectSize="18sp"
            tl:tl_textUnSelectColor="#ff666666"/>
        <androidx.viewpager.widget.ViewPager
            android:id="@attr/vp_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>
    <FrameLayout
        android:id="@attr/fl_search_container"
        android:background="#fafafa"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <im.uwrkaxlmjj.ui.hviews.search.MrySearchView
            android:id="@attr/searchview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/dp_15"
            android:layout_marginTop="12dp"
            android:layout_marginRight="@dimen/dp_15"
            android:layout_marginBottom="13dp"/>
    </FrameLayout>
    <FrameLayout
        android:id="@attr/fl_search_cover"
        android:background="#99000000"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="55dp"/>
</FrameLayout>
