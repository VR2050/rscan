<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true">
        <im.uwrkaxlmjj.ui.components.BackupImageView
            android:id="@attr/img_avatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="22dp"
            android:layout_marginTop="@dimen/dp_10"
            android:layout_marginBottom="@dimen/dp_10"
            android:layout_centerVertical="true"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="@dimen/sp_16"
            android:textColor="#111111"
            android:id="@attr/tv_nick_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dp_15"
            android:text=""
            android:layout_toRightOf="@attr/img_avatar"
            android:layout_centerVertical="true"
            app:render="true"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="9sp"
            android:textColor="@color/white"
            android:id="@attr/tv_gender_age"
            android:background="@drawable/shape_item_bg_fc_gender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text=""
            android:drawablePadding="@dimen/dp_3"
            android:layout_toRightOf="@attr/tv_nick_name"
            android:layout_centerVertical="true"
            android:drawableStart="@drawable/selector_item_fc_gender"
            android:paddingStart="@dimen/dp_6"
            android:paddingEnd="@dimen/dp_6"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="12sp"
            android:textColor="@color/selector_color_item_fc_detail_btn_follow"
            android:gravity="center"
            android:id="@attr/tv_attention"
            android:background="@drawable/shape_bg_item_fc_detail_btn_follow"
            android:layout_width="55dp"
            android:layout_height="24dp"
            android:layout_marginRight="19dp"
            android:text=""
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <im.uwrkaxlmjj.ui.cells.DividerCell
        android:id="@attr/divider"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="@dimen/dp_10"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
