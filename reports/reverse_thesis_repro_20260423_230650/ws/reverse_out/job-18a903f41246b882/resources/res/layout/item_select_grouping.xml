<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="65dp">
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="15sp"
        android:textColor="@color/black"
        android:id="@attr/tv_group_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_centerVertical="true"
        app:render="true"/>
    <ImageView
        android:id="@attr/iv_selector"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="15dp"
        android:src="@+id/ic_grouping_selected"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
    <im.uwrkaxlmjj.ui.hcells.MryDividerCell
        android:id="@attr/divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_alignLeft="@attr/tv_group_name"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
