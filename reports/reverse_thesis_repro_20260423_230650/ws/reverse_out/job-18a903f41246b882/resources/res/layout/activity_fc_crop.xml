<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <FrameLayout
            android:id="@attr/fr_PhotoCropView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <ImageView
            android:layout_gravity="bottom|left"
            android:id="@attr/imgRotate"
            android:background="@drawable/fc_rotate_crop"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_margin="15dp"/>
    </FrameLayout>
    <RelativeLayout
        android:background="#000000"
        android:layout_width="match_parent"
        android:layout_height="80dp">
        <im.uwrkaxlmjj.ui.components.ColorTextView
            android:textSize="14sp"
            android:textColor="@color/white"
            android:id="@attr/txt_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="25dp"
            android:text="@string/Cancel"
            app:stringkey="Cancel"/>
        <im.uwrkaxlmjj.ui.components.ColorTextView
            android:textSize="14sp"
            android:textColor="@color/white"
            android:id="@attr/txt_complete"
            android:background="@drawable/fc_bt_bg"
            android:paddingLeft="10dp"
            android:paddingTop="5dp"
            android:paddingRight="10dp"
            android:paddingBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="15dp"
            android:text="@string/Done"
            android:layout_alignParentRight="true"
            app:stringkey="Done"/>
    </RelativeLayout>
</LinearLayout>
