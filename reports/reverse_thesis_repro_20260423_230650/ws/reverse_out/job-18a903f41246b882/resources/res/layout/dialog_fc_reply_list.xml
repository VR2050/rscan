<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@attr/fl_content"
    android:background="@drawable/shape_bg_dialog_fc_detail_child_reply"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:layout_gravity="bottom"
        android:id="@attr/rl_reply"
        android:tag="@string/key_windowBackgroundWhite"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_85">
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="@dimen/sp_15"
            android:textColor="@color/color_FFBCBCBC"
            android:gravity="center_vertical"
            android:id="@attr/btn_reply"
            android:background="@drawable/shape_bg_detail_page_bottom_reply"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_40"
            android:layout_marginTop="@dimen/dp_10"
            android:hint="发表回复…"
            android:paddingStart="@dimen/dp_16"
            android:paddingEnd="@dimen/dp_10"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"
            app:render="true"/>
    </FrameLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@attr/iv_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_fc_back"
            android:layout_alignTop="@attr/tv_reply_list_title"
            android:layout_alignBottom="@attr/tv_reply_list_title"
            android:layout_centerVertical="true"
            android:paddingStart="@dimen/dp_10"
            android:paddingEnd="@dimen/dp_10"
            android:layout_marginStart="@dimen/dp_0"
            android:layout_marginEnd="@dimen/dp_10"
            android:layout_alignParentEnd="true"/>
        <View
            android:id="@attr/view_divider"
            android:background="@color/color_FFDFE4ED"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_below="@attr/tv_reply_list_title"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/color_333333"
            android:gravity="center"
            android:id="@attr/tv_reply_list_title"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp_52"
            android:text="评论详情"
            android:layout_centerHorizontal="true"
            app:render="true"/>
    </RelativeLayout>
    <com.scwang.smartrefresh.layout.SmartRefreshLayout
        android:id="@attr/smartRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="53dp"
        android:layout_marginBottom="@dimen/dp_85"
        app:srlEnableFooterTranslationContent="true"
        app:srlEnableOverScrollBounce="false"
        app:srlEnablePreviewInEditMode="false">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@attr/rv_reply_list"
            android:background="#f2f2f2"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"/>
    </com.scwang.smartrefresh.layout.SmartRefreshLayout>
</FrameLayout>
