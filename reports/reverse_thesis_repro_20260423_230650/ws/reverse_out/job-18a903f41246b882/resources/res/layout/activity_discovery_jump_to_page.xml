<?xml version="1.0" encoding="utf-8"?>
<im.uwrkaxlmjj.ui.hviews.dragView.DragHelperFrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@attr/dragHelperFrameLayout"
    android:background="#000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@attr/containerWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:id="@attr/video_view"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <include layout="@layout/include_descovery_jump_page_guide"/>
    <im.uwrkaxlmjj.ui.hviews.dragView.DragHelperFrameLayout
        android:id="@attr/dhfMenu"
        android:background="#0000"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <im.uwrkaxlmjj.ui.hviews.MryLinearLayout
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:id="@attr/containerMenu"
            android:background="#90000000"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:minWidth="80dp"
            android:minHeight="32dp"
            app:mryBorderColor="#ffffff"
            app:mryBorderWidth="0.5dp"
            app:mryRadius="16dp">
            <FrameLayout
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <im.uwrkaxlmjj.ui.components.RadialProgressView
                    android:layout_gravity="center"
                    android:id="@attr/progressView"
                    android:visibility="gone"
                    android:layout_width="25dp"
                    android:layout_height="25dp"/>
                <im.uwrkaxlmjj.ui.hviews.MryAlphaImageView
                    android:layout_gravity="center"
                    android:id="@attr/ivShowMenuDialog"
                    android:padding="4dp"
                    android:layout_width="30dp"
                    android:layout_height="20dp"
                    android:src="@+id/game_play_icon_drag"/>
            </FrameLayout>
            <View
                android:layout_gravity="center_vertical"
                android:background="#ffffff"
                android:layout_width="0.5dp"
                android:layout_height="19dp"
                android:layout_marginLeft="11dp"
                android:layout_marginRight="11dp"/>
            <im.uwrkaxlmjj.ui.hviews.MryAlphaImageView
                android:layout_gravity="center_vertical"
                android:id="@attr/ivClose"
                android:padding="3dp"
                android:layout_width="30dp"
                android:layout_height="20dp"
                android:src="@+id/game_play_icon_show_menu"/>
        </im.uwrkaxlmjj.ui.hviews.MryLinearLayout>
    </im.uwrkaxlmjj.ui.hviews.dragView.DragHelperFrameLayout>
    <ImageView
        android:layout_gravity="end|bottom"
        android:id="@attr/img_refresh"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_marginBottom="96dp"
        android:src="@+id/icon_refresh_web"
        android:scaleType="centerCrop"
        android:layout_marginEnd="@dimen/dp_5"/>
</im.uwrkaxlmjj.ui.hviews.dragView.DragHelperFrameLayout>
