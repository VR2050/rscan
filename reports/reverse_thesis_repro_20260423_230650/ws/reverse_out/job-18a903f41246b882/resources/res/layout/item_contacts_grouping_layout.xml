<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="65dp">
    <ImageView
        android:id="@attr/list_item_genre_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:src="@+id/ic_grouping_arrow"
        android:layout_centerVertical="true"/>
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="15sp"
        android:textColor="@color/black"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@attr/list_item_genre_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="7dp"
        android:maxLines="1"
        android:layout_toLeftOf="@attr/list_item_genre_online_number"
        android:layout_toRightOf="@attr/list_item_genre_arrow"
        android:layout_centerVertical="true"
        app:render="true"/>
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="14sp"
        android:textColor="#8b8d99"
        android:id="@attr/list_item_genre_online_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:text="0/0"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
    <im.uwrkaxlmjj.ui.hcells.MryDividerCell
        android:id="@attr/divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_alignLeft="@attr/list_item_genre_name"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
