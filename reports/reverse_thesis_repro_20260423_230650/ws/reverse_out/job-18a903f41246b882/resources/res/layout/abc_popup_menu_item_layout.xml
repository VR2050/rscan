<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.view.menu.ListMenuItemView xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minWidth="196dp">
    <ImageView
        android:id="@attr/group_divider"
        android:background="@drawable/abc_list_divider_material"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"/>
    <LinearLayout
        android:id="@attr/content"
        android:duplicateParentState="true"
        android:layout_width="match_parent"
        android:layout_height="?style/dropdownListPreferredItemHeight"
        style="@plurals/RtlOverlay.Widget.AppCompat.PopupMenuItem">
        <RelativeLayout
            android:layout_gravity="center_vertical"
            android:duplicateParentState="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@plurals/RtlOverlay.Widget.AppCompat.PopupMenuItem.InternalGroup">
            <TextView
                android:textAppearance="?style/textAppearanceLargePopupMenu"
                android:ellipsize="marquee"
                android:id="@attr/title"
                android:fadingEdge="horizontal"
                android:duplicateParentState="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_alignParentTop="true"
                style="@plurals/RtlOverlay.Widget.AppCompat.PopupMenuItem.Text"/>
            <TextView
                android:textAppearance="?style/textAppearanceSmallPopupMenu"
                android:id="@attr/shortcut"
                android:duplicateParentState="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_below="@attr/title"
                style="@plurals/RtlOverlay.Widget.AppCompat.PopupMenuItem.Text"/>
        </RelativeLayout>
        <ImageView
            android:layout_gravity="center"
            android:id="@attr/submenuarrow"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleType="center"
            style="@plurals/RtlOverlay.Widget.AppCompat.PopupMenuItem.SubmenuArrow"/>
    </LinearLayout>
</androidx.appcompat.view.menu.ListMenuItemView>
