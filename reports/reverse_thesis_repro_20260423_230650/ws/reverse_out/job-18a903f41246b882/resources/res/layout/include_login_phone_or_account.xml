<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="40dp"
    android:minHeight="55dp">
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="12sp"
        android:textColor="@color/color_red_packet_default"
        android:id="@attr/tvPhoneNumberInvalidTips"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        app:mryTextStyle="1"
        app:textKey="ReminderUserNameInvalid"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@attr/etPhoneNumberParent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="55dp">
        <im.uwrkaxlmjj.ui.hviews.MryAlphaImageView
            android:layout_gravity="center_vertical"
            android:id="@attr/iv1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="15dp"
            android:src="@+id/ic_login_account"/>
        <im.uwrkaxlmjj.ui.hviews.MryEditText
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textColorHint="#cacaca"
            android:gravity="center_vertical"
            android:id="@attr/etPhoneNumber"
            android:background="@null"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:minHeight="55dp"
            android:layout_weight="1"
            android:inputType="textEmailAddress"
            android:imeOptions="actionNext"
            app:hintKey="ReminderUserNameInvalid"
            app:mryTextStyle="4"/>
        <im.uwrkaxlmjj.ui.hviews.MryAlphaImageView
            android:layout_gravity="end|center_vertical"
            android:id="@attr/ivClearPhoneNumber"
            android:padding="11dp"
            android:visibility="gone"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@+id/ic_close"/>
    </LinearLayout>
</LinearLayout>
