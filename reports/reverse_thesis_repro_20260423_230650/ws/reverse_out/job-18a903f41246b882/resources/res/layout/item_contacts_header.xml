<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="105dp">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@attr/ll_new_friend"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@attr/iv_new_friend_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@+id/ic_new_friend"/>
            <ImageView
                android:id="@attr/iv_unread"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@+id/ic_unread"
                android:layout_alignRight="@attr/iv_new_friend_icon"/>
        </RelativeLayout>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="@dimen/dp_12"
            android:textColor="#333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:render="true"
            app:textKey="NewFriends"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@attr/ll_my_grouping"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@+id/ic_my_grouping"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="14sp"
            android:textColor="#333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:render="true"
            app:textKey="MyGrouping"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@attr/ll_my_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@+id/ic_my_group"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="@dimen/dp_12"
            android:textColor="#333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:render="true"
            app:textKey="MyGroup"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@attr/ll_my_channel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@+id/ic_my_channel"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="@dimen/dp_12"
            android:textColor="#333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:render="true"
            app:textKey="MyChannel"/>
    </LinearLayout>
</LinearLayout>
