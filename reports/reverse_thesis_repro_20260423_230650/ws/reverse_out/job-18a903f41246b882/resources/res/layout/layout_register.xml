<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:paddingStart="29dp"
    android:paddingEnd="29dp">
    <TextView
        android:textSize="@dimen/dp_26"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="103dp"
        android:layout_marginBottom="40dp"
        android:text="@string/SignUp"/>
    <TextView
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/color_red_packet_default"
        android:id="@attr/tvPhoneNumberInvalidTips"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:mryTextStyle="1"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/shape_black_alp30_r10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="25dp"
        android:minHeight="55dp">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@attr/iv1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="15dp"
            android:src="@+id/ic_login_account"/>
        <EditText
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textColorHint="#cacaca"
            android:gravity="center_vertical"
            android:id="@attr/etPhoneNumber"
            android:background="@null"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:minHeight="55dp"
            android:hint="@string/ReminderUserNameInvalid"
            android:layout_weight="1"
            android:inputType="textEmailAddress"
            android:imeOptions="actionNext"/>
        <ImageView
            android:layout_gravity="end|center_vertical"
            android:id="@attr/ivClearPhoneNumber"
            android:padding="11dp"
            android:visibility="gone"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@+id/ic_close"/>
    </LinearLayout>
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/color_red_packet_default"
        android:id="@attr/tvPasswordInvalidTips1"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/LoginPwdRule"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/shape_black_alp30_r10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="55dp">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@attr/ivPwd1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="15dp"
            android:src="@+id/ic_login_pwd"/>
        <EditText
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textColorHint="#cacaca"
            android:gravity="center_vertical"
            android:id="@attr/etPassword1"
            android:background="@null"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:minHeight="55dp"
            android:hint="@string/LoginPwdRule"
            android:maxLength="16"
            android:layout_weight="1"
            android:inputType="textWebPassword"
            android:imeOptions="actionDone"/>
        <ImageView
            android:layout_gravity="end|center_vertical"
            android:id="@attr/ivClearPassword1"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@+id/ic_close"/>
        <ImageView
            android:layout_gravity="end|center_vertical"
            android:id="@attr/ivPwdShow1"
            android:padding="11dp"
            android:visibility="visible"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginRight="10dp"
            android:src="@+id/eye_close"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@attr/etInviteCodedParent"
        android:background="@drawable/shape_black_alp30_r10"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:minHeight="55dp">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="15dp"
            android:src="@+id/ic_login_pwd"/>
        <EditText
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textColorHint="#cacaca"
            android:gravity="center_vertical"
            android:id="@attr/etInviteCode"
            android:background="@null"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:minHeight="55dp"
            android:hint="@string/PleaseEnterInviteCode"
            android:maxLength="16"
            android:layout_weight="1"
            android:inputType="textCapWords"
            android:imeOptions="actionDone"/>
        <ImageView
            android:layout_gravity="end|center_vertical"
            android:id="@attr/ivClearInviteCode"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@+id/ic_close"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@attr/ll_image_code"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp">
        <im.uwrkaxlmjj.ui.hviews.MryEditText
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textColorHint="#cacaca"
            android:gravity="center_vertical"
            android:id="@attr/etCode"
            android:background="@drawable/shape_black_alp30_r10"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:minHeight="55dp"
            android:layout_weight="1"
            android:inputType="textEmailAddress"
            android:imeOptions="actionNext"
            android:layout_marginEnd="@dimen/dp_15"
            app:hintKey="PleaseInputVerifyCodeHint"
            app:mryTextStyle="4"/>
        <androidx.constraintlayout.utils.widget.ImageFilterView
            android:id="@attr/ivCode"
            android:background="#eeeeee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="100dp"
            android:minHeight="@dimen/dp_50"/>
    </LinearLayout>
    <im.uwrkaxlmjj.ui.hviews.MryRoundButton
        android:enabled="false"
        android:textSize="@dimen/dp_15"
        android:id="@attr/btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="55dp"
        android:text="@string/register"
        app:mryIsRadiusAdjustBounds="false"
        app:mryRadius="@dimen/dp_8"
        app:mryTextStyle="4"
        app:render="true"
        app:textKey="register"/>
    <TextView
        android:textSize="@dimen/dp_15"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@attr/tvLogin"
        android:background="@drawable/shape_1b2b48_r10"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="30dp"
        android:minHeight="25dp"
        android:text="@string/LoginByPassword"/>
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@attr/llPrivacyAgreement"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="39dp">
        <im.uwrkaxlmjj.ui.hviews.MryCheckBox
            android:enabled="false"
            android:id="@attr/cbPrivacyAgreement"
            android:background="@drawable/check_blue_circle"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:button="@null"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="12sp"
            android:textColor="@color/white"
            android:id="@attr/tvPrivacyAgreement"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:lineSpacingExtra="5dp"
            app:mryAlphaEnable="false"
            app:mryTextStyle="4"
            app:textKey="IHaveReadAndAgree"/>
    </LinearLayout>
</LinearLayout>
