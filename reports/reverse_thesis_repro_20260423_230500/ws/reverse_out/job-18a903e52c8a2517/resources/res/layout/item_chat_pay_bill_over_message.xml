<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:paddingLeft="10dp"
    android:paddingTop="10dp"
    android:paddingRight="10dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@attr/rlTitle"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_333333"
            android:id="@attr/tvRemind"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="-32dp"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/bbl_999999"
            android:id="@attr/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="12dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@attr/llBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@attr/llAmount1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="99dp">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@attr/ivSmallIconBig"
                    android:visibility="visible"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@+id/icon_paybill_big"/>
                <TextView
                    android:textSize="20sp"
                    android:textColor="@color/color_333333"
                    android:ellipsize="end"
                    android:layout_gravity="center"
                    android:id="@attr/tvAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:singleLine="true"/>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:id="@attr/rlAmount2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="26dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="99dp">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@attr/ivSmallIconBig2"
                    android:visibility="visible"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@+id/icon_paybill_big"/>
                <TextView
                    android:textSize="20sp"
                    android:textColor="@color/color_333333"
                    android:ellipsize="end"
                    android:layout_gravity="center"
                    android:id="@attr/tvAmount2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:singleLine="true"/>
            </LinearLayout>
        </RelativeLayout>
        <Space
            android:id="@attr/space"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="26dp"/>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@attr/rlRow1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_text_999999"
                android:id="@attr/tvRow1Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_333333"
                android:id="@attr/tvRow1Info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="15dp"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@attr/rlRow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_10">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_text_999999"
                android:id="@attr/tvRow2Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_333333"
                android:ellipsize="end"
                android:id="@attr/tvRow2Info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="100dp"
                android:layout_marginRight="15dp"
                android:singleLine="true"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@attr/rlRow3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_10">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_text_999999"
                android:id="@attr/tvRow3Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_333333"
                android:ellipsize="end"
                android:id="@attr/tvRow3Info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="100dp"
                android:layout_marginRight="15dp"
                android:singleLine="true"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
        <View
            android:background="#ededed"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="12dp"/>
        <RelativeLayout
            android:id="@attr/rlSeeDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_333333"
                android:id="@attr/tvSeeDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>
            <ImageView
                android:background="@+id/fc_icon_publish_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="15dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
