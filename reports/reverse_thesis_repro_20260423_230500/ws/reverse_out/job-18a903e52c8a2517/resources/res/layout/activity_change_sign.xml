<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@attr/rl_signature_container"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="148dp"
        android:layout_margin="10dp">
        <im.uwrkaxlmjj.ui.hviews.MryEditText
            android:textSize="16sp"
            android:id="@attr/et_signature"
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="@string/EmptySignTips"
            android:maxLength="30"
            app:hintKey="EmptySignTips"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="13sp"
            android:textColor="@color/color_text_999999"
            android:id="@attr/tv_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/30字"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
    <im.uwrkaxlmjj.ui.hviews.MryRoundButton
        android:enabled="false"
        android:textSize="15sp"
        android:id="@attr/btn_submit"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_margin="35dp"
        android:text="@string/Submit"
        app:textKey="Submit"/>
</LinearLayout>
