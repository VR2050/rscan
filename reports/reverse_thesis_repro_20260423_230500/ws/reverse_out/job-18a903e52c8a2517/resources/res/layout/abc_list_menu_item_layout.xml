<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.view.menu.ListMenuItemView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="?style/listPreferredItemHeightSmall">
    <RelativeLayout
        android:layout_gravity="center_vertical"
        android:duplicateParentState="true"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="?style/listPreferredItemPaddingLeft"
        android:layout_marginRight="?style/listPreferredItemPaddingRight"
        android:layout_weight="1">
        <TextView
            android:textAppearance="?style/textAppearanceListItemSmall"
            android:ellipsize="marquee"
            android:id="@attr/title"
            android:fadingEdge="horizontal"
            android:duplicateParentState="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"/>
        <TextView
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:id="@attr/shortcut"
            android:duplicateParentState="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_below="@attr/title"
            android:layout_alignParentLeft="true"/>
    </RelativeLayout>
</androidx.appcompat.view.menu.ListMenuItemView>
