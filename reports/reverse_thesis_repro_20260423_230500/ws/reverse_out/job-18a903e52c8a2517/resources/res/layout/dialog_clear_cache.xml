<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/dialog_near_person_filter_text_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="11dp"
        android:layout_marginRight="11dp"
        android:layout_marginBottom="10dp">
        <im.uwrkaxlmjj.ui.components.RecyclerListView
            android:id="@attr/rlv_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="14sp"
            android:textColor="#268cff"
            android:gravity="center"
            android:id="@attr/tv_clear"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_48"
            android:text="      "/>
    </LinearLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="#268cff"
        android:gravity="center"
        android:id="@attr/tv_cancel"
        android:background="@drawable/dialog_near_person_filter_text_bg"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_48"
        android:layout_marginLeft="11dp"
        android:layout_marginRight="11dp"
        android:layout_marginBottom="30dp"
        android:text="@string/Cancel"/>
</LinearLayout>
