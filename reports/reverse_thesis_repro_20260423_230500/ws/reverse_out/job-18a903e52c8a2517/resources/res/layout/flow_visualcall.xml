<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@attr/fl_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:orientation="vertical"
            android:id="@attr/lin_video"
            android:background="#000000"
            android:layout_width="103dp"
            android:layout_height="200dp"/>
        <RelativeLayout
            android:id="@attr/rl_small_window"
            android:layout_width="45dp"
            android:layout_height="80dp"
            android:layout_alignRight="@attr/lin_video"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@attr/lin_voice"
            android:visibility="visible"
            android:layout_width="64dp"
            android:layout_height="64dp">
            <ImageView
                android:id="@attr/iv_call"
                android:background="@drawable/visualcall_phone"
                android:layout_width="27dp"
                android:layout_height="27dp"/>
            <Chronometer
                android:textSize="11sp"
                android:textColor="#ffffffff"
                android:id="@attr/chr_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
