<?xml version="1.0" encoding="utf-8"?>
<com.scwang.smartrefresh.layout.SmartRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@attr/refreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:srlEnableHeaderTranslationContent="true"
    app:srlEnableLoadMore="false"
    app:srlEnableOverScrollBounce="false"
    app:srlEnableOverScrollDrag="true">
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:orientation="vertical"
            android:id="@attr/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="0dp"
            app:elevation="0dp">
            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@attr/collapsingToolbarLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:collapsedTitleGravity="0x11"
                app:layout_scrollFlags="0x3"
                app:statusBarScrim="@android:color/transparent"
                app:titleEnabled="false">
                <include layout="@layout/include_fc_topic_main_top"/>
                <FrameLayout
                    android:id="@attr/actionBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="1">
                    <ImageView
                        android:id="@attr/ivBack"
                        android:padding="8dp"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginLeft="1dp"
                        android:src="@+id/ic_back"
                        android:scaleType="centerInside"/>
                    <ImageView
                        android:layout_gravity="end"
                        android:id="@attr/ivCamera"
                        android:padding="12dp"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginRight="1dp"
                        android:src="@+id/ic_fc_menu_publish"
                        app:tint="@color/white"/>
                    <im.uwrkaxlmjj.ui.cells.DividerCell
                        android:id="@attr/divider"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="1px"/>
                </FrameLayout>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <FrameLayout
            android:id="@attr/rvContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">
            <im.uwrkaxlmjj.ui.components.RecyclerListView
                android:id="@attr/rv"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
        </FrameLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</com.scwang.smartrefresh.layout.SmartRefreshLayout>
