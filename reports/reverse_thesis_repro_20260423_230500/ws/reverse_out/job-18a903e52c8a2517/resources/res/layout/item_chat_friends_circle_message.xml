<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@attr/llContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@attr/rlContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <im.uwrkaxlmjj.ui.hviews.MryImageView
            android:id="@attr/ivRedPoint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="32dp"
            android:src="@+id/iv_chat_fc_red_point"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@attr/llInfoLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="83dp"
            android:layout_marginTop="11dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="15sp"
                    android:textColor="#000000"
                    android:ellipsize="end"
                    android:id="@attr/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:maxEms="5"/>
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="14sp"
                    android:textColor="#bdcbd3"
                    android:id="@attr/tvInteractiveType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp">
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="14sp"
                    android:textColor="#999999"
                    android:ellipsize="end"
                    android:id="@attr/tvInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:maxEms="8"
                    android:singleLine="true"/>
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:id="@attr/tvLike"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableLeft="@+id/iv_chat_fc_like"
                    android:drawablePadding="5dp"/>
            </LinearLayout>
            <im.uwrkaxlmjj.ui.hviews.MryTextView
                android:textSize="12sp"
                android:textColor="#c1c1c1"
                android:id="@attr/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@attr/llBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="40dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true">
            <LinearLayout
                android:gravity="center"
                android:id="@attr/llFcInfo"
                android:paddingLeft="10dp"
                android:paddingTop="14dp"
                android:paddingRight="10dp"
                android:paddingBottom="14dp"
                android:layout_width="111dp"
                android:layout_height="66dp">
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:ellipsize="end"
                    android:id="@attr/tvFcInfo"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="2"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center_vertical"
                android:id="@attr/llAttention"
                android:background="@+id/iv_chat_fc_attention_bg"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <im.uwrkaxlmjj.ui.hviews.MryImageView
                    android:layout_gravity="center_vertical"
                    android:background="@+id/iv_chat_fc_attenti"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="12sp"
                    android:textColor="#2ba9f8"
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="4dp"
                    android:text="关注"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center_vertical"
                android:id="@attr/llMutual"
                android:background="@+id/iv_chat_fc_mutual_bg"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <im.uwrkaxlmjj.ui.hviews.MryImageView
                    android:layout_gravity="center_vertical"
                    android:background="@+id/iv_chat_fc_mutual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <im.uwrkaxlmjj.ui.hviews.MryTextView
                    android:textSize="12sp"
                    android:textColor="#d1d1d1"
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="4dp"
                    android:text="已互关"/>
            </LinearLayout>
        </LinearLayout>
        <View
            android:id="@attr/line"
            android:background="#dedede"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_alignLeft="@attr/llInfoLayout"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
</RelativeLayout>
