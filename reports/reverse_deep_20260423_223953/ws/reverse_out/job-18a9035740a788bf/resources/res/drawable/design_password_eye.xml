<?xml version="1.0" encoding="utf-8"?>
<animated-selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_checked="true"
        android:id="@attr/visible"
        android:drawable="@drawable/design_ic_visibility"/>
    <item
        android:id="@attr/masked"
        android:drawable="@drawable/design_ic_visibility_off"/>
    <transition
        android:drawable="@drawable/avd_show_password"
        android:toId="@attr/visible"
        android:fromId="@attr/masked"/>
    <transition
        android:drawable="@drawable/avd_hide_password"
        android:toId="@attr/masked"
        android:fromId="@attr/visible"/>
</animated-selector>
