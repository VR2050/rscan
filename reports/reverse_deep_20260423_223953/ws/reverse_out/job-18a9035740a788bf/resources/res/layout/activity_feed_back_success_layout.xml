<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#fffafafa"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="@dimen/dp_10"
        android:paddingRight="@dimen/dp_10"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@attr/ivFeedStatusImg"
            android:layout_width="@dimen/dp_56"
            android:layout_height="@dimen/dp_56"
            android:layout_marginTop="50dp"
            android:src="@+id/transfer_success_icon"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="15sp"
            android:textColor="#ff333333"
            android:id="@attr/mryFeedStatusText"
            android:layout_width="60dp"
            android:layout_height="21dp"
            android:layout_marginTop="34dp"
            android:text="反馈成功"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="13sp"
            android:textColor="#ff333333"
            android:gravity="center"
            android:id="@attr/mryFeedDescText"
            android:layout_width="310dp"
            android:layout_height="47dp"
            android:layout_marginTop="18dp"
            android:text="感谢您对本软件的关注与支持，我们会认真处理您的反馈，尽快修复和完善相关功能"/>
        <Button
            android:textColor="@color/white"
            android:id="@attr/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="30dp"
            android:layout_marginRight="12dp"
            android:text="关闭"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
