<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="14sp"
        android:id="@attr/tv_title"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="23dp"
        android:text="@string/PrivacyProfilePhoto"
        android:layout_centerVertical="true"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"
        app:render="true"
        app:textKey="PrivacyProfilePhoto"/>
    <ImageView
        android:id="@attr/iv_arrow"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="16dp"
        android:src="@+id/icon_arrow_right"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"/>
    <RelativeLayout
        android:id="@attr/rl_header"
        android:layout_width="94dp"
        android:layout_height="94dp"
        android:layout_marginTop="@dimen/dp_20"
        android:layout_marginRight="10dp"
        android:layout_toLeftOf="@attr/iv_arrow"
        android:layout_centerVertical="true"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0">
        <im.uwrkaxlmjj.ui.components.BackupImageView
            android:id="@attr/iv_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
        <im.uwrkaxlmjj.ui.components.RadialProgressView
            android:id="@attr/rpvAvatar"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <ImageView
            android:id="@attr/img_camera"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@+id/icon_new_camera"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@drawable/shape_edit_bg"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginLeft="@dimen/dp_20"
        android:layout_marginTop="@dimen/dp_20"
        android:layout_marginRight="@dimen/dp_20"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintTop_toBottomOf="@attr/rl_header">
        <ImageView
            android:layout_width="23dp"
            android:layout_height="23dp"
            android:layout_marginLeft="@dimen/dp_15"
            android:src="@drawable/ic_smile"/>
        <TextView
            android:textSize="@dimen/dp_12"
            android:textStyle="bold"
            android:textColor="#242025"
            android:gravity="start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/EditInfomationText"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/dp_10"/>
        <ImageView
            android:layout_width="@dimen/dp_14"
            android:layout_height="@dimen/dp_14"
            android:src="@+id/icon_edit"
            android:scaleType="centerCrop"
            android:layout_marginEnd="@dimen/dp_15"/>
    </LinearLayout>
    <im.uwrkaxlmjj.ui.hcells.MryDividerCell
        android:id="@attr/divider"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="20dp"
        android:layout_alignParentBottom="true"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintStart_toStartOf="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
