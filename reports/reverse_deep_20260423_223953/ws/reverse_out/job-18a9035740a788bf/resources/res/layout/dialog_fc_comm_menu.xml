<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <im.uwrkaxlmjj.ui.hviews.MryLinearLayout
        android:orientation="vertical"
        android:id="@attr/containerContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_10"
        android:layout_marginStart="@dimen/dp_15"
        android:layout_marginEnd="@dimen/dp_15"
        app:mryRadius="@dimen/dp_10">
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="16sp"
            android:textColor="@color/color_text_black_222222"
            android:gravity="center"
            android:id="@attr/tv_title"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="42dp"/>
        <im.uwrkaxlmjj.ui.cells.DividerCell
            android:id="@attr/divider"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <im.uwrkaxlmjj.ui.components.RecyclerListView
            android:id="@attr/rlv_list"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"/>
    </im.uwrkaxlmjj.ui.hviews.MryLinearLayout>
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="16sp"
        android:textColor="#268cff"
        android:gravity="center"
        android:id="@attr/tv_cancel"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_60"
        android:layout_marginBottom="@dimen/dp_28"
        android:text="@string/Cancel"
        android:layout_marginStart="@dimen/dp_15"
        android:layout_marginEnd="@dimen/dp_15"
        app:mryAlphaEnable="false"/>
</LinearLayout>
