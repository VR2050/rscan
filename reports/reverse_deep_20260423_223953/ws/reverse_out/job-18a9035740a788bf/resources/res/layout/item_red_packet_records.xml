<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="80dp">
    <FrameLayout
        android:id="@attr/ffAvatarLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_centerVertical="true">
        <im.uwrkaxlmjj.ui.components.BackupImageView
            android:id="@attr/iv_avatar"
            android:background="@+id/ic_wx_circle"
            android:layout_width="45dp"
            android:layout_height="45dp"/>
        <ImageView
            android:id="@attr/iv_default_avatar"
            android:background="@+id/ic_wx_circle"
            android:visibility="gone"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:scaleType="centerInside"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="right"
        android:orientation="vertical"
        android:id="@attr/llRightLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="15dp"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/black"
                android:id="@attr/tv_CG_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20.00"/>
            <ImageView
                android:id="@attr/tvMoneyUnit"
                android:layout_width="@dimen/dp_15"
                android:layout_height="@dimen/dp_15"
                android:layout_marginTop="@dimen/dp_3"
                android:src="@+id/ic_red_pack"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@attr/iv_best"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:layout_marginRight="@dimen/dp_5"
                android:src="@+id/icon_feature_best"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_999999"
                android:id="@attr/tv_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="已领取"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="13dp"
        android:layout_marginRight="@dimen/dp_15"
        android:layout_toLeftOf="@attr/llRightLayout"
        android:layout_toRightOf="@attr/ffAvatarLayout"
        android:layout_centerVertical="true">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/black"
            android:ellipsize="end"
            android:id="@attr/tv_type_and_from"
            android:paddingRight="@dimen/dp_20"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="个人红包-来自TOMxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxaaaxxxxxxxxxxx"
            android:maxLines="1"
            android:singleLine="true"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_text_999999"
            android:id="@attr/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="11月20日 21:16"/>
    </LinearLayout>
</RelativeLayout>
