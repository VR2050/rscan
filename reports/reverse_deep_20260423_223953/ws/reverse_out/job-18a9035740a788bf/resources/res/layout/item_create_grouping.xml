<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="65dp">
    <im.uwrkaxlmjj.ui.components.BackupImageView
        android:id="@attr/iv_avatar"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginLeft="12dp"
        android:layout_centerVertical="true"/>
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="15sp"
        android:textColor="#333333"
        android:ellipsize="end"
        android:id="@attr/tv_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="12dp"
        android:maxLines="1"
        android:layout_toRightOf="@attr/iv_avatar"
        android:layout_centerVertical="true"
        app:render="true"/>
    <im.uwrkaxlmjj.ui.hcells.MryDividerCell
        android:id="@attr/divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_alignLeft="@attr/tv_name"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
