<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/selector_grey"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="15sp"
        android:textColor="#ff8b8d99"
        android:gravity="center_vertical"
        android:id="@attr/tvGroupDescView"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginLeft="25dp"
        android:layout_marginRight="25dp"
        android:text="分组"/>
    <TextView
        android:textColor="#ff222222"
        android:gravity="center_vertical"
        android:id="@attr/tvGroupingSettingView"
        android:background="@color/white"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:drawableRight="@+id/icon_arrow_right"/>
    <TextView
        android:textSize="15sp"
        android:textColor="#ff8b8d99"
        android:gravity="center_vertical"
        android:id="@attr/tvNoteDescView"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginLeft="25dp"
        android:layout_marginRight="25dp"
        android:text="备注名"/>
    <FrameLayout
        android:id="@attr/flNoteSettingLayout"
        android:background="@color/white"
        android:paddingLeft="16dp"
        android:paddingRight="8dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp">
        <EditText
            android:textSize="14sp"
            android:textColor="@color/color_text_black_222222"
            android:gravity="center_vertical"
            android:id="@attr/etNoteEditView"
            android:background="@null"
            android:paddingRight="26dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="@string/SetNoteTips"
            android:maxLength="64"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@attr/ivClearNoteView"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@+id/ic_clear_remarks"/>
    </FrameLayout>
</LinearLayout>
