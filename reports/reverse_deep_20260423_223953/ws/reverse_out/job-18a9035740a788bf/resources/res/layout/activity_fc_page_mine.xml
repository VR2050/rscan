<?xml version="1.0" encoding="utf-8"?>
<com.scwang.smartrefresh.layout.SmartRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@attr/smartRefreshLayout"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:srlEnableHeaderTranslationContent="true"
    app:srlEnableOverScrollBounce="false"
    app:srlEnableOverScrollDrag="true"
    app:srlEnablePreviewInEditMode="false">
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:orientation="vertical"
            android:id="@attr/mAppbarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="@dimen/dp_0">
            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@attr/ctl_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:collapsedTitleGravity="0x11"
                app:layout_scrollFlags="0x13"
                app:statusBarScrim="@android:color/transparent"
                app:titleEnabled="false">
                <RelativeLayout
                    android:id="@attr/rl_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="2"
                    app:layout_collapseParallaxMultiplier="0.75">
                    <ImageView
                        android:id="@attr/iv_fc_bg"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:src="@drawable/friends_circle_bg"
                        android:scaleType="centerCrop"/>
                    <im.uwrkaxlmjj.ui.components.BackupImageView
                        android:id="@attr/iv_user_avatar"
                        android:layout_width="@dimen/dp_60"
                        android:layout_height="@dimen/dp_60"
                        android:layout_marginTop="-20dp"
                        android:scaleType="centerCrop"
                        android:layout_below="@attr/iv_fc_bg"
                        android:layout_marginStart="@dimen/dp_15"/>
                    <im.uwrkaxlmjj.ui.hviews.MryTextView
                        android:textSize="@dimen/sp_9"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:id="@attr/tv_gender"
                        android:background="@drawable/shape_item_bg_fc_gender"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/dp_13"
                        android:layout_marginTop="@dimen/dp_4"
                        android:drawablePadding="@dimen/dp_3"
                        android:layout_alignTop="@attr/tv_user_name"
                        android:drawableStart="@drawable/selector_item_fc_gender"
                        android:paddingStart="@dimen/dp_6"
                        android:paddingEnd="@dimen/dp_6"
                        android:layout_marginStart="@dimen/dp_7"
                        android:layout_toEndOf="@attr/tv_user_name"/>
                    <im.uwrkaxlmjj.ui.hviews.MryTextView
                        android:textSize="@dimen/sp_15"
                        android:textColor="@color/black"
                        android:id="@attr/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/dp_21"
                        android:layout_alignBottom="@attr/iv_user_avatar"
                        android:layout_marginStart="@dimen/dp_15"
                        android:layout_toEndOf="@attr/iv_user_avatar"
                        app:render="true"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="24dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="@dimen/dp_16"
                        android:layout_below="@attr/tv_user_name"
                        android:paddingStart="@dimen/dp_20"
                        android:paddingEnd="@dimen/dp_20">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1">
                            <im.uwrkaxlmjj.ui.components.ColorTextView
                                android:textSize="@dimen/sp_12"
                                android:textColor="@color/color_text_8B8D99"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/firendscircle_dynamic"
                                app:stringkey="firendscircle_dynamic"/>
                            <im.uwrkaxlmjj.ui.hviews.MryTextView
                                android:textSize="@dimen/sp_17"
                                android:textColor="@color/color_text_black_222222"
                                android:id="@attr/tv_publish_fc_num"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:layout_marginStart="@dimen/dp_5"
                                app:render="true"/>
                        </LinearLayout>
                        <View
                            android:layout_gravity="center_vertical"
                            android:background="#ffdedede"
                            android:layout_width="@dimen/dp_1"
                            android:layout_height="@dimen/dp_17"/>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1">
                            <im.uwrkaxlmjj.ui.components.ColorTextView
                                android:textSize="@dimen/sp_12"
                                android:textColor="@color/color_text_8B8D99"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/firendscircle_attention"
                                app:stringkey="firendscircle_attention"/>
                            <im.uwrkaxlmjj.ui.hviews.MryTextView
                                android:textSize="@dimen/sp_17"
                                android:textColor="@color/color_text_black_222222"
                                android:id="@attr/tv_followed_user_num"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:layout_marginStart="@dimen/dp_5"
                                app:render="true"/>
                        </LinearLayout>
                        <View
                            android:layout_gravity="center_vertical"
                            android:background="#ffdedede"
                            android:layout_width="@dimen/dp_1"
                            android:layout_height="@dimen/dp_17"/>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1">
                            <im.uwrkaxlmjj.ui.components.ColorTextView
                                android:textSize="@dimen/sp_12"
                                android:textColor="@color/color_text_8B8D99"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/firendscircle_get_zan"
                                app:stringkey="firendscircle_get_zan"/>
                            <im.uwrkaxlmjj.ui.hviews.MryTextView
                                android:textSize="@dimen/sp_17"
                                android:textColor="@color/color_text_black_222222"
                                android:id="@attr/tv_like_num"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:layout_marginStart="@dimen/dp_5"
                                app:render="true"/>
                        </LinearLayout>
                        <View
                            android:layout_gravity="center_vertical"
                            android:background="#ffdedede"
                            android:layout_width="@dimen/dp_1"
                            android:layout_height="@dimen/dp_17"/>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1">
                            <im.uwrkaxlmjj.ui.components.ColorTextView
                                android:textSize="@dimen/sp_12"
                                android:textColor="@color/color_text_8B8D99"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/firendscircle_fans"
                                app:stringkey="firendscircle_fans"/>
                            <im.uwrkaxlmjj.ui.hviews.MryTextView
                                android:textSize="@dimen/sp_17"
                                android:textColor="@color/color_text_black_222222"
                                android:id="@attr/tv_fans_num"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:layout_marginStart="@dimen/dp_5"
                                app:render="true"/>
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>
                <androidx.appcompat.widget.Toolbar
                    android:id="@attr/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    app:contentInsetEnd="@dimen/dp_0"
                    app:contentInsetLeft="@dimen/dp_0"
                    app:contentInsetRight="@dimen/dp_0"
                    app:contentInsetStart="@dimen/dp_0"
                    app:layout_collapseMode="1"
                    app:titleMargin="@dimen/dp_0">
                    <RelativeLayout
                        android:gravity="bottom"
                        android:id="@attr/rl_title"
                        android:paddingBottom="@dimen/dp_16"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <ImageView
                            android:id="@attr/ic_back"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@+id/ic_fc_back_black"
                            android:paddingStart="@dimen/dp_10"
                            android:paddingEnd="@dimen/dp_10"
                            android:layout_marginStart="@dimen/dp_10"/>
                        <ImageView
                            android:id="@attr/iv_fc_publish"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@+id/ic_fc_publish_blue"
                            android:layout_marginEnd="@dimen/dp_20"
                            android:layout_alignParentEnd="true"/>
                        <im.uwrkaxlmjj.ui.hviews.MryTextView
                            android:textSize="@dimen/sp_16"
                            android:textColor="@color/color_333333"
                            android:id="@attr/tv_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/FriendHub"
                            android:layout_centerHorizontal="true"/>
                    </RelativeLayout>
                </androidx.appcompat.widget.Toolbar>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@attr/rv_fc_list"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
        <include
            android:id="@attr/rl_empty"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_anchor="@attr/mAppbarLayout"
            app:layout_anchorGravity="0x50"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            layout="@layout/view_fc_footer"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</com.scwang.smartrefresh.layout.SmartRefreshLayout>
