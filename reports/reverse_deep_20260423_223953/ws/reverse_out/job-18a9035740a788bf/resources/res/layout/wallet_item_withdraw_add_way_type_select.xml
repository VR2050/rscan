<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="66dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@attr/container"
        android:background="@drawable/cell_all_selector"
        android:padding="@dimen/dp_16"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:layout_marginStart="@dimen/dp_16"
        android:layout_marginEnd="@dimen/dp_16">
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/text_descriptive_color"
            android:id="@attr/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@attr/tvContent"
            app:layout_constraintEnd_toEndOf="0"
            app:layout_constraintStart_toStartOf="0"
            app:layout_constraintTop_toTopOf="0"
            app:layout_constraintVertical_chainStyle="2"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="@dimen/sp_13"
            android:textColor="@color/text_secondary_color"
            android:textColorHint="@color/text_secondary_color"
            android:gravity="center_vertical"
            android:id="@attr/tvContent"
            android:background="@null"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginEnd="@dimen/dp_12"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="0"
            app:layout_constraintEnd_toEndOf="0"
            app:layout_constraintEnd_toStartOf="@attr/ivArrow"
            app:layout_constraintStart_toStartOf="@attr/tvTitle"
            app:layout_constraintTop_toBottomOf="@attr/tvTitle"/>
        <ImageView
            android:id="@attr/ivArrow"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@+id/icon_arrow_right"
            app:layout_constraintBottom_toBottomOf="@attr/tvContent"
            app:layout_constraintEnd_toEndOf="0"
            app:layout_constraintStart_toEndOf="@attr/tvContent"
            app:layout_constraintTop_toTopOf="@attr/tvContent"
            app:tint="@color/icon_secondary_color"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
