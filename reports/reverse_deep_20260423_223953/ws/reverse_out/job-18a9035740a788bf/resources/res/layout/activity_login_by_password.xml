<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:paddingStart="29dp"
    android:paddingEnd="29dp">
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="@dimen/dp_26"
        android:textColor="@color/white"
        android:id="@attr/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="103dp"
        app:mryTextStyle="1"
        app:textKey="LoginByPassword"/>
    <include layout="@layout/include_login_phone_or_account"/>
    <include layout="@layout/include_login_password"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@attr/etGoogleCodedParent"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:minHeight="55dp">
        <im.uwrkaxlmjj.ui.hviews.MryAlphaImageView
            android:layout_gravity="center_vertical"
            android:id="@attr/ivGoogle"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="15dp"
            android:src="@+id/ic_login_pwd"/>
        <im.uwrkaxlmjj.ui.hviews.MryEditText
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textColorHint="#cacaca"
            android:gravity="center_vertical"
            android:id="@attr/etGoogleCode"
            android:background="@null"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:minHeight="55dp"
            android:maxLength="16"
            android:layout_weight="1"
            android:inputType="number"
            android:imeOptions="actionDone"
            app:hintKey="PleaseEnterGoogle"
            app:mryTextStyle="4"/>
        <im.uwrkaxlmjj.ui.hviews.MryAlphaImageView
            android:layout_gravity="end|center_vertical"
            android:id="@attr/ivClearGoogleCode"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@+id/ic_close"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@attr/etInviteCodedParent"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:minHeight="55dp">
        <im.uwrkaxlmjj.ui.hviews.MryEditText
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textColorHint="#cacaca"
            android:gravity="center_vertical"
            android:id="@attr/etInviteCode"
            android:background="@null"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:minHeight="55dp"
            android:maxLength="16"
            android:layout_weight="1"
            android:inputType="textCapWords"
            android:imeOptions="actionDone"
            app:hintKey="PleaseEnterInviteCode"
            app:mryTextStyle="4"/>
        <im.uwrkaxlmjj.ui.hviews.MryAlphaImageView
            android:layout_gravity="end|center_vertical"
            android:id="@attr/ivClearInviteCode"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@+id/ic_close"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@attr/ll_image_code"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp">
        <im.uwrkaxlmjj.ui.hviews.MryEditText
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textColorHint="#cacaca"
            android:gravity="center_vertical"
            android:id="@attr/etCode"
            android:background="@null"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:minHeight="55dp"
            android:layout_weight="1"
            android:inputType="textEmailAddress"
            android:imeOptions="actionNext"
            android:layout_marginEnd="@dimen/dp_15"
            app:hintKey="PleaseInputVerifyCodeHint"
            app:mryTextStyle="4"/>
        <androidx.constraintlayout.utils.widget.ImageFilterView
            android:id="@attr/ivCode"
            android:background="#eeeeee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="100dp"
            android:minHeight="@dimen/dp_50"/>
    </LinearLayout>
    <im.uwrkaxlmjj.ui.hviews.MryRoundButton
        android:enabled="false"
        android:textSize="@dimen/dp_15"
        android:id="@attr/btn"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_52"
        android:layout_marginTop="25dp"
        app:mryIsRadiusAdjustBounds="false"
        app:mryRadius="@dimen/dp_8"
        app:mryTextStyle="4"
        app:render="true"
        app:textKey="Login"/>
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="14sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@attr/tvForgotPassword"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:minHeight="25dp"
        app:mryTextStyle="4"
        app:textKey="ForgetPassword"/>
    <im.uwrkaxlmjj.ui.hviews.MryTextView
        android:textSize="@dimen/dp_16"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@attr/tvLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:minHeight="25dp"
        app:mryTextStyle="4"
        app:textKey="LoginByPassword"/>
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@attr/llPrivacyAgreement"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="39dp">
        <im.uwrkaxlmjj.ui.hviews.MryCheckBox
            android:enabled="false"
            android:id="@attr/cbPrivacyAgreement"
            android:background="@drawable/check_blue_circle"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:button="@null"/>
        <im.uwrkaxlmjj.ui.hviews.MryTextView
            android:textSize="12sp"
            android:textColor="@color/white"
            android:id="@attr/tvPrivacyAgreement"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:lineSpacingExtra="5dp"
            app:mryAlphaEnable="false"
            app:mryTextStyle="4"
            app:textKey="IHaveReadAndAgree"/>
    </LinearLayout>
</LinearLayout>
