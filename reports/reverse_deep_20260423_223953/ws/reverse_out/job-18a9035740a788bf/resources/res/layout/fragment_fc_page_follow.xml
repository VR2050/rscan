<?xml version="1.0" encoding="utf-8"?>
<com.scwang.smartrefresh.layout.SmartRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@attr/smartRefreshLayout"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:srlEnableFooterTranslationContent="true"
    app:srlEnableHeaderTranslationContent="true"
    app:srlEnableOverScrollBounce="false">
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@attr/fl_container"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="0dp"
            app:elevation="0dp">
            <FrameLayout
                android:id="@attr/rvTopicsParent"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:layout_scrollFlags="0x1">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@attr/rvTopics"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:overScrollMode="never"/>
                <LinearLayout
                    android:gravity="center"
                    android:layout_gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:id="@attr/llAllTopics"
                    android:paddingLeft="15dp"
                    android:paddingRight="15dp"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent">
                    <im.uwrkaxlmjj.ui.hviews.MryTextView
                        android:textSize="12sp"
                        android:textColor="#2ecefd"
                        android:gravity="center_vertical"
                        android:id="@attr/tvAllTopics"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="3dp"
                        android:text="@string/All"
                        android:singleLine="true"
                        app:textKey="All"/>
                    <ImageView
                        android:layout_width="6dp"
                        android:layout_height="11dp"
                        android:layout_marginLeft="3dp"
                        android:src="@drawable/arrow_right_white"
                        app:tint="#2ecefd"/>
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@attr/rv_fc_list"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</com.scwang.smartrefresh.layout.SmartRefreshLayout>
