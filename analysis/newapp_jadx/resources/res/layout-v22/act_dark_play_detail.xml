<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="100dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
                android:id="@+id/banner_parent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toTopOf="parent"
                app:scale_height="480dp"
                app:scale_width="360dp">
                <com.youth.banner.Banner
                    android:id="@+id/banner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:banner_auto_loop="false"
                    app:banner_infinite_loop="false"/>
            </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/black"
                android:ellipsize="end"
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="16dp"
                android:maxLines="2"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@+id/banner_parent"/>
            <androidx.recyclerview.widget.RecyclerView
                android:orientation="horizontal"
                android:id="@+id/rv_tag"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="16dp"
                android:overScrollMode="never"
                android:layout_marginHorizontal="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@+id/tv_name"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_certificate"
                android:background="@drawable/bg_1f1f1f_corner_8"
                android:padding="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="16dp"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@+id/rv_tag">
                <ImageView
                    android:id="@+id/iv_certificate"
                    android:background="@drawable/img_certificate"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:layout_constraintLeft_toLeftOf="@+id/cl_certificate"
                    app:layout_constraintTop_toTopOf="@+id/cl_certificate"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffdba5"
                    android:id="@+id/tv_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:layout_marginHorizontal="8dp"
                    app:layout_constraintLeft_toRightOf="@+id/iv_certificate"
                    app:layout_constraintTop_toTopOf="@+id/cl_certificate"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="#dcdbdb"
                    android:id="@+id/tv_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:layout_marginHorizontal="8dp"
                    app:layout_constraintLeft_toRightOf="@+id/iv_certificate"
                    app:layout_constraintTop_toBottomOf="@+id/tv_label"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@+id/mid_guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.5"/>
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:id="@+id/tv_info"
                android:padding="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:text="基本信息"
                android:layout_marginHorizontal="5dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cl_certificate"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffdba5"
                android:id="@+id/tv_age_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:text="年龄："
                app:layout_constraintLeft_toLeftOf="@+id/tv_info"
                app:layout_constraintTop_toBottomOf="@+id/tv_info"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffdba5"
                android:id="@+id/tv_age"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                app:layout_constraintLeft_toRightOf="@+id/tv_age_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_info"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffdba5"
                android:id="@+id/tv_height_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="身高："
                app:layout_constraintLeft_toRightOf="@+id/mid_guideline"
                app:layout_constraintTop_toBottomOf="@+id/tv_info"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffdba5"
                android:id="@+id/tv_height"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                app:layout_constraintLeft_toRightOf="@+id/tv_height_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_info"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffdba5"
                android:id="@+id/tv_weight_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginTop="16dp"
                android:text="体重："
                app:layout_constraintLeft_toLeftOf="@+id/tv_info"
                app:layout_constraintTop_toBottomOf="@+id/tv_age_title"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffdba5"
                android:id="@+id/tv_weight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="16dp"
                app:layout_constraintLeft_toRightOf="@+id/tv_weight_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_age_title"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffdba5"
                android:id="@+id/tv_cup_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="胸围："
                app:layout_constraintLeft_toRightOf="@+id/mid_guideline"
                app:layout_constraintTop_toBottomOf="@+id/tv_height"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffdba5"
                android:id="@+id/tv_cup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="16dp"
                app:layout_constraintLeft_toRightOf="@+id/tv_cup_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_height"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ll_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                app:layout_constraintLeft_toLeftOf="@+id/tv_weight_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_weight_title">
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffdba5"
                    android:id="@+id/tv_price_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="16dp"
                    android:text="服务价格："/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffdba5"
                    android:id="@+id/tv_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffdba5"
                android:id="@+id/tv_service1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginTop="16dp"
                app:layout_constraintLeft_toLeftOf="@+id/tv_info"
                app:layout_constraintTop_toBottomOf="@+id/ll_price"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#dcdbdb"
                android:id="@+id/tv_intro"
                android:background="@drawable/bg_1f1f1f_corner_8"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="16dp"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintLeft_toLeftOf="@+id/tv_service1"
                app:layout_constraintTop_toBottomOf="@+id/tv_service1"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintLeft_toLeftOf="@+id/tv_intro"
                app:layout_constraintTop_toBottomOf="@+id/tv_intro">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_service2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_marginHorizontal="16dp"
                    app:layout_constraintLeft_toLeftOf="@+id/tv_intro"
                    app:layout_constraintTop_toBottomOf="@+id/tv_intro">
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:id="@+id/tv_service2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="服务项目"
                        app:layout_constraintLeft_toLeftOf="@+id/cl_service2"
                        app:layout_constraintTop_toTopOf="@+id/cl_service2"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:id="@+id/tv_service_required_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="必选"
                        app:layout_constraintLeft_toLeftOf="@+id/cl_service2"
                        app:layout_constraintTop_toBottomOf="@+id/tv_service2"/>
                    <RadioGroup
                        android:orientation="horizontal"
                        android:id="@+id/rg_face"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@+id/tv_service_required_title">
                        <RadioButton
                            android:textSize="14sp"
                            android:textColor="@drawable/selector_text_service"
                            android:gravity="center"
                            android:id="@+id/rb_body"
                            android:background="@drawable/selector_bg_service"
                            android:layout_width="104dp"
                            android:layout_height="60dp"
                            android:layout_marginRight="20dp"
                            android:checked="false"
                            android:button="@null"/>
                        <RadioButton
                            android:textSize="14sp"
                            android:textColor="@drawable/selector_text_service"
                            android:gravity="center"
                            android:id="@+id/rb_face"
                            android:background="@drawable/selector_bg_service"
                            android:layout_width="104dp"
                            android:layout_height="60dp"
                            android:layout_marginRight="20dp"
                            android:checked="false"
                            android:button="@null"/>
                    </RadioGroup>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_required_service"
                        android:scrollbars="none"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:overScrollMode="never"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:layout_constraintTop_toBottomOf="@+id/rg_face"
                        app:spanCount="3"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:id="@+id/tv_service_optional_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="可选"
                        app:layout_constraintLeft_toLeftOf="@+id/cl_service2"
                        app:layout_constraintTop_toBottomOf="@+id/rv_required_service"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_optional_service"
                        android:scrollbars="none"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:overScrollMode="never"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:layout_constraintTop_toBottomOf="@+id/tv_service_optional_title"
                        app:spanCount="3"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:id="@+id/tv_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="时间"
                        app:layout_constraintLeft_toLeftOf="@+id/cl_service2"
                        app:layout_constraintTop_toBottomOf="@+id/rv_optional_service"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:id="@+id/btn_minus"
                        android:background="@drawable/btn_plusreduce_style"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginRight="12dp"
                        android:text="–"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_time"
                        app:layout_constraintRight_toLeftOf="@+id/tv_minute"
                        app:layout_constraintTop_toTopOf="@+id/tv_time"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:id="@+id/tv_minute"
                        android:background="@drawable/bg_white_corner_8"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:layout_marginRight="4dp"
                        android:text="10"
                        android:paddingHorizontal="16dp"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_time"
                        app:layout_constraintRight_toLeftOf="@+id/tv_minute_title"
                        app:layout_constraintTop_toTopOf="@+id/tv_time"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:id="@+id/tv_minute_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="12dp"
                        android:text="分钟"
                        app:layout_constraintRight_toLeftOf="@+id/btn_plus"
                        app:layout_constraintTop_toTopOf="@+id/tv_time"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:id="@+id/btn_plus"
                        android:background="@drawable/btn_plusreduce_style"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="+"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_time"
                        app:layout_constraintRight_toRightOf="@+id/cl_service2"
                        app:layout_constraintTop_toTopOf="@+id/tv_time"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <View
                    android:id="@+id/view_paid_cover"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            app:layout_constraintBottom_toTopOf="@+id/btn_submit_aichangeface_video">
            <TextView
                android:textColor="@color/black"
                android:id="@+id/user_account_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="账户余额：0"/>
            <TextView
                android:textColor="#ff0000"
                android:id="@+id/text_gorecharge"
                android:padding="10dp"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="去充值"
                android:paddingHorizontal="10dp"/>
        </LinearLayout>
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="12sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/tv_order"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="订单"
            android:drawableTop="@drawable/ic_order"
            android:drawablePadding="3dp"
            android:paddingHorizontal="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/btn_submit_aichangeface_video"
            android:background="@drawable/btn_submit_style"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="5dp"
            android:text="预约服务"
            app:layout_constraintLeft_toRightOf="@+id/tv_order"
            app:layout_constraintRight_toLeftOf="@+id/tv_share"
            app:layout_constraintTop_toTopOf="@+id/tv_order"/>
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="12sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/tv_share"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="分享"
            android:drawableTop="@drawable/ic_share"
            android:drawablePadding="3dp"
            android:paddingHorizontal="14dp"
            app:drawable_height="28dp"
            app:drawable_width="28dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:id="@+id/error_view"
        android:background="?attr/my_page_bg"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <include layout="@layout/error_view"/>
    </FrameLayout>
    <include layout="@layout/title_bar_layout"/>
</FrameLayout>
