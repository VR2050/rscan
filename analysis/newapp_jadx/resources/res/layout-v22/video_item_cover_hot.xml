<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/textView"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="img_cover"/>
    <ImageView
        android:id="@+id/iv_ico_type"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="18dp"
        android:src="@drawable/icon_mh_new"
        android:adjustViewBounds="true"/>
    <com.jbzd.media.movecartoons.view.text.ImageTextView
        android:textSize="10sp"
        android:textColor="@color/price"
        android:gravity="center"
        android:id="@+id/itv_price"
        android:background="@drawable/home_red_flag_bg"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="3dp"
        android:text="5"
        android:layout_marginStart="3dp"
        android:layout_marginEnd="3dp"
        android:layout_alignParentEnd="true"
        android:paddingHorizontal="6dp"/>
    <com.jbzd.media.movecartoons.view.GradientTextView
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:id="@+id/text_price_type"
        android:visibility="gone"
        android:layout_width="30dp"
        android:layout_height="20dp"
        android:layout_margin="3dp"
        android:layout_alignParentEnd="true"
        app:endColor="#ffb343"
        app:startColor="#ffb343"/>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/itv_ad"
        android:background="@drawable/home_duration_bg"
        android:paddingLeft="5dp"
        android:paddingTop="2dp"
        android:paddingRight="5dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_margin="3sp"
        android:text="广告"
        android:layout_alignParentEnd="true"
        android:paddingHorizontal="5dp"
        android:paddingVertical="2dp"/>
    <com.jbzd.media.movecartoons.view.text.ImageTextView
        android:textSize="10sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/itv_zhiding"
        android:background="@drawable/home_zhiding_flag_bg"
        android:visibility="gone"
        android:layout_width="35dp"
        android:layout_height="18dp"
        android:layout_marginLeft="3dp"
        android:layout_marginTop="3dp"
        android:text="置顶"
        android:layout_alignParentLeft="true"/>
    <RelativeLayout
        android:background="@drawable/bg_videoitem_bottom"
        android:paddingLeft="5dp"
        android:paddingTop="15dp"
        android:paddingRight="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="5dp">
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="8sp"
            android:textColor="@color/black"
            android:gravity="center_vertical"
            android:id="@+id/itv_love"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableLeft="@drawable/icon_video_love"
            android:drawablePadding="2dp"
            android:layout_alignParentRight="true"
            app:drawable_height="8dp"
            app:drawable_width="8dp"/>
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="13sp"
            android:textColor="@color/black"
            android:gravity="center_vertical"
            android:id="@+id/itv_clicks"
            android:paddingLeft="4sp"
            android:paddingTop="3sp"
            android:paddingRight="4sp"
            android:paddingBottom="3sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:layout_alignParentLeft="true"
            android:paddingHorizontal="4sp"
            android:paddingVertical="3sp"
            app:drawableTint="@color/white"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/black"
            android:gravity="center_vertical"
            android:id="@+id/tv_duration"
            android:paddingLeft="4sp"
            android:paddingTop="3sp"
            android:paddingRight="4sp"
            android:paddingBottom="3sp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:paddingHorizontal="4sp"
            android:paddingVertical="3sp"/>
    </RelativeLayout>
    <TextView
        android:textSize="11sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_ad_new_novel"
        android:background="@drawable/home_duration_bg"
        android:paddingLeft="4dp"
        android:paddingTop="1dp"
        android:paddingRight="4dp"
        android:paddingBottom="1dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="6dp"
        android:text="广告"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="4dp"
        android:paddingVertical="1dp"/>
    <ImageView
        android:id="@+id/iv_novel_audio"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/icon_novel_audio"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"/>
</RelativeLayout>
