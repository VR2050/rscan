<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/img_vip_icon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_place_holder_horizontal"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/black"
        android:id="@+id/tv_time_vipcard_countdown"
        android:background="@drawable/bg_red_round25"
        android:paddingLeft="10dp"
        android:paddingTop="3dp"
        android:paddingRight="10dp"
        android:paddingBottom="3dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:text="新人倒计时 23:22:21"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        app:layout_constraintBottom_toBottomOf="@+id/img_vip_icon"
        app:layout_constraintEnd_toEndOf="@+id/img_vip_icon"/>
</androidx.constraintlayout.widget.ConstraintLayout>
