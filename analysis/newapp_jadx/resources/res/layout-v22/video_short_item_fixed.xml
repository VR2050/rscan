<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:background="@color/white"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="14sp"
        android:gravity="center"
        android:id="@+id/space_left"
        android:background="@color/transparent"
        android:padding="8sp"
        android:layout_width="0dp"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:layout_width="145dp"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:scale_height="120dp"
                    app:scale_width="90dp">
                    <RelativeLayout
                        android:id="@+id/item_more"
                        android:background="@drawable/selector_btn_module_change_bg"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <com.jbzd.media.movecartoons.view.text.ImageTextView
                            android:textSize="15sp"
                            android:textColor="?attr/my_change_btn_txt_color"
                            android:gravity="center"
                            android:paddingLeft="18dp"
                            android:paddingBottom="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="去\10查\10看\10更\10多"
                            android:drawableRight="@drawable/short_hor_more"
                            android:layout_centerInParent="true"
                            app:drawableTint="?attr/my_change_btn_txt_color"
                            app:drawable_height="18dp"
                            app:drawable_width="18dp"/>
                    </RelativeLayout>
                    <RelativeLayout
                        android:id="@+id/item_parent"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_video"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:adjustViewBounds="true"
                            app:shapeAppearance="@style/RoundedStyle"/>
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/rl_coverOption"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <LinearLayout
                                android:gravity="center"
                                android:id="@+id/ll_money_vip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent">
                                <com.jbzd.media.movecartoons.view.text.ImageTextView
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:id="@+id/itv_icon_money"
                                    android:background="@drawable/bg_video_lefttop"
                                    android:paddingLeft="8dp"
                                    android:paddingTop="1dp"
                                    android:paddingRight="8dp"
                                    android:paddingBottom="1dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="8"
                                    android:drawableLeft="@drawable/icon_coin_balance_left"
                                    android:drawablePadding="3dp"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="1dp"
                                    app:drawable_height="10dp"
                                    app:drawable_width="10dp"/>
                                <TextView
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:id="@+id/tv_video_type"
                                    android:background="@drawable/bg_video_vip"
                                    android:paddingLeft="8dp"
                                    android:paddingTop="1dp"
                                    android:paddingRight="8dp"
                                    android:paddingBottom="1dp"
                                    android:visibility="gone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="VIP"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="1dp"/>
                            </LinearLayout>
                            <ImageView
                                android:id="@+id/iv_ico_type"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="18dp"
                                android:src="@drawable/icon_mh_free"
                                android:adjustViewBounds="true"/>
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <com.jbzd.media.movecartoons.view.text.ImageTextView
                                    android:textSize="10sp"
                                    android:textColor="@color/black"
                                    android:gravity="center_vertical"
                                    android:id="@+id/itv_type"
                                    android:background="@drawable/icon_pic_type_bg"
                                    android:paddingLeft="8dp"
                                    android:paddingRight="8dp"
                                    android:visibility="gone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="16dp"
                                    android:layout_marginLeft="5dp"
                                    android:layout_marginTop="5dp"
                                    android:drawableLeft="@drawable/icon_pic_type"
                                    android:drawablePadding="2dp"
                                    android:paddingHorizontal="8dp"
                                    app:drawable_height="10dp"
                                    app:drawable_width="10dp"/>
                                <com.jbzd.media.movecartoons.view.text.ImageTextView
                                    android:textSize="10sp"
                                    android:textColor="@color/price"
                                    android:gravity="center"
                                    android:id="@+id/itv_price"
                                    android:background="@drawable/home_diamond_flag_bg"
                                    android:visibility="gone"
                                    android:layout_width="30dp"
                                    android:layout_height="20dp"
                                    android:layout_margin="3sp"
                                    android:layout_alignParentEnd="true"/>
                                <com.jbzd.media.movecartoons.view.GradientTextView
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:id="@+id/text_price_type"
                                    android:visibility="gone"
                                    android:layout_width="30dp"
                                    android:layout_height="20dp"
                                    android:layout_margin="3dp"
                                    android:layout_alignParentEnd="true"
                                    app:endColor="#ff6701"
                                    app:startColor="#f5fdd403"/>
                                <TextView
                                    android:textSize="@dimen/priceTextSize"
                                    android:textColor="@color/white"
                                    android:gravity="center"
                                    android:id="@+id/itv_ad"
                                    android:background="@drawable/home_duration_bg"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="2dp"
                                    android:paddingRight="5dp"
                                    android:paddingBottom="2dp"
                                    android:visibility="gone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3sp"
                                    android:layout_marginBottom="3sp"
                                    android:text="广告"
                                    android:layout_marginStart="3sp"
                                    android:layout_marginEnd="3sp"
                                    android:layout_alignParentEnd="true"
                                    android:paddingHorizontal="5dp"
                                    android:paddingVertical="2dp"/>
                                <com.jbzd.media.movecartoons.view.text.ImageTextView
                                    android:textSize="10sp"
                                    android:textColor="@color/black"
                                    android:gravity="center"
                                    android:id="@+id/itv_zhiding"
                                    android:background="@drawable/home_zhiding_flag_bg"
                                    android:visibility="gone"
                                    android:layout_width="35dp"
                                    android:layout_height="18dp"
                                    android:layout_marginLeft="3dp"
                                    android:layout_marginTop="3dp"
                                    android:text="置顶"
                                    android:layout_alignParentLeft="true"/>
                            </RelativeLayout>
                        </LinearLayout>
                    </RelativeLayout>
                    <RelativeLayout
                        android:paddingLeft="5dp"
                        android:paddingTop="15dp"
                        android:paddingRight="5dp"
                        android:paddingBottom="3dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:paddingHorizontal="5dp">
                        <com.jbzd.media.movecartoons.view.text.ImageTextView
                            android:textSize="11sp"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:id="@+id/tv_count"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@{item.click}"
                            android:drawableLeft="@drawable/icon_video_count"
                            android:drawablePadding="2dp"
                            android:layout_alignParentLeft="true"
                            android:fontFamily="@font/number"
                            android:layout_marginStart="3dp"
                            app:drawable_height="13dp"
                            app:drawable_width="13dp"/>
                        <TextView
                            android:textSize="11sp"
                            android:textColor="@color/white"
                            android:id="@+id/tv_duration"
                            android:background="@drawable/bg_time"
                            android:paddingLeft="7dp"
                            android:paddingTop="2dp"
                            android:paddingRight="7dp"
                            android:paddingBottom="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:text="@{item.getDuration_show}"
                            android:layout_alignParentLeft="true"
                            android:layout_marginEnd="3dp"
                            android:paddingHorizontal="7dp"
                            android:paddingVertical="2dp"/>
                    </RelativeLayout>
                </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:id="@+id/ll_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:id="@+id/tv_name"
                        android:paddingTop="1.5dp"
                        android:paddingBottom="1.5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:maxLines="1"
                        android:paddingVertical="1.5dp"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/color_ff6a00"
                        android:id="@+id/tv_video_click"
                        android:background="@drawable/shape_comic_type"
                        android:paddingLeft="6dp"
                        android:paddingTop="3dp"
                        android:paddingRight="6dp"
                        android:paddingBottom="3dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:maxLines="2"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <include layout="@layout/view_restricted"/>
    </FrameLayout>
</LinearLayout>
