<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:scale_height="140dp"
        app:scale_width="100dp">
        <RelativeLayout
            android:id="@+id/item_more"
            android:background="@drawable/selector_btn_module_change_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textSize="15sp"
                android:textColor="?attr/my_change_btn_txt_color"
                android:gravity="center"
                android:paddingLeft="18dp"
                android:paddingBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="去\10查\10看\10更\10多"
                android:drawableRight="@drawable/short_hor_more"
                android:layout_centerInParent="true"
                app:drawableTint="?attr/my_change_btn_txt_color"
                app:drawable_height="18dp"
                app:drawable_width="18dp"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/item_parent"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                app:shapeAppearance="@style/RoundedStyle"/>
            <RelativeLayout
                android:id="@+id/rl_coverOption"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <include layout="@layout/video_item_cover"/>
            </RelativeLayout>
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textSize="12sp"
                android:textColor="@color/price"
                android:gravity="center"
                android:id="@+id/iv_coin_video"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:drawableLeft="@drawable/icon_coin_balance_left"
                android:drawablePadding="2dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentRight="true"
                app:drawable_height="15dp"
                app:drawable_width="15dp"/>
            <LinearLayout
                android:id="@+id/ll_ad_new"
                android:paddingRight="6dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_alignParentBottom="true">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/itv_ad_new"
                    android:background="@drawable/home_duration_bg"
                    android:paddingLeft="4dp"
                    android:paddingTop="2dp"
                    android:paddingRight="4dp"
                    android:paddingBottom="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="广告"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="2dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:id="@+id/ll_money_vip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true">
                <com.jbzd.media.movecartoons.view.text.ImageTextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/itv_icon_money"
                    android:background="@drawable/bg_video_lefttop"
                    android:paddingLeft="8dp"
                    android:paddingTop="1dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="1dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8"
                    android:drawableLeft="@drawable/icon_coin_balance_left"
                    android:drawablePadding="3dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="1dp"
                    app:drawable_height="10dp"
                    app:drawable_width="10dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/tv_video_type"
                    android:background="@drawable/bg_video_vip"
                    android:paddingLeft="8dp"
                    android:paddingTop="1dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="1dp"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIP"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="1dp"/>
            </LinearLayout>
            <ImageView
                android:id="@+id/iv_ico_type"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:src="@drawable/icon_mh_free"
                android:adjustViewBounds="true"/>
        </RelativeLayout>
        <include layout="@layout/view_restricted"/>
    </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/ll_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/black"
            android:id="@+id/tv_name"
            android:paddingTop="1.5dp"
            android:paddingBottom="1.5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:maxLines="1"
            android:paddingVertical="1.5dp"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_ff6a00"
            android:id="@+id/tv_video_click"
            android:background="@drawable/shape_comic_type"
            android:paddingLeft="6dp"
            android:paddingTop="3dp"
            android:paddingRight="6dp"
            android:paddingBottom="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:maxLines="2"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"/>
    </LinearLayout>
</LinearLayout>
