<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:background="@drawable/bg_all_shape"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:orientation="vertical"
            android:id="@+id/title_layout"
            android:paddingTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/title_bar_height">
            <RelativeLayout
                android:id="@+id/btn_titleBack"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentLeft="true">
                <ImageView
                    android:id="@+id/iv_titleLeftIcon"
                    android:background="@drawable/style_icon_all"
                    android:padding="8dp"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:src="@drawable/ic_btn_icon_black"
                    android:scaleType="fitCenter"
                    android:layout_centerVertical="true"
                    android:layout_marginHorizontal="10dp"/>
            </RelativeLayout>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text=""
                android:layout_centerHorizontal="true"/>
            <RelativeLayout
                android:id="@+id/btn_titleRight"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentRight="true">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:id="@+id/tv_titleRight"
                    android:padding="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dp"
                    android:text=""
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:id="@+id/btn_titleRightIcon"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentRight="true"
                android:paddingHorizontal="10dp">
                <ImageView
                    android:id="@+id/iv_titleRightIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="fitCenter"
                    android:maxHeight="20dp"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <View
                android:id="@+id/title_divider"
                android:background="#0cffffff"
                android:visibility="invisible"
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/app_bar_layout"
                android:background="@color/transparent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:elevation="0dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingBottom="6dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_scrollFlags="exitUntilCollapsed|scroll">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:id="@+id/ll_my_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_collapseMode="parallax">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:id="@+id/ll_mine_info"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:layout_marginHorizontal="10dp">
                            <com.jbzd.media.movecartoons.view.image.CircleImageView
                                android:id="@+id/civ_head_posthome"
                                android:layout_width="65dp"
                                android:layout_height="65dp"
                                android:layout_marginTop="5dp"
                                android:layout_marginBottom="5dp"
                                android:src="@drawable/ic_place_holder_circle_51"
                                android:layout_centerInParent="true"
                                android:layout_marginVertical="5dp"
                                app:border_color="#fbc15b"
                                app:border_color_inside="#ffbe4f"
                                app:border_width="0dp"/>
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="5dp"
                                android:layout_weight="1">
                                <TextView
                                    android:textSize="16sp"
                                    android:textColor="@color/black"
                                    android:id="@+id/tv_comicsdetail_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:drawablePadding="5dp"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"/>
                                <LinearLayout
                                    android:orientation="horizontal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp">
                                    <com.jbzd.media.movecartoons.view.text.ImageTextView
                                        android:textSize="@dimen/textSizeSmall"
                                        android:textColor="@color/black"
                                        android:id="@+id/iv_isposter_vip"
                                        android:visibility="gone"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:drawableLeft="@drawable/icon_vip"/>
                                    <com.jbzd.media.movecartoons.view.text.ImageTextView
                                        android:textSize="@dimen/textSizeSmall"
                                        android:textColor="@color/black"
                                        android:id="@+id/iv_isposter"
                                        android:visibility="gone"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="5dp"
                                        android:drawableLeft="@drawable/icon_user_creater"
                                        app:drawable_height="13dp"
                                        app:drawable_width="13dp"/>
                                </LinearLayout>
                            </LinearLayout>
                            <com.jbzd.media.movecartoons.view.FollowTextView
                                android:textSize="14sp"
                                android:textColor="@color/selector_text_color_follow"
                                android:gravity="center"
                                android:id="@+id/tv_follow_posthome"
                                android:background="@drawable/state_follow_style"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"
                                android:layout_width="66dp"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:layout_marginStart="10dp"
                                android:paddingVertical="5dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginTop="6dp"
                            android:layout_marginRight="10dp"
                            android:layout_marginBottom="6dp"
                            android:layout_marginHorizontal="10dp"
                            android:layout_marginVertical="6dp">
                            <TextView
                                android:textSize="13sp"
                                android:textColor="@color/color_999999"
                                android:id="@+id/fans_posthome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:maxLines="1"/>
                            <TextView
                                android:textSize="13sp"
                                android:textColor="@color/color_999999"
                                android:id="@+id/follows_posthome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="20dp"
                                android:maxLines="1"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:textSize="14sp"
                                android:textColor="@color/transparent"
                                android:id="@+id/acc_id_posthome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawablePadding="5dp"/>
                            <ImageView
                                android:id="@+id/src_sex_leftline"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="5dp"
                                android:src="@drawable/img_line_ver"/>
                            <ImageView
                                android:textSize="@dimen/textSizeSmall"
                                android:textColor="@color/black"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/iv_sex_posthome"
                                android:visibility="gone"
                                android:layout_width="13dp"
                                android:layout_height="13dp"
                                android:layout_marginLeft="5dp"
                                android:src="@drawable/icon_sexmale"/>
                        </LinearLayout>
                    </LinearLayout>
                    <TextView
                        android:background="@color/input_background_color"
                        android:layout_width="match_parent"
                        android:layout_height="15dp"/>
                </LinearLayout>
            </com.google.android.material.appbar.AppBarLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:id="@+id/ll_top"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_scrollFlags="enterAlways|scroll">
                    <com.flyco.tablayout.SlidingTabLayout
                        android:layout_gravity="center"
                        android:id="@+id/tablayout_userhome"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_marginBottom="-2dp"
                        android:layout_weight="1"
                        app:tl_divider_color="@color/transparent"
                        app:tl_iconVisible="false"
                        app:tl_indicator_color="@color/transparent"
                        app:tl_indicator_corner_radius="3dp"
                        app:tl_tab_padding="8dp"
                        app:tl_textBold="NONE"
                        app:tl_textSelectColor="@color/color_fd4c8b"
                        app:tl_textSelectSize="16sp"
                        app:tl_textUnselectColor="@color/color_fd4c8b"
                        app:tl_textsize="16sp"/>
                </LinearLayout>
                <androidx.viewpager.widget.ViewPager
                    android:id="@+id/vp_content_userhome"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior"/>
            </LinearLayout>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>
    </LinearLayout>
</FrameLayout>
