<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll_item"
    android:background="@drawable/style_post_tag"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/ll_microtanot_userrow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_gray_white"
            android:gravity="center"
            android:id="@+id/tv_posttopic_name"
            android:paddingLeft="8dp"
            android:paddingTop="5dp"
            android:paddingRight="8dp"
            android:paddingBottom="5dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="伦理之爱"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:maxLength="4"
            android:paddingHorizontal="8dp"
            android:paddingVertical="5dp"/>
        <com.jbzd.media.movecartoons.view.image.CircleImageView
            android:id="@+id/iv_posttopic_left_avatar"
            android:visibility="gone"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_logo"
            android:layout_centerInParent="true"
            app:border_color="@color/line_default_color"
            app:border_width="0dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/white80"
                    android:id="@+id/tv_post_toptics_number"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="2.5千个帖子"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/white80"
                    android:gravity="center"
                    android:id="@+id/tv_post_toptics_times"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="9508.5万浏览"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/white80"
                    android:gravity="right"
                    android:id="@+id/tv_post_toptics_followers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="156.5万关注"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/iv_select"
            android:visibility="gone"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/selector_check1"
            android:scaleType="fitXY"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <RelativeLayout
            android:id="@+id/rl_wantsee"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textSize="13sp"
                android:textColor="#ffffff"
                android:gravity="center_vertical"
                android:id="@+id/itv_microtanot_wantsee"
                android:paddingLeft="10dp"
                android:paddingTop="5dp"
                android:paddingRight="10dp"
                android:paddingBottom="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="想看"
                android:drawableLeft="@drawable/movie_desc_love"
                android:drawablePadding="2dp"
                android:layout_centerInParent="true"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                app:drawable_height="16dp"
                app:drawable_width="16dp"/>
        </RelativeLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
