<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingVertical="8dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_description"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <androidx.appcompat.widget.AppCompatEditText
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/color_gold_main_near"
                    android:gravity="top|left"
                    android:id="@+id/et_aichangeface_info"
                    android:background="@drawable/bg_input_login"
                    android:padding="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="144dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:hint="请输入描述内容"
                    android:maxLines="5"
                    android:maxLength="500"
                    android:textCursorDrawable="@drawable/color_cursor"
                    android:layout_marginHorizontal="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <androidx.appcompat.widget.AppCompatEditText
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/color_gold_main_near"
                    android:id="@+id/ed_postopic_price"
                    android:background="@drawable/bg_b3000000_corner_6"
                    android:padding="10dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:hint="请设置视频价格0～999金币，不设置则免费"
                    android:maxLines="1"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/et_aichangeface_info"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:orientation="vertical"
                android:id="@+id/cl_media"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cl_description">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_add"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:id="@+id/tv_media_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:text="上传人脸参考照片"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/color_gold_main_near"
                        android:id="@+id/tv_aichangeface_basemin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="2dp"
                        android:text="(必填，至少1张)"
                        app:layout_constraintStart_toEndOf="@+id/tv_media_title"
                        app:layout_constraintTop_toBottomOf="@+id/tv_media_title"
                        app:layout_constraintTop_toTopOf="@+id/tv_media_title"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_image"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        android:layout_marginVertical="10dp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_media_title"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:id="@+id/tv_aichangeface_base"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        android:text="上传人脸原图照片"
                        android:layout_marginVertical="10dp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/rv_image"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/color_gold_main_near"
                        android:id="@+id/tv_aichangeface_minface"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="2dp"
                        android:text="(必填，至少1张)"
                        app:layout_constraintStart_toEndOf="@+id/tv_aichangeface_base"
                        app:layout_constraintTop_toBottomOf="@+id/tv_aichangeface_base"
                        app:layout_constraintTop_toTopOf="@+id/tv_aichangeface_base"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_image_base"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginVertical="12dp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_aichangeface_base"/>
                    <RadioGroup
                        android:orientation="horizontal"
                        android:id="@+id/rg_changeface_open_personal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginHorizontal="10dp"
                        app:layout_constraintTop_toBottomOf="@+id/rv_image_base">
                        <RadioButton
                            android:textSize="15sp"
                            android:textColor="@color/black"
                            android:id="@+id/rb_aichangeface_open"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:checked="true"
                            android:button="@null"
                            android:text="公开"
                            android:drawableLeft="@drawable/selector_radio"
                            android:drawablePadding="6dp"
                            android:paddingHorizontal="10dp"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>
                        <RadioButton
                            android:textSize="15sp"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:id="@+id/rb_aichangeface_personal"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:checked="false"
                            android:button="@null"
                            android:text="私密"
                            android:drawableLeft="@drawable/selector_radio"
                            android:drawablePadding="6dp"
                            android:paddingHorizontal="10dp"/>
                    </RadioGroup>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/color_gold_main"
                        android:id="@+id/tv_aichangeface_bottomtips"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="可以选择公开或者私密，公开则会分享给大家一起欣赏哟,兄弟有福一起享,选择私密则会出现在 我的购买-AI定制中，别人是无法查看的哟！"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/rg_changeface_open_personal"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:layout_gravity="bottom"
                        android:id="@+id/btn_submit_aichangeface_video"
                        android:background="@drawable/btn_orange_style"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:layout_marginBottom="15dp"
                        android:text="0金币"
                        android:layout_marginVertical="15dp"
                        app:layout_constraintTop_toBottomOf="@+id/tv_aichangeface_bottomtips"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
