<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/input_background_color"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="vertical"
        android:background="@color/input_background_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:dividerPadding="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:showDividers="middle">
        <TextView
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/txt_scan"
            android:background="@drawable/bg_topround6_style"
            android:paddingTop="15dp"
            android:paddingBottom="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="扫描账号凭证"
            android:paddingVertical="15dp"/>
        <TextView
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/txt_upload"
            android:background="@drawable/bg_bottomround6_style"
            android:paddingTop="15dp"
            android:paddingBottom="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="上传账号凭证"
            android:paddingVertical="15dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/btn_cancel"
        android:background="@drawable/bg_bottomround6_style"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/app_content_margin"
        android:text="@string/dialog_btn_cancel"
        android:paddingVertical="12dp"/>
</androidx.appcompat.widget.LinearLayoutCompat>
