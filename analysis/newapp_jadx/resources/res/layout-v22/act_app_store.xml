<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_all_shape"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <include layout="@layout/title_bar_layout"/>
        <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
            android:id="@+id/banner_parent"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fav_title"
            app:scale_height="175dp"
            app:scale_width="375dp">
            <com.youth.banner.Banner
                android:id="@+id/banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:banner_indicator_gravity="right"
                app:banner_indicator_height="3dp"
                app:banner_indicator_marginBottom="10dp"
                app:banner_indicator_marginRight="20dp"
                app:banner_indicator_normal_color="@color/white60"
                app:banner_indicator_normal_width="7dp"
                app:banner_indicator_radius="4dp"
                app:banner_indicator_selected_color="@color/color_gold_main"
                app:banner_indicator_selected_width="13dp"
                app:banner_radius="0dp"/>
        </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
        <FrameLayout
            android:id="@+id/frag_content"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="5dp"/>
    </LinearLayout>
</FrameLayout>
