<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_score_change"
        android:background="@drawable/bg_item_pre_pay_recommend"
        android:paddingTop="25dp"
        android:paddingBottom="25dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingVertical="25dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:ellipsize="end"
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/black40"
            android:id="@+id/tvTips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:layout_constraintEnd_toEndOf="@+id/ll_score_change"
            app:layout_constraintStart_toStartOf="@+id/ll_score_change"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_sign_now"
        android:background="@drawable/btn_orange_style"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="15dp"
        android:text="进行兑换"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@+id/ll_score_change"/>
</androidx.constraintlayout.widget.ConstraintLayout>
