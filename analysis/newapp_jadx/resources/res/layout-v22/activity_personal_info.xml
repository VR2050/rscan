<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/activity_personal_info_0"
    android:background="@color/white"
    android:padding="@dimen/app_content_margin"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/user_nick_name"/>
    <androidx.appcompat.widget.AppCompatEditText
        android:textSize="16sp"
        android:textColor="@color/black"
        android:textColorHint="@color/black26"
        android:gravity="center_vertical"
        android:id="@+id/edit_nick_name"
        android:tag="binding_1"
        android:background="@drawable/bg_input_login"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/hint_nick_name"
        android:singleLine="true"
        android:maxLength="20"
        android:textCursorDrawable="@drawable/color_cursor"
        android:paddingStart="@dimen/app_content_margin"
        android:paddingEnd="@dimen/app_content_margin"
        android:paddingVertical="10dp"/>
    <ImageView
        android:visibility="gone"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:src="@drawable/icon_avatar_tips"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/black39"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/avatar_change_tips"
        android:layout_marginVertical="16dp"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center_horizontal"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/group_sexy"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="35dp">
        <CheckBox
            android:id="@+id/radio_sex_male"
            android:tag="binding_2"
            android:background="@drawable/sex_male_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:button="@null"
            app:layout_constraintEnd_toStartOf="@+id/radio_sex_female"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <CheckBox
            android:id="@+id/radio_sex_female"
            android:tag="binding_3"
            android:background="@drawable/sex_female_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:button="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/radio_sex_male"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:id="@+id/bottom_btn"
        android:paddingTop="30dp"
        android:paddingBottom="30dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="30dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <TextView
            android:textSize="15sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/btn_submit"
            android:background="@drawable/btn_orange_style"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="确认"
            android:paddingVertical="12dp"/>
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
