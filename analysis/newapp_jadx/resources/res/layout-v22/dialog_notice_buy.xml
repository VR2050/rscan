<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@color/transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_dialog_black"
            android:layout_width="300dp"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="6dp"
                android:layout_marginRight="20dp"
                android:text="温馨提示"
                android:layout_marginHorizontal="20dp"
                android:paddingVertical="12dp"/>
            <TextView
                android:textSize="15sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:id="@+id/tv_dialog_content"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:text="请开通暗网高级VIP，无限畅看社区帖子！！"
                android:layout_marginHorizontal="5dp"
                android:paddingVertical="10dp"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:id="@+id/tv_cancel_dialog"
                    android:background="@drawable/btn_update_style"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="取消"
                    android:layout_weight="1"/>
                <View
                    android:layout_width="20dp"
                    android:layout_height="1dp"/>
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:id="@+id/tv_buy_dialog"
                    android:background="@drawable/btn_orange_style"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="购买"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
