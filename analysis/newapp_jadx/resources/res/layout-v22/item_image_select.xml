<?xml version="1.0" encoding="utf-8"?>
<com.jbzd.media.movecartoons.view.AspectRatioLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll_add_select"
    android:background="@drawable/iv_add"
    android:layout_width="104dp"
    android:layout_height="104dp"
    app:arl_heightRatio="1"
    app:arl_widthRatio="1">
    <ImageView
        android:textSize="12sp"
        android:textColor="@color/search_hint"
        android:gravity="center"
        android:id="@+id/tv_add_media"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_add"
        android:layout_centerInParent="true"
        android:paddingVertical="24dp"/>
    <ImageView
        android:id="@+id/iv_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <ImageView
        android:id="@+id/iv_delete"
        android:padding="4dp"
        android:visibility="gone"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/dialog_close_new"
        android:layout_alignParentRight="true"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/transparent"
        android:gravity="center_horizontal"
        android:id="@+id/tv_change"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="更换图片"
        android:layout_alignParentBottom="true"
        android:paddingVertical="4dp"/>
    <TextView
        android:textSize="11sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_cover_img"
        android:background="@drawable/bg_cover"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:text="封面"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="6dp"/>
</com.jbzd.media.movecartoons.view.AspectRatioLayout>
