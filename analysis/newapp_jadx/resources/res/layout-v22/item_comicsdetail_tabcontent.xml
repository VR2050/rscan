<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="3dp">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_chapter_cover"
            android:layout_width="140dp"
            android:layout_height="90dp"
            android:layout_marginLeft="10dp"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            app:shapeAppearance="@style/RoundedStyle"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:id="@+id/tv_chapter_name"
            android:paddingTop="15dp"
            android:paddingBottom="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="章节名称"
            android:maxLines="2"
            android:layout_weight="1"
            android:paddingVertical="15dp"/>
        <LinearLayout
            android:gravity="center"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginHorizontal="10dp">
            <TextView
                android:textColor="@color/color_red_white_selector"
                android:id="@+id/tv_tablecontent_watch"
                android:background="@drawable/bg_watch_comics"
                android:paddingLeft="12dp"
                android:paddingTop="3dp"
                android:paddingRight="12dp"
                android:paddingBottom="3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="观看"
                android:paddingHorizontal="12dp"
                android:paddingVertical="3dp"/>
            <TextView
                android:textColor="@color/black"
                android:id="@+id/tv_tablecontent_vip"
                android:background="@drawable/btn_orange_style"
                android:paddingLeft="12dp"
                android:paddingTop="2dp"
                android:paddingRight="12dp"
                android:paddingBottom="2dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIP"
                android:paddingHorizontal="12dp"
                android:paddingVertical="2dp"/>
            <TextView
                android:textColor="@color/white"
                android:id="@+id/tv_tablecontent_coin"
                android:background="@drawable/bg_comics_coin"
                android:paddingLeft="8dp"
                android:paddingTop="4dp"
                android:paddingRight="8dp"
                android:paddingBottom="4dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50"
                android:drawableRight="@drawable/icon_coin_balance_left"
                android:drawablePadding="3dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
