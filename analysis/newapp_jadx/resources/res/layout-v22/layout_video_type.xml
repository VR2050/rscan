<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="10sp"
        android:textColor="#743e00"
        android:gravity="center"
        android:id="@+id/tv_freeFlag"
        android:background="@drawable/icon_video_free"
        android:paddingBottom="3dp"
        android:visibility="gone"
        android:layout_width="50dp"
        android:layout_height="27dp"
        android:text="免费"/>
    <ImageView
        android:id="@+id/iv_adFlag"
        android:visibility="gone"
        android:layout_width="45dp"
        android:layout_height="25dp"
        android:src="@drawable/icon_ad"
        android:scaleType="fitCenter"/>
    <RelativeLayout
        android:id="@+id/rl_price"
        android:background="@drawable/icon_video_price_bg"
        android:visibility="gone"
        android:layout_width="50dp"
        android:layout_height="27dp">
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="9sp"
            android:textColor="@color/black"
            android:gravity="center_vertical"
            android:id="@+id/itv_price"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingBottom="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:drawableLeft="@drawable/icon_video_price"
            android:layout_centerInParent="true"
            android:paddingHorizontal="10dp"
            app:drawable_height="8dp"
            app:drawable_width="10dp"/>
    </RelativeLayout>
</LinearLayout>
