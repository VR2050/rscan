<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.jbzd.media.movecartoons.view.text.ImageTextView
        android:textSize="10sp"
        android:textColor="@color/price"
        android:gravity="center"
        android:id="@+id/itv_price"
        android:background="@drawable/home_red_flag_bg"
        android:paddingLeft="6dp"
        android:paddingTop="1dp"
        android:paddingRight="6dp"
        android:paddingBottom="1dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:drawableRight="@drawable/coin_small"
        android:drawablePadding="2dp"
        android:layout_alignParentEnd="true"
        android:paddingHorizontal="6dp"
        android:paddingVertical="1dp"/>
    <com.jbzd.media.movecartoons.view.GradientTextView
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:id="@+id/text_price_type"
        android:visibility="gone"
        android:layout_width="30dp"
        android:layout_height="20dp"
        android:layout_margin="3dp"
        android:layout_alignParentEnd="true"
        app:endColor="#ffb343"
        app:startColor="#ffb343"/>
    <com.jbzd.media.movecartoons.view.text.ImageTextView
        android:textSize="10sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/itv_zhiding"
        android:background="@drawable/home_zhiding_flag_bg"
        android:visibility="gone"
        android:layout_width="35dp"
        android:layout_height="18dp"
        android:layout_marginLeft="3dp"
        android:layout_marginTop="3dp"
        android:text="置顶"
        android:layout_alignParentLeft="true"/>
    <RelativeLayout
        android:id="@+id/ll_bottom_cover"
        android:paddingLeft="5dp"
        android:paddingTop="20dp"
        android:paddingRight="5dp"
        android:paddingBottom="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="5dp">
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="8sp"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:id="@+id/itv_love"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableLeft="@drawable/icon_video_love"
            android:drawablePadding="2dp"
            android:layout_alignParentRight="true"
            app:drawable_height="8dp"
            app:drawable_width="8dp"/>
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="11sp"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:id="@+id/itv_clicks"
            android:paddingLeft="4dp"
            android:paddingTop="2dp"
            android:paddingRight="4dp"
            android:paddingBottom="2dp"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:drawableLeft="@drawable/icon_playnum_left"
            android:drawablePadding="5dp"
            android:layout_alignParentLeft="true"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp"
            app:drawableTint="@color/white"
            app:drawable_height="15dp"
            app:drawable_width="15dp"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/white"
            android:id="@+id/tv_duration"
            android:background="@drawable/bg_time"
            android:paddingLeft="7dp"
            android:paddingTop="2dp"
            android:paddingRight="7dp"
            android:paddingBottom="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:layout_alignParentLeft="true"
            android:layout_marginEnd="3dp"
            android:paddingHorizontal="7dp"
            android:paddingVertical="2dp"/>
    </RelativeLayout>
</RelativeLayout>
