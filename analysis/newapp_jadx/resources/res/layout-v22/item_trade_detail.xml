<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_trade_detail"
    android:background="#b3000000"
    android:paddingBottom="16dp"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/iv_mine_avatar"
        android:layout_width="43dp"
        android:layout_height="43dp"
        android:layout_marginTop="16dp"
        android:scaleType="centerCrop"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/black"
        android:ellipsize="end"
        android:id="@+id/tv_postdetail_nickname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="@+id/iv_mine_avatar"
        app:layout_constraintStart_toEndOf="@+id/iv_mine_avatar"
        app:layout_constraintTop_toTopOf="@+id/iv_mine_avatar"/>
    <ImageView
        android:id="@+id/iv_vip"
        android:background="@drawable/icon_surface"
        android:layout_width="40dp"
        android:layout_height="16dp"
        android:scaleType="center"
        android:adjustViewBounds="true"
        android:layout_marginStart="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_mine_avatar"
        app:layout_constraintStart_toEndOf="@+id/tv_postdetail_nickname"
        app:layout_constraintTop_toTopOf="@+id/iv_mine_avatar"/>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/black"
        android:id="@+id/tv_type"
        android:background="@drawable/bg_identity_sale"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="卖方"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:paddingHorizontal="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_mine_avatar"
        app:layout_constraintRight_toLeftOf="@+id/btn_submit_aichangeface_video"
        app:layout_constraintStart_toEndOf="@+id/iv_vip"
        app:layout_constraintTop_toTopOf="@+id/iv_mine_avatar"/>
    <com.jbzd.media.movecartoons.view.GradientRoundCornerButton
        android:textSize="12sp"
        android:gravity="center"
        android:id="@+id/btn_submit_aichangeface_video"
        android:paddingLeft="10dp"
        android:paddingTop="6dp"
        android:paddingRight="10dp"
        android:paddingBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="完成/取消"
        android:layout_marginEnd="16dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        app:gradientBg="@drawable/btn_submit_corner8_style"
        app:gradientCornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_mine_avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/tv_type"
        app:layout_constraintTop_toTopOf="@+id/iv_mine_avatar"
        app:txtColor="@color/black"/>
    <androidx.recyclerview.widget.RecyclerView
        android:orientation="horizontal"
        android:id="@+id/rv_tag"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginVertical="16dp"
        app:layoutManager="com.google.android.flexbox.FlexboxLayoutManager"
        app:layout_constraintStart_toStartOf="@+id/iv_mine_avatar"
        app:layout_constraintTop_toBottomOf="@+id/iv_mine_avatar"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/black"
        android:id="@+id/etv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginRight="16dp"
        android:minHeight="48dp"
        android:layout_marginHorizontal="16dp"/>
    <FrameLayout
        android:id="@+id/fl_cover"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@+id/etv_content">
        <com.jbzd.media.movecartoons.view.SquareGridView
            android:id="@+id/square_grid_images"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="7.5dp"
            android:layout_marginRight="7.5dp"
            android:layout_marginHorizontal="7.5dp"/>
        <RelativeLayout
            android:id="@+id/rl_item_video"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginHorizontal="16dp">
            <ImageView
                android:id="@+id/iv_video_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_media_player"
                android:scaleType="centerInside"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
    </FrameLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/black"
        android:id="@+id/tv_deposit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fl_cover"/>
    <com.jbzd.media.movecartoons.view.text.ImageTextView
        android:textSize="14sp"
        android:textColor="@color/black"
        android:orientation="horizontal"
        android:id="@+id/tv_expand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="展开详情"
        android:drawableRight="@drawable/ic_expand"
        android:layout_marginEnd="16dp"
        app:drawable_height="12dp"
        app:drawable_width="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fl_cover"/>
</androidx.constraintlayout.widget.ConstraintLayout>
