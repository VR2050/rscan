<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_task_every_day"
    android:background="@color/white"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="30dp"
    android:paddingHorizontal="10dp">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_task_icon"
        android:layout_width="43dp"
        android:layout_height="43dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/black"
        android:gravity="center_vertical"
        android:id="@+id/tv_task_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@+id/iv_task_icon"
        app:layout_constraintTop_toTopOf="@+id/iv_task_icon"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/black40"
        android:id="@+id/tv_task_title_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintEnd_toStartOf="@+id/tv_task_action_state"
        app:layout_constraintStart_toStartOf="@+id/tv_task_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_task_title"/>
    <com.noober.background.view.BLTextView
        android:textSize="11sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_task_action_state"
        android:background="@drawable/btn_orange_style"
        android:paddingLeft="13dp"
        android:paddingTop="8dp"
        android:paddingRight="13dp"
        android:paddingBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="13dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_task_title_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_task_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
