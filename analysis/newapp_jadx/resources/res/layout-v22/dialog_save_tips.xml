<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/ll_card"
            android:background="@drawable/border_normal_shadow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="44dp"
            android:layout_marginRight="44dp"
            android:layout_marginHorizontal="44dp">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:paddingTop="30dp"
                android:paddingBottom="25dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="是否保存修改"/>
            <View
                android:background="#7fbcfc"
                android:layout_width="match_parent"
                android:layout_height="1px"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="52dp">
                <com.qunidayede.supportlibrary.widget.CommonShapeButton
                    android:textSize="15sp"
                    android:textColor="@color/main_74b4fb"
                    android:gravity="center"
                    android:id="@+id/btn_cancel"
                    android:visibility="visible"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="放 弃"
                    android:layout_weight="1"
                    app:csb_cornerRadius="12.5dp"
                    app:csb_endColor="@color/transparent"
                    app:csb_startColor="@color/transparent"
                    app:csb_textColor="@color/main_74b4fb"
                    app:csb_textSize="13sp"/>
                <View
                    android:background="#7fbcfc"
                    android:layout_width="1px"
                    android:layout_height="match_parent"/>
                <com.qunidayede.supportlibrary.widget.CommonShapeButton
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:id="@+id/btn_submit_aichangeface_video"
                    android:visibility="visible"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="保 存"
                    android:layout_weight="1"
                    app:csb_cornerRadius="12.5dp"
                    app:csb_endColor="@color/transparent"
                    app:csb_startColor="@color/transparent"
                    app:csb_textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
