<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@color/white"
            android:layout_width="280dp"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/color_gold_main"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="温馨提示"/>
            <TextView
                android:textSize="15sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="25dp"
                android:text="购买VIP即可查看此贴详情"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="30dp"
                android:layout_marginHorizontal="20dp">
                <com.jbzd.media.movecartoons.view.GradientRoundCornerButton
                    android:id="@+id/close"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:text="取消"
                    android:layout_weight="1"
                    app:gradientBg="@drawable/btn_submit_style"
                    app:gradientCornerRadius="15dp"
                    app:txtColor="@color/color_gold_main_c"/>
                <View
                    android:layout_width="20dp"
                    android:layout_height="1dp"/>
                <com.jbzd.media.movecartoons.view.GradientRoundCornerButton
                    android:id="@+id/vip"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:text="开通会员"
                    android:layout_weight="1"
                    app:gradientBg="@drawable/btn_submit_style"
                    app:gradientCornerRadius="15dp"
                    app:txtColor="@color/color_gold_main_c"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
