<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/color_222222"
    android:paddingRight="10dp"
    android:paddingBottom="5dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:dividerPadding="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:showDividers="middle">
        <RelativeLayout
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp">
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:paddingLeft="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="阅读设置"
                android:layout_centerInParent="true"/>
            <ImageView
                android:id="@+id/iv_close_novel_read_setting"
                android:background="@drawable/style_icon_all"
                android:padding="3dp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginRight="0dp"
                android:src="@drawable/ic_close"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="文章字号"
                android:layout_weight="3"/>
            <RelativeLayout
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingVertical="10dp">
                <TextView
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/tv_textsize_small"
                    android:background="@drawable/bg_textsize_style"
                    android:paddingLeft="16dp"
                    android:paddingTop="4dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A-"
                    android:layout_alignParentLeft="true"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"/>
                <TextView
                    android:textColor="@color/white"
                    android:id="@+id/tv_textsize_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="16"
                    android:layout_centerInParent="true"/>
                <TextView
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/tv_textsize_big"
                    android:background="@drawable/bg_textsize_style"
                    android:paddingLeft="16dp"
                    android:paddingTop="4dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A+"
                    android:layout_alignParentRight="true"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"/>
            </RelativeLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="15dp"
            android:paddingBottom="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="15dp">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="调整亮度"
                android:layout_weight="3"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <SeekBar
                    android:id="@+id/progress_brightness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="4dp"
                    android:max="100"
                    android:progress="10"
                    android:progressDrawable="@drawable/seek_sutopage_default"
                    android:minHeight="4dp"
                    android:thumb="@drawable/seekbar_comicschapter"
                    android:layout_weight="1"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="主题颜色"
                android:layout_weight="3"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <RadioGroup
                    android:orientation="horizontal"
                    android:id="@+id/ra_group_background"
                    android:paddingLeft="-15dp"
                    android:paddingRight="-15dp"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:paddingHorizontal="-15dp">
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:gravity="center_horizontal"
                        android:id="@+id/ra_novelcolor_one"
                        android:paddingTop="10dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:drawableTop="@drawable/style_novel_colorone"
                        android:layout_weight="1"
                        app:drawable_height="28dp"
                        app:drawable_width="28dp"/>
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:gravity="center_horizontal"
                        android:id="@+id/ra_novelcolor_two"
                        android:paddingTop="10dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:drawableTop="@drawable/style_novel_colortwo"
                        android:layout_weight="1"
                        app:drawable_height="28dp"
                        app:drawable_width="28dp"/>
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:gravity="center_horizontal"
                        android:id="@+id/ra_novelcolor_three"
                        android:paddingTop="10dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:drawableTop="@drawable/style_novel_colorthree"
                        android:layout_weight="1"
                        app:drawable_height="28dp"
                        app:drawable_width="28dp"/>
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:gravity="center_horizontal"
                        android:id="@+id/ra_novelcolor_four"
                        android:paddingTop="10dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:drawableTop="@drawable/style_novel_colorfour"
                        android:layout_weight="1"
                        app:drawable_height="28dp"
                        app:drawable_width="28dp"/>
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:gravity="center_horizontal"
                        android:id="@+id/ra_novelcolor_five"
                        android:paddingTop="10dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:drawableTop="@drawable/style_novel_colorfive"
                        android:layout_weight="1"
                        app:drawable_height="28dp"
                        app:drawable_width="28dp"/>
                </RadioGroup>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="主题颜色"
                android:layout_weight="3"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1">
                    <ImageView
                        android:background="@drawable/theme_novelcolor_white"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:paddingRight="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1">
                    <ImageView
                        android:background="@drawable/theme_novelcolor_yellow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:paddingRight="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1">
                    <ImageView
                        android:background="@drawable/theme_novelcolor_three"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:paddingLeft="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1">
                    <ImageView
                        android:background="@drawable/theme_novelcolor_four"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1">
                    <ImageView
                        android:background="@drawable/theme_novelcolor_five"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="翻页模式"
                android:layout_weight="3"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <RadioGroup
                    android:orientation="horizontal"
                    android:id="@+id/rg_nav"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="15dp">
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:textSize="11sp"
                        android:textColor="@color/color_novepage_model"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/rb_novelred_fg"
                        android:background="@drawable/bg_tag_new_style"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_marginRight="10dp"
                        android:button="@null"
                        android:text="覆盖"
                        android:layout_weight="1"/>
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:textSize="11sp"
                        android:textColor="@color/color_novepage_model"
                        android:gravity="center"
                        android:id="@+id/rb_novelred_sx"
                        android:background="@drawable/bg_tag_new_style"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_marginRight="10dp"
                        android:button="@null"
                        android:text="上下"
                        android:layout_weight="1"/>
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:textSize="11sp"
                        android:textColor="@color/color_novepage_model"
                        android:gravity="center"
                        android:id="@+id/rb_novelred_fz"
                        android:background="@drawable/bg_tag_new_style"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_marginRight="10dp"
                        android:button="@null"
                        android:text="仿真"
                        android:layout_weight="1"/>
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:textSize="11sp"
                        android:textColor="@color/color_novepage_model"
                        android:gravity="center"
                        android:id="@+id/rb_novelred_ph"
                        android:background="@drawable/bg_tag_new_style"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_marginRight="10dp"
                        android:button="@null"
                        android:text="平滑"
                        android:layout_weight="1"/>
                    <com.jbzd.media.movecartoons.view.text.MyRadioButton
                        android:textSize="11sp"
                        android:textColor="@color/color_novepage_model"
                        android:gravity="center"
                        android:id="@+id/rb_novelred_default"
                        android:background="@drawable/bg_tag_new_style"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:button="@null"
                        android:text="无"
                        android:layout_weight="1"/>
                </RadioGroup>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="深色模式"
                android:layout_weight="3"/>
            <LinearLayout
                android:gravity="right"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <Switch
                    android:id="@+id/sw_switch_model_dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumb="@drawable/selector_thumb"
                    android:track="@drawable/selector_track"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
