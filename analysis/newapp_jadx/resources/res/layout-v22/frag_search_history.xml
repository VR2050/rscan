<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_all_shape"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/ll_top"
        android:background="@drawable/bg_round25_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="12dp"
        android:layout_marginHorizontal="12dp">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/search_layout_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/ll_search"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1">
                <com.qunidayede.supportlibrary.widget.ClearEditText
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/color_gold_main_near"
                    android:id="@+id/cet_input"
                    android:background="@drawable/search_bar_bg_half"
                    android:paddingLeft="10dp"
                    android:paddingRight="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:hint="搜一下，您想看的这里都有"
                    android:singleLine="true"
                    android:drawableLeft="@drawable/icon_search"
                    android:drawablePadding="5dp"
                    android:imeOptions="actionSearch"
                    android:drawableTint="@color/color_gold_main_near"/>
            </LinearLayout>
            <TextView
                android:textSize="15sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:id="@+id/tv_doSearch"
                android:background="@drawable/bg_search_style"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_margin="2dp"
                android:text="搜索"
                android:paddingHorizontal="15dp"/>
        </LinearLayout>
    </LinearLayout>
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:background="@color/transparent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        app:layout_behavior="@string/my_appbar_fling_behavior">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="enterAlways|scroll">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_hty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10">
                    <TextView
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="历史记录"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:id="@+id/tv_clear_history"
                        android:paddingLeft="5dp"
                        android:paddingTop="5dp"
                        android:paddingRight="5dp"
                        android:paddingBottom="5dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="清除搜索历史"
                        android:drawableRight="@drawable/icon_clear_history"
                        android:drawablePadding="2dp"
                        android:paddingHorizontal="5dp"
                        android:paddingVertical="5dp"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_hty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:overScrollMode="never"
                    android:layout_marginHorizontal="10dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="8"/>
            </LinearLayout>
            <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
                android:id="@+id/banner_parent_search"
                android:background="@color/transparent"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:scale_height="100dp"
                app:scale_width="375dp">
                <com.youth.banner.Banner
                    android:id="@+id/banner_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:banner_indicator_gravity="right"
                    app:banner_indicator_height="3dp"
                    app:banner_indicator_marginBottom="10dp"
                    app:banner_indicator_marginRight="20dp"
                    app:banner_indicator_normal_color="@color/white60"
                    app:banner_indicator_normal_width="7dp"
                    app:banner_indicator_radius="4dp"
                    app:banner_indicator_selected_color="@color/color_gold_main"
                    app:banner_indicator_selected_width="13dp"
                    app:banner_radius="0dp"/>
            </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_hot"
                android:background="@drawable/bg_search_tag"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="10dp"
                android:layout_marginHorizontal="10dp">
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#ff3f3f"
                    android:paddingLeft="10dp"
                    android:paddingTop="10dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="热门标签"
                    android:drawableLeft="@drawable/icon_search_hot"
                    android:drawablePadding="5dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="10dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_hotWords"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:overScrollMode="never"
                    android:paddingHorizontal="10dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_hotWords_post"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:overScrollMode="never"
                    android:paddingHorizontal="10dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>
    <FrameLayout
        android:id="@+id/frag_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="5dp"/>
</LinearLayout>
