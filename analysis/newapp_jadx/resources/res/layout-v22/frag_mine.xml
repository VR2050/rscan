<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.drake.brv.PageRefreshLayout
        android:id="@+id/mine_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        app:srlEnableLoadMore="false"
        app:srlEnableOverScrollBounce="false">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_bottom"
                android:background="@drawable/bg_all_shape"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@color/transparent"
                    android:paddingBottom="6dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:orientation="horizontal"
                        android:id="@+id/layout_user_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginTop="75dp"
                        android:layout_marginBottom="10dp"
                        app:layout_constraintTop_toTopOf="parent">
                        <RelativeLayout
                            android:id="@+id/ll_avtar"
                            android:layout_width="68dp"
                            android:layout_height="68dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/iv_user_avater"
                                android:background="@drawable/ic_place_holder_circle_51"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/ic_place_holder_circle_51"
                                android:scaleType="centerCrop"
                                app:shapeAppearance="@style/CircleStyle"/>
                            <ImageView
                                android:id="@+id/iv_user_sex"
                                android:padding="4dp"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/icon_sexfemale"
                                android:layout_alignParentRight="true"
                                android:layout_alignParentBottom="true"/>
                        </RelativeLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            app:layout_constraintStart_toEndOf="@+id/ll_avtar">
                            <TextView
                                android:textSize="19sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:id="@+id/tv_name_new"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"/>
                            <TextView
                                android:textSize="13sp"
                                android:textColor="@color/black39"
                                android:id="@+id/tv_num_new"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <androidx.constraintlayout.widget.Group
                            android:id="@+id/vip_group_ids"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <com.jbzd.media.movecartoons.view.text.ImageTextView
                            android:textSize="11sp"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:id="@+id/itv_sign_mine"
                            android:paddingLeft="10dp"
                            android:paddingTop="5dp"
                            android:paddingRight="10dp"
                            android:paddingBottom="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:drawableStart="@drawable/icon_qiandao_search"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <ImageView
                            android:id="@+id/iv_share_promotion"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/icon_share_mine"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/ll_membercenter_wallet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="16dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="16dp"
                        android:layout_marginHorizontal="16dp"
                        app:layout_constraintStart_toStartOf="@+id/layout_user_info"
                        app:layout_constraintTop_toBottomOf="@+id/layout_user_info">
                        <RelativeLayout
                            android:id="@+id/rl_goVip"
                            android:background="@drawable/bg_mine_vipbg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp">
                            <LinearLayout
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="11dp"
                                android:layout_marginTop="5dp"
                                android:paddingVertical="10dp">
                                <TextView
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:ellipsize="end"
                                    android:id="@+id/tv_groupTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="会员中心"
                                    android:maxLines="1"/>
                                <TextView
                                    android:textSize="13sp"
                                    android:textColor="@color/white"
                                    android:ellipsize="end"
                                    android:id="@+id/be_vip"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="去开通会员吧"
                                    android:maxLines="1"/>
                            </LinearLayout>
                        </RelativeLayout>
                        <RelativeLayout
                            android:id="@+id/rl_goRecharge"
                            android:background="@drawable/bg_mine_balance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_weight="1">
                            <LinearLayout
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="11dp"
                                android:layout_marginTop="5dp"
                                android:paddingVertical="10dp">
                                <TextView
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:ellipsize="end"
                                    android:id="@+id/tv_balance_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="金币钱包"
                                    android:maxLines="1"/>
                                <TextView
                                    android:textSize="13sp"
                                    android:textColor="@color/white"
                                    android:ellipsize="end"
                                    android:id="@+id/tv_balance"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="余额 330"
                                    android:maxLines="1"/>
                            </LinearLayout>
                        </RelativeLayout>
                    </LinearLayout>
                    <RelativeLayout
                        android:id="@+id/ll_vip_infos"
                        android:background="@drawable/bg_vip_tips"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginHorizontal="10dp"
                        app:layout_constraintStart_toStartOf="@+id/ll_membercenter_wallet"
                        app:layout_constraintTop_toBottomOf="@+id/ll_membercenter_wallet">
                        <ImageView
                            android:id="@+id/iv_viptips_show"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="8dp"
                            android:src="@drawable/icon_viptips_show"
                            android:adjustViewBounds="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"/>
                        <LinearLayout
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true">
                            <TextView
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:id="@+id/tv_group_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                            <TextView
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:id="@+id/tv_group_endtime"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </RelativeLayout>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/grid_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="10dp"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="4"/>
                    <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
                        android:id="@+id/banner_parent"
                        android:background="@drawable/ic_holder_ad200_51"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginBottom="10dp"
                        android:layout_marginHorizontal="10dp"
                        app:scale_height="100dp"
                        app:scale_width="375dp">
                        <com.youth.banner.Banner
                            android:id="@+id/banner_mine"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:banner_indicator_gravity="right"
                            app:banner_indicator_height="5dp"
                            app:banner_indicator_marginBottom="5dp"
                            app:banner_indicator_marginRight="7dp"
                            app:banner_indicator_normal_color="@color/black"
                            app:banner_indicator_normal_width="5dp"
                            app:banner_indicator_selected_color="#f0d187"
                            app:banner_indicator_selected_width="5dp"/>
                    </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAds"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="12dp"
                        android:layout_marginHorizontal="12dp"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_mine_one"
                        android:background="@drawable/bg_search_tag"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:nestedScrollingEnabled="false"
                        android:layout_marginHorizontal="10dp"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="4"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_mine_two"
                        android:background="@drawable/bg_search_tag"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="10dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginBottom="10dp"
                        android:nestedScrollingEnabled="false"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginVertical="10dp"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_mine_three"
                        android:background="@drawable/bg_search_tag"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="10dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="10dp"
                        android:nestedScrollingEnabled="false"
                        android:layout_marginHorizontal="10dp"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="4"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:background="@drawable/bg_search_tag"
                        android:padding="5dp"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginHorizontal="10dp">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:id="@+id/ll_service_online"
                            android:padding="@dimen/app_content_margin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <ImageView
                                android:id="@+id/iv_icon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/icon_me_list_service"
                                android:scaleType="fitXY"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/black"
                                android:id="@+id/tv_bottomitem_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:layout_marginBottom="5dp"
                                android:text="在线客服"
                                android:layout_marginVertical="5dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:id="@+id/ll_service_group"
                            android:padding="@dimen/app_content_margin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/mine_service_group"
                                android:scaleType="fitXY"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/black"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:layout_marginBottom="5dp"
                                android:text="官方群组"
                                android:layout_marginVertical="5dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:id="@+id/ll_service_applist"
                            android:padding="@dimen/app_content_margin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/app_recommend"
                                android:scaleType="fitXY"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/black"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:layout_marginBottom="5dp"
                                android:text="应用推荐"
                                android:layout_marginVertical="5dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:background="@color/white"
                android:paddingLeft="10dp"
                android:paddingTop="35dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我的"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:id="@+id/iv_setting"
                    android:padding="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableLeft="@drawable/mine_icon_setting"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/black54"
                android:gravity="center"
                android:layout_gravity="bottom"
                android:id="@+id/tv_version_name"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="V4.5"
                android:paddingVertical="10dp"/>
        </FrameLayout>
    </com.drake.brv.PageRefreshLayout>
</LinearLayout>
