<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:id="@+id/ll_item_follow"
    android:tag="layout/item_follow_0"
    android:background="@color/white"
    android:paddingLeft="@dimen/app_content_margin"
    android:paddingTop="5dp"
    android:paddingRight="@dimen/app_content_margin"
    android:paddingBottom="5dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/app_content_margin"
    android:paddingVertical="5dp">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/civ_avatar"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@drawable/ic_place_holder_circle_51"
        app:shapeAppearance="@style/CircleStyle"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/black"
        android:ellipsize="end"
        android:id="@+id/tv_postdetail_nickname"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/app_content_margin"
        android:layout_marginRight="@dimen/app_content_margin"
        android:maxLines="1"
        android:layout_weight="1"
        android:layout_marginHorizontal="@dimen/app_content_margin"/>
    <com.jbzd.media.movecartoons.view.FollowTextView
        android:textSize="14sp"
        android:textColor="@color/selector_text_color_follow"
        android:gravity="center"
        android:id="@+id/itv_item_follow_state"
        android:background="@drawable/state_follow_style"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:paddingVertical="3dp"/>
    <ToggleButton
        android:textSize="12sp"
        android:textColor="@drawable/selector_follow_text"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/btn_follow"
        android:tag="binding_1"
        android:background="@drawable/selector_btn_follow"
        android:visibility="gone"
        android:layout_width="52dp"
        android:layout_height="24dp"
        android:textOn="@string/un_focus"
        android:textOff="@string/focus"/>
</LinearLayout>
