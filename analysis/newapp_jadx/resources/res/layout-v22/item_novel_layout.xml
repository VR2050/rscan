<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:tag="layout/item_novel_layout_0"
    android:background="@color/white"
    android:paddingBottom="5dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
            android:id="@+id/item_parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:scale_height="180dp"
            app:scale_width="140dp">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                app:shapeAppearance="@style/RoundedStyle"/>
            <RelativeLayout
                android:id="@+id/rl_coverOption"
                android:tag="binding_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <include layout="@layout/video_item_cover_hot"/>
                <ImageView
                    android:id="@+id/iv_novel_audio"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/icon_novel_audio"
                    android:adjustViewBounds="true"
                    android:layout_alignParentRight="true"/>
            </RelativeLayout>
        </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_name"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="2dp">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:ellipsize="end"
                    android:id="@+id/tv_novel_name"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:layout_weight="1"
                    android:paddingVertical="5dp"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="@color/color_ff6a00"
                    android:id="@+id/tv_novel_category_subtitle"
                    android:background="@drawable/shape_comic_type"
                    android:paddingLeft="6dp"
                    android:paddingTop="2dp"
                    android:paddingRight="6dp"
                    android:paddingBottom="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="2"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
