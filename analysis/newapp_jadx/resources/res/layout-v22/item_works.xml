<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="10dp">
    <RelativeLayout
        android:id="@+id/rl_img"
        android:background="@drawable/video_cover_bg"
        android:padding="0.5dp"
        android:layout_width="153dp"
        android:layout_height="86dp">
        <ImageView
            android:id="@+id/iv_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_place_holder_horizontal"
            android:scaleType="centerCrop"/>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true">
            <include layout="@layout/layout_video_type"/>
        </RelativeLayout>
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="8sp"
            android:textColor="@color/black"
            android:gravity="center_vertical"
            android:id="@+id/itv_duration"
            android:background="@drawable/bg_duration"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:layout_width="wrap_content"
            android:layout_height="14dp"
            android:layout_marginLeft="8dp"
            android:layout_marginBottom="8dp"
            android:drawableLeft="@drawable/icon_home_video_duration"
            android:drawablePadding="3dp"
            android:layout_alignParentBottom="true"
            android:paddingHorizontal="8dp"
            app:drawable_height="8dp"
            app:drawable_width="8dp"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_marginLeft="8dp">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/black"
            android:ellipsize="end"
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginRight="3dp"
            android:maxLines="2"
            android:lineSpacingMultiplier="1.3"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/main_88bcff"
            android:ellipsize="end"
            android:id="@+id/tv_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:lineSpacingMultiplier="1.3"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <LinearLayout
            android:gravity="bottom"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="11sp"
                android:textColor="#fab626"
                android:id="@+id/tv_reason"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/main_88bcff"
                android:id="@+id/tv_more"
                android:paddingLeft="3dp"
                android:paddingRight="3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=". . ."
                android:paddingHorizontal="3dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
