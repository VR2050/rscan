<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/title_layout"
        android:background="#4d000000"
        android:paddingTop="20dp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_bar_height">
        <RelativeLayout
            android:id="@+id/btn_titleBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentLeft="true">
            <ImageView
                android:id="@+id/iv_titleLeftIcon"
                android:background="@drawable/style_icon_all"
                android:padding="8dp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:src="@drawable/ic_btn_icon_black"
                android:scaleType="fitCenter"
                android:layout_centerVertical="true"
                android:layout_marginHorizontal="10dp"/>
        </RelativeLayout>
        <TextView
            android:textSize="17sp"
            android:textColor="#ffdba5"
            android:gravity="center"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text=""
            android:layout_centerHorizontal="true"/>
        <RelativeLayout
            android:id="@+id/btn_titleRight"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/black"
                android:id="@+id/tv_titleRight"
                android:padding="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:text=""
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/btn_titleRightIcon"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:paddingHorizontal="10dp">
            <ImageView
                android:id="@+id/iv_titleRightIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="fitCenter"
                android:maxHeight="20dp"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <View
            android:id="@+id/title_divider"
            android:background="#0cffffff"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_height"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:background="@color/transparent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        app:layout_behavior="@string/my_appbar_fling_behavior">
        <com.flyco.tablayout.SlidingTabLayout
            android:id="@+id/sorting_tab_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>
    </com.google.android.material.appbar.AppBarLayout>
    <com.jbzd.media.movecartoons.view.page.MyViewPager
        android:id="@+id/vp_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"/>
</LinearLayout>
