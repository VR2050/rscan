<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include layout="@layout/title_bar_layout"/>
    <FrameLayout
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="56dp"
            android:paddingHorizontal="16dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_description"
                    android:paddingTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/ll_posttopic_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="15sp"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="选择话题"/>
                        <RelativeLayout
                            android:background="@drawable/bg_coinrecharge_style"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp">
                            <TextView
                                android:textSize="14sp"
                                android:textColor="@color/color_ff6a00"
                                android:textColorHint="@color/color_ff6a00"
                                android:id="@+id/tv_tags_selected"
                                android:padding="8dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="2dp"
                                android:hint="请选择话题"/>
                            <com.jbzd.media.movecartoons.view.text.ImageTextView
                                android:textSize="14sp"
                                android:textColor="@color/black"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/itv_tags_more"
                                android:padding="8dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="2dp"
                                android:text="选择"
                                android:drawableRight="@drawable/icon_arrow_gray"
                                android:drawablePadding="3dp"
                                android:layout_alignParentRight="true"
                                android:layout_centerVertical="true"
                                app:drawable_height="14dp"
                                app:drawable_width="9dp"/>
                        </RelativeLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/ll_post_coin_set"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:layout_constraintTop_toBottomOf="@+id/ll_posttopic_name">
                        <TextView
                            android:textSize="15sp"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="设置价格"/>
                        <LinearLayout
                            android:orientation="vertical"
                            android:background="@drawable/bg_input_login"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp">
                            <androidx.appcompat.widget.AppCompatEditText
                                android:textSize="14sp"
                                android:textColor="@color/black"
                                android:textColorHint="@color/black26"
                                android:id="@+id/ed_post_money"
                                android:background="@null"
                                android:padding="8dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="请输入0-99金币，不填写则免费"
                                android:maxLength="3"
                                android:inputType="number"
                                android:textCursorDrawable="@drawable/color_cursor"/>
                            <TextView
                                android:background="@color/color_999999"
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:alpha="0.1"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/ll_post_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:layout_constraintTop_toBottomOf="@+id/ll_post_coin_set">
                        <TextView
                            android:textSize="15sp"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="填写标题"/>
                        <LinearLayout
                            android:orientation="vertical"
                            android:background="@drawable/bg_input_login"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp">
                            <androidx.appcompat.widget.AppCompatEditText
                                android:textSize="14sp"
                                android:textColor="@color/black"
                                android:textColorHint="@color/black26"
                                android:id="@+id/ed_postopic_title"
                                android:background="@null"
                                android:padding="8dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="请输入标题"
                                android:maxLines="1"
                                android:textCursorDrawable="@drawable/color_cursor"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/ll_post_coin_set"/>
                            <TextView
                                android:background="@color/color_999999"
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:alpha="0.1"/>
                        </LinearLayout>
                    </LinearLayout>
                    <androidx.appcompat.widget.AppCompatEditText
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/black26"
                        android:gravity="start|top"
                        android:id="@+id/et_aivideochangeface_info"
                        android:background="@drawable/bg_input_login"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="179dp"
                        android:layout_marginTop="@dimen/dp_10"
                        android:layout_marginBottom="@dimen/dp_10"
                        android:hint="[选填]请输入帖子内容"
                        android:maxLines="5"
                        android:maxLength="500"
                        android:textCursorDrawable="@drawable/color_cursor"
                        android:layout_marginVertical="@dimen/dp_10"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ll_post_title"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:orientation="vertical"
                    android:id="@+id/cl_media"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cl_description">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_add"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/ll_postimage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <LinearLayout
                                android:orientation="horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:textSize="16sp"
                                    android:textColor="@color/black"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="上传封面"/>
                                <TextView
                                    android:textSize="14sp"
                                    android:textColor="@color/color_999999"
                                    android:id="@+id/tv_media_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="*最多上传9张，最大每张1M"/>
                            </LinearLayout>
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_image"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/tv_media_title"/>
                            <TextView
                                android:textColor="@color/color_ff6a00"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp"
                                android:text="默认第一张为封面图"
                                android:layout_marginVertical="10dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/ll_postvideo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="15dp"
                            android:layout_marginBottom="15dp"
                            android:layout_marginVertical="15dp"
                            app:layout_constraintLeft_toLeftOf="@+id/ll_postimage"
                            app:layout_constraintTop_toBottomOf="@+id/ll_postimage">
                            <LinearLayout
                                android:orientation="horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:textSize="16sp"
                                    android:textColor="@color/black"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="上传视频"/>
                                <TextView
                                    android:textSize="14sp"
                                    android:textColor="@color/color_999999"
                                    android:id="@+id/tv_media_video_tips"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="*最多100M以内"/>
                            </LinearLayout>
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_video"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp"
                                android:layout_marginVertical="10dp"/>
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_gravity="bottom"
            android:id="@+id/btn_submit_aichangeface_video"
            android:background="@drawable/btn_orange_style"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:text="确认上传"/>
        <FrameLayout
            android:id="@+id/error_view"
            android:background="?attr/my_page_bg"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <include layout="@layout/error_view"/>
        </FrameLayout>
    </FrameLayout>
</LinearLayout>
