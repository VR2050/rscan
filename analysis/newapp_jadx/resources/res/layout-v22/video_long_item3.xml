<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="wrap_content"
    android:layout_height="130dp"
    android:layout_marginLeft="6dp">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="140dp"
        android:layout_height="80dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
                    android:id="@+id/srl_coverParent_vertical"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:scale_height="16dp"
                    app:scale_width="12dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_video_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_place_holder_vertical_51"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        app:shapeAppearance="@style/RoundedStyle"/>
                </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
                <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
                    android:id="@+id/srl_coverParent_img"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:scale_height="9dp"
                    app:scale_width="16dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_video"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_place_holder_circle_51"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        app:shapeAppearance="@style/RoundedStyle"/>
                </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:layout_gravity="bottom"
                    android:id="@+id/tv_duration"
                    android:background="@drawable/bg_time"
                    android:paddingLeft="7dp"
                    android:paddingTop="2dp"
                    android:paddingRight="7dp"
                    android:paddingBottom="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="2dp"/>
                <RelativeLayout
                    android:layout_gravity="bottom"
                    android:id="@+id/ll_ad_new"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:id="@+id/itv_ad_new"
                        android:background="@drawable/home_duration_bg"
                        android:paddingLeft="4dp"
                        android:paddingTop="2dp"
                        android:paddingRight="4dp"
                        android:paddingBottom="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        android:text="广告"
                        android:layout_alignParentRight="true"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp"/>
                </RelativeLayout>
            </FrameLayout>
            <LinearLayout
                android:gravity="center"
                android:id="@+id/ll_money_vip"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true">
                <com.jbzd.media.movecartoons.view.text.ImageTextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/itv_icon_money"
                    android:background="@drawable/bg_video_lefttop"
                    android:paddingLeft="8dp"
                    android:paddingTop="1dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="1dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8"
                    android:drawableLeft="@drawable/icon_coin_balance_left"
                    android:drawablePadding="3dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="1dp"
                    app:drawable_height="10dp"
                    app:drawable_width="10dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/tv_video_type"
                    android:background="@drawable/bg_video_vip"
                    android:paddingLeft="8dp"
                    android:paddingTop="1dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="1dp"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIP"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="1dp"/>
            </LinearLayout>
            <ImageView
                android:id="@+id/iv_ico_type"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:src="@drawable/icon_mh_free"
                android:adjustViewBounds="true"/>
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textSize="12sp"
                android:textColor="@color/price"
                android:gravity="center"
                android:id="@+id/iv_coin_video"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:drawableLeft="@drawable/icon_coin_balance_left"
                android:drawablePadding="2dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentRight="true"
                app:drawable_height="15dp"
                app:drawable_width="15dp"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/ll_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/black"
            android:id="@+id/tv_name"
            android:paddingTop="1.5dp"
            android:paddingBottom="1.5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:maxLines="1"
            android:paddingVertical="1.5dp"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_ff6a00"
            android:id="@+id/tv_video_click"
            android:background="@drawable/shape_comic_type"
            android:paddingLeft="6dp"
            android:paddingTop="3dp"
            android:paddingRight="6dp"
            android:paddingBottom="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:maxLines="1"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"/>
    </LinearLayout>
</LinearLayout>
