<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/touchBlocker"
        android:background="@android:color/transparent"
        android:focusable="false"
        android:clickable="false"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="42dp"
        android:layout_marginTop="70dp"
        android:layout_marginRight="42dp"
        android:layout_marginHorizontal="42dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.youth.banner.Banner
                android:id="@+id/banner"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:banner_indicator_gravity="center"
                app:banner_indicator_height="3dp"
                app:banner_indicator_normal_color="@color/white60"
                app:banner_indicator_normal_width="8dp"
                app:banner_indicator_radius="4dp"
                app:banner_indicator_selected_color="@color/white"
                app:banner_indicator_selected_width="28dp"
                app:banner_radius="0dp"
                app:layout_constraintDimensionRatio="w,328:276"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <com.noober.background.view.BLTextView
                android:textSize="14sp"
                android:textColor="#8a0000"
                android:gravity="center"
                android:id="@+id/btnVip"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginTop="12dp"
                android:text="VIP去广告 &gt;"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="12dp"
                android:translationZ="20dp"
                android:elevation="20dp"
                app:bl_corners_radius="8dp"
                app:bl_gradient_endColor="#ff9756"
                app:bl_gradient_startColor="#ffdfae"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:id="@+id/bottomMask"
                android:background="@drawable/bg_ad_bottom_mask"
                android:layout_width="0dp"
                android:layout_height="110dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/banner"/>
            <com.noober.background.view.BLTextView
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/tvCountdown"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="16dp"
                android:text="10秒后可继续阅读"
                android:translationZ="10dp"
                android:elevation="10dp"
                android:layout_marginHorizontal="16dp"
                app:bl_corners_radius="20dp"
                app:bl_solid_color="#ff4f00"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
