<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/lLayout_bg"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:orientation="vertical"
            android:id="@+id/title_layout"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <RelativeLayout
                android:id="@+id/btn_titleBack"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentLeft="true"
                android:paddingHorizontal="10dp">
                <ImageView
                    android:id="@+id/iv_titleLeftIcon"
                    android:background="@drawable/style_icon_all"
                    android:padding="8dp"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_btn_icon_black"
                    android:scaleType="fitCenter"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <TextView
                android:textSize="17sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text=""
                android:layout_centerHorizontal="true"/>
            <RelativeLayout
                android:id="@+id/btn_titleRight"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentRight="true">
                <TextView
                    android:textSize="13sp"
                    android:textColor="?attr/title_bar_color"
                    android:id="@+id/tv_titleRight"
                    android:padding="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:id="@+id/btn_titleRightIcon"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentRight="true"
                android:paddingHorizontal="10dp">
                <ImageView
                    android:id="@+id/iv_titleRightIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="fitCenter"
                    android:maxHeight="20dp"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <View
                android:id="@+id/title_divider"
                android:background="#0cffffff"
                android:visibility="invisible"
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:id="@+id/ll_blocklist_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
