<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/root"
    android:tag="layout/item_video_layout_0"
    android:background="@color/white"
    android:paddingBottom="5dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_video"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="h,2:1.2"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearance="@style/RoundedStyle"/>
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/img_stroke"
        android:tag="binding_1"
        android:padding="2dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="h,2:1.2"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearance="@style/RoundedStyle"/>
    <ImageView
        android:id="@+id/iv_ico_type"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="18dp"
        android:src="@drawable/icon_mh_free"
        android:adjustViewBounds="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:gravity="center"
        android:id="@+id/layout_isHide_vip"
        android:background="@drawable/bg_video_lefttop"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/img_icon_money"
            android:tag="binding_2"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_marginRight="2dp"
            android:src="@drawable/icon_coin_balance_left"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/tv_video_type"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIP"
            android:paddingVertical="1dp"/>
    </LinearLayout>
    <RelativeLayout
        android:paddingLeft="5dp"
        android:paddingTop="15dp"
        android:paddingRight="5dp"
        android:paddingBottom="3dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="5dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_video">
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="11sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/tv_count"
            android:tag="binding_3"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableLeft="@drawable/icon_video_count"
            android:drawablePadding="2dp"
            android:layout_alignParentLeft="true"
            android:fontFamily="@font/number"
            android:layout_marginStart="3dp"
            app:drawable_height="13dp"
            app:drawable_width="13dp"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/white"
            android:id="@+id/tv_duration"
            android:tag="binding_4"
            android:background="@drawable/bg_time"
            android:paddingLeft="7dp"
            android:paddingTop="4dp"
            android:paddingRight="7dp"
            android:paddingBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:layout_alignParentLeft="true"
            android:layout_marginEnd="3dp"
            android:paddingHorizontal="7dp"
            android:paddingVertical="4dp"/>
    </RelativeLayout>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/black"
        android:id="@+id/tv_name"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:paddingVertical="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_video"/>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/color_ff6a00"
        android:id="@+id/tv_video_click"
        android:background="@drawable/shape_comic_type"
        android:paddingLeft="6dp"
        android:paddingTop="2dp"
        android:paddingRight="6dp"
        android:paddingBottom="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="2"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_name"/>
</androidx.constraintlayout.widget.ConstraintLayout>
