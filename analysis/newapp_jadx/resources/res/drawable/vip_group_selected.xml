<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp"/>
            <gradient
                android:startColor="#6fa9f8"
                android:endColor="#ffbf1f"
                android:angle="360"
                android:type="linear"
                android:centerColor="#ec68ad"/>
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp"/>
            <solid android:color="@color/bgBlack"/>
        </shape>
    </item>
</layer-list>
