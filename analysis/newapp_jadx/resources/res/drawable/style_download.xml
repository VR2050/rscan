<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="5dp"/>
            <gradient
                android:startColor="#397786"
                android:endColor="#397786"
                android:angle="270"
                android:centerY="0.75"
                android:centerColor="#397786"/>
        </shape>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <corners android:radius="5dp"/>
                <gradient
                    android:startColor="#6ce3ff"
                    android:endColor="#6ce3ff"
                    android:angle="270"
                    android:centerY="0.75"
                    android:centerColor="#6ce3ff"/>
            </shape>
        </clip>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="5dp"/>
                <gradient
                    android:startColor="#6ce3ff"
                    android:endColor="#6ce3ff"
                    android:angle="270"
                    android:centerY="0.75"
                    android:centerColor="#6ce3ff"/>
            </shape>
        </clip>
    </item>
</layer-list>
