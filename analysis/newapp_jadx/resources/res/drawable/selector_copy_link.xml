<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <stroke
                android:width="1dp"
                android:color="#ff477a"/>
            <corners android:radius="99dp"/>
            <solid android:color="#1eff477a"/>
        </shape>
    </item>
    <item>
        <shape>
            <stroke
                android:width="1dp"
                android:color="#ff477a"/>
            <corners android:radius="99dp"/>
            <solid android:color="#0aff477a"/>
        </shape>
    </item>
</selector>
