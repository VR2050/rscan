<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <shape>
                <corners android:radius="20dp"/>
                <gradient
                    android:startColor="#ffffe6"
                    android:endColor="#a0907f"
                    android:angle="270"/>
            </shape>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <shape>
                <corners android:radius="20dp"/>
                <gradient
                    android:startColor="#ffffe6"
                    android:endColor="#a0907f"
                    android:angle="270"/>
            </shape>
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="20dp"/>
            <gradient
                android:startColor="#ebe4c6"
                android:endColor="#a5896b"
                android:angle="270"/>
        </shape>
    </item>
</selector>
