<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <gradient
                android:startColor="#fa505c"
                android:endColor="#fb3287"
                android:angle="360"
                android:type="linear"/>
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="#1b1b1b"/>
        </shape>
    </item>
</layer-list>
