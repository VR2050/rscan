<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/color_red_ff3f3f"/>
            <corners android:radius="25dp"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_red_ff3f3f"/>
        </shape>
    </item>
    <item android:state_pressed="false">
        <shape>
            <solid android:color="@color/color_ff4545"/>
            <corners android:radius="25dp"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_ff4545"/>
        </shape>
    </item>
</selector>
