<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <corners android:radius="25dp"/>
            <solid android:color="@color/color_ff6a00"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_ff6a00"/>
        </shape>
    </item>
    <item android:state_checked="true">
        <shape>
            <corners android:radius="25dp"/>
            <solid android:color="@color/color_ff6a00"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_ff6a00"/>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="25dp"/>
            <solid android:color="@color/color_ff6a00"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_ff6a00"/>
        </shape>
    </item>
    <item android:state_pressed="false">
        <shape>
            <corners android:radius="25dp"/>
            <solid android:color="@color/input_background_color"/>
            <stroke
                android:width="1dp"
                android:color="@color/input_background_color"/>
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="25dp"/>
            <solid android:color="@color/input_background_color"/>
            <stroke
                android:width="1dp"
                android:color="@color/input_background_color"/>
        </shape>
    </item>
</selector>
