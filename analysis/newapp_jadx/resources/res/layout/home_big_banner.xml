<?xml version="1.0" encoding="utf-8"?>
<com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/banner_parent"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:layout_marginBottom="8dp"
    app:scale_height="384dp"
    app:scale_width="375dp">
    <com.youth.banner.Banner
        android:id="@+id/banner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:banner_indicator_gravity="center"
        app:banner_indicator_height="4dp"
        app:banner_indicator_marginBottom="5dp"
        app:banner_indicator_normal_color="#5a5369"
        app:banner_indicator_normal_width="9dp"
        app:banner_indicator_radius="2dp"
        app:banner_indicator_selected_color="#f62fff"
        app:banner_indicator_selected_width="9dp"
        app:banner_radius="5dp"/>
</com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
