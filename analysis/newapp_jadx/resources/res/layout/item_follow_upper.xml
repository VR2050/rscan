<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:id="@+id/ll_follow_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp">
        <RelativeLayout
            android:layout_width="50dp"
            android:layout_height="50dp">
            <com.jbzd.media.movecartoons.view.image.CircleImageView
                android:id="@+id/civ_avatar"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/ic_place_holder_circle_51"
                android:layout_centerInParent="true"
                app:border_color="@color/white"
                app:border_width="0dp"/>
            <ImageView
                android:id="@+id/iv_subheader_vip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:src="@drawable/icon_vip_small"
                android:layout_alignParentRight="true"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1">
            <include layout="@layout/frag_profile"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/white_translucent"
                        android:ellipsize="end"
                        android:id="@+id/tv_follow_follows"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/white_translucent"
                        android:ellipsize="end"
                        android:id="@+id/tv_follow_fans"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:maxLines="1"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/selector_text_color_follow"
            android:gravity="center"
            android:id="@+id/itv_postuser_follow"
            android:background="@drawable/state_follow_style"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </LinearLayout>
</LinearLayout>
