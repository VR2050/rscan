<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/ll_adParent_bottom"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="6dp"
    android:layout_marginTop="4dp"
    android:layout_marginRight="6dp">
    <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
        android:id="@+id/banner_parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:scale_height="100dp"
        app:scale_width="375dp">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_img_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_holder_ad200_51"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"/>
    </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
</LinearLayout>
