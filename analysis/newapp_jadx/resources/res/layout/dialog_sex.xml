<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="bottom"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg2"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_sex_male"
        android:background="@drawable/bg_sex_style"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="男"/>
    <TextView
        android:background="@color/black26"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_sex_female"
        android:background="@drawable/bg_sex_style"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="女"/>
    <TextView
        android:background="@color/black26"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_sex_private"
        android:background="@drawable/bg_sex_style"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="不公开"/>
    <TextView
        android:background="@color/black26"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_sex_canel"
        android:background="@drawable/bg_sex_style"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="取消"/>
</LinearLayout>
