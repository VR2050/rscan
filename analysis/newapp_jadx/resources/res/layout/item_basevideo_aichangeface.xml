<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rv_tag_layout"
    android:layout_width="135dp"
    android:layout_height="88dp"
    android:layout_marginRight="8dp">
    <ImageView
        android:id="@+id/img_default_show"
        android:layout_width="135dp"
        android:layout_height="86dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.jbzd.media.movecartoons.view.video.FullPlayerView
        android:id="@+id/item_player"
        android:visibility="gone"
        android:layout_width="135dp"
        android:layout_height="86dp"/>
    <View
        android:id="@+id/view"
        android:background="@color/bgBlack"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0"/>
    <ImageView
        android:textSize="14sp"
        android:textColor="@color/font_main"
        android:ellipsize="end"
        android:id="@+id/iv_center_playicon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/icon_player_pause"
        android:maxLines="1"
        android:singleLine="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/view_up"
        android:background="@drawable/bg_basevideo_style"
        android:layout_width="135dp"
        android:layout_height="88dp"
        app:layout_constraintBottom_toBottomOf="@+id/img_default_show"
        app:layout_constraintEnd_toEndOf="@+id/img_default_show"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@+id/img_default_show"
        app:layout_constraintTop_toTopOf="@+id/img_default_show"
        app:layout_constraintVertical_bias="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
