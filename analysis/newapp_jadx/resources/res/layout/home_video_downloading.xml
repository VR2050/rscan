<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:background="@color/white"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/iv_video"
        android:layout_width="160dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="h,16:9"
        app:layout_constraintStart_toEndOf="@+id/iv_edit"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.jbzd.media.movecartoons.view.text.ImageTextView
        android:textSize="12sp"
        android:textColor="#ffffff"
        android:gravity="center_vertical"
        android:id="@+id/itv_price"
        android:background="@drawable/home_diamond_flag_bg"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:drawableRight="@drawable/home_diamond"
        android:drawablePadding="2dp"
        app:drawable_height="10dp"
        app:drawable_width="10dp"
        app:layout_constraintStart_toStartOf="@+id/iv_video"
        app:layout_constraintTop_toTopOf="@+id/iv_video"/>
    <ImageView
        android:id="@+id/iv_flag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:src="@drawable/ic_flag_vip"
        android:scaleType="fitCenter"
        app:layout_constraintStart_toStartOf="@+id/iv_video"
        app:layout_constraintTop_toTopOf="@+id/iv_video"/>
    <TextView
        android:textSize="10sp"
        android:textColor="#ffffff"
        android:gravity="center_vertical"
        android:id="@+id/tv_duration"
        android:background="@drawable/bg_popular_index"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="8dp"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        app:layout_constraintBottom_toBottomOf="@+id/iv_video"
        app:layout_constraintEnd_toEndOf="@+id/iv_video"/>
    <com.jbzd.media.movecartoons.view.text.ImageTextView
        android:textSize="10sp"
        android:textColor="#ffffff"
        android:gravity="center_vertical"
        android:id="@+id/tv_wantLook"
        android:background="@drawable/bg_popular_index"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginBottom="8dp"
        android:drawablePadding="1dp"
        android:layout_alignParentLeft="true"
        android:layout_alignParentBottom="true"
        app:drawable_height="14dp"
        app:drawable_width="14dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_video"
        app:layout_constraintStart_toStartOf="@+id/iv_video"/>
    <ImageView
        android:id="@+id/iv_edit"
        android:background="@drawable/edit_selector"
        android:visibility="gone"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_margin="4dp"
        android:layout_alignParentRight="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_video"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/black"
            android:ellipsize="end"
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"/>
        <RelativeLayout
            android:orientation="horizontal"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="10sp"
                android:textColor="@color/black40"
                android:ellipsize="end"
                android:id="@+id/tvDownload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:maxLines="1"
                android:layout_alignParentLeft="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/btn_status_left"
                android:background="@drawable/btn_pink_download"
                android:paddingLeft="8dp"
                android:paddingTop="2dp"
                android:paddingRight="8dp"
                android:paddingBottom="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="5dp"
                android:text="重新下载"
                android:layout_toLeftOf="@+id/btn_del"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_red_white_selector"
                android:gravity="center"
                android:id="@+id/btn_del"
                android:background="@drawable/bg_watch_comics"
                android:paddingLeft="8dp"
                android:paddingTop="2dp"
                android:paddingRight="8dp"
                android:paddingBottom="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="删除"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
        <ProgressBar
            android:id="@+id/pb_progress_download"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:progress="1"
            android:progressDrawable="@drawable/download_progress_bg"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
