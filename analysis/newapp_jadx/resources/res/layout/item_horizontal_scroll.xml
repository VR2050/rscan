<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
        android:id="@+id/item_parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:scale_height="180dp"
        app:scale_width="140dp">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            app:shapeAppearance="@style/RoundedStyle"/>
        <RelativeLayout
            android:id="@+id/rl_coverOption"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <include layout="@layout/video_item_cover_hot"/>
            <ImageView
                android:id="@+id/iv_novel_audio"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_novel_audio"
                android:adjustViewBounds="true"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
    </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/ll_name"
        android:paddingTop="6dp"
        android:paddingBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/black"
            android:id="@+id/tv_name"
            android:paddingTop="1.5dp"
            android:paddingBottom="1.5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:maxLines="1"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_ff6a00"
            android:id="@+id/tv_video_click"
            android:background="@drawable/shape_comic_type"
            android:paddingLeft="6dp"
            android:paddingTop="3dp"
            android:paddingRight="6dp"
            android:paddingBottom="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:maxLines="2"/>
    </LinearLayout>
</LinearLayout>
