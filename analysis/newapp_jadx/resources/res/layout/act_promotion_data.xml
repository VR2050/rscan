<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#151618"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="18dp"
    android:paddingEnd="18dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_user_info"
        android:background="@drawable/item_settled_level_bg"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/guide_center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.5"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#5b3e20"
            android:id="@+id/txt_recharge_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="可提现"
            app:layout_constraintEnd_toEndOf="@+id/guide_center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="25sp"
            android:textColor="#5b3e20"
            android:id="@+id/txt_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1000"
            android:fontFamily="@font/number"
            app:layout_constraintEnd_toEndOf="@+id/guide_center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_recharge_label"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5b3e20"
            android:id="@+id/txt_total_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="总收益"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/guide_center"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="25sp"
            android:textColor="#5b3e20"
            android:id="@+id/txt_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4740"
            android:fontFamily="@font/number"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/guide_center"
            app:layout_constraintTop_toBottomOf="@+id/txt_total_label"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textColor="#f6edce"
            android:id="@+id/btn_recharge"
            android:background="@drawable/btn_promotion_recharge"
            android:layout_width="0dp"
            android:layout_height="33dp"
            android:layout_marginTop="18dp"
            android:text="@string/post_withdraw_immediately"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_amount"
            app:layout_constraintWidth_percent="0.4"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/guideLine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:id="@+id/txt_month_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/number"
        app:layout_constraintEnd_toEndOf="@+id/guideLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_user_info"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:id="@+id/txt_month_performance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/number"
        app:layout_constraintEnd_toEndOf="@+id/guideLine"
        app:layout_constraintStart_toStartOf="@+id/guideLine"
        app:layout_constraintTop_toBottomOf="@+id/layout_user_info"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:id="@+id/txt_month_promotion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideLine"
        app:layout_constraintTop_toBottomOf="@+id/layout_user_info"/>
    <TextView
        android:textColor="#f6edce"
        android:id="@+id/txt_month_total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="当月收益(元)"
        app:layout_constraintEnd_toEndOf="@+id/guideLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_month_amount"/>
    <TextView
        android:textColor="#f6edce"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="当月业绩(元)"
        app:layout_constraintEnd_toEndOf="@+id/guideLine"
        app:layout_constraintStart_toStartOf="@+id/guideLine"
        app:layout_constraintTop_toBottomOf="@+id/txt_month_amount"/>
    <TextView
        android:textColor="#f6edce"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="当月推广数"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideLine"
        app:layout_constraintTop_toBottomOf="@+id/txt_month_amount"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:id="@+id/txt_today_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/number"
        app:layout_constraintEnd_toEndOf="@+id/guideLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_month_total"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:id="@+id/txt_today_performance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/number"
        app:layout_constraintEnd_toEndOf="@+id/guideLine"
        app:layout_constraintStart_toStartOf="@+id/guideLine"
        app:layout_constraintTop_toBottomOf="@+id/txt_month_total"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:id="@+id/txt_today_promotion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideLine"
        app:layout_constraintTop_toBottomOf="@+id/txt_month_total"/>
    <TextView
        android:textColor="#f6edce"
        android:id="@+id/txt_today_total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="今日收益(元)"
        app:layout_constraintEnd_toEndOf="@+id/guideLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_today_amount"/>
    <TextView
        android:textColor="#f6edce"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="今日业绩(元)"
        app:layout_constraintEnd_toEndOf="@+id/guideLine"
        app:layout_constraintStart_toStartOf="@+id/guideLine"
        app:layout_constraintTop_toBottomOf="@+id/txt_today_amount"/>
    <TextView
        android:textColor="#f6edce"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="今日推广数"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideLine"
        app:layout_constraintTop_toBottomOf="@+id/txt_today_amount"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/black"
        android:id="@+id/txt_direct_statistics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="直推总统计"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_today_total"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:id="@+id/txt_direct_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="1888"
        android:fontFamily="@font/number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_direct_statistics"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#f6edce"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="直推用户数"
        app:layout_constraintBottom_toBottomOf="@+id/txt_direct_num"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/txt_direct_num"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:id="@+id/txt_direct_pay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="0"
        android:fontFamily="@font/number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_direct_num"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#f6edce"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="直推付费用户"
        app:layout_constraintBottom_toBottomOf="@+id/txt_direct_pay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/txt_direct_pay"/>
    <TextView
        android:textSize="17sp"
        android:textColor="@color/black"
        android:id="@+id/txt_direct_proxy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="23"
        android:fontFamily="@font/number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_direct_pay"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#f6edce"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="直推下级代理"
        app:layout_constraintBottom_toBottomOf="@+id/txt_direct_proxy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/txt_direct_proxy"/>
</androidx.constraintlayout.widget.ConstraintLayout>
