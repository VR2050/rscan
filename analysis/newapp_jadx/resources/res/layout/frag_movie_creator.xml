<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:paddingLeft="10dp"
    android:paddingTop="10dp"
    android:paddingRight="10dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.jbzd.media.movecartoons.view.image.CircleImageView
        android:id="@+id/civ_head"
        android:background="@drawable/head_img_bg"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@drawable/ic_place_holder_circle_51"
        app:border_color="@color/white"
        app:border_color_inside="?attr/my_image_circle_bg"
        app:border_width="0.5dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_head"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_weight="1">
        <TextView
            android:textSize="13sp"
            android:textColor="?attr/my_txt_color"
            android:ellipsize="end"
            android:id="@+id/tv_postdetail_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="?attr/my_txt_color4"
            android:id="@+id/tv_userDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <TextView
        android:textSize="15sp"
        android:textColor="?attr/my_press_btn_txt_color3"
        android:gravity="center"
        android:id="@+id/tv_buyFansBtn"
        android:background="?attr/my_press_btn_bg3"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:text="加入粉丝团"/>
    <TextView
        android:textSize="15sp"
        android:textColor="?attr/my_select_btn_txt_color"
        android:gravity="center"
        android:id="@+id/tv_doCollect_force"
        android:background="?attr/my_select_btn_bg"
        android:paddingLeft="11.5dp"
        android:paddingRight="11.5dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:text="关注"/>
</LinearLayout>
