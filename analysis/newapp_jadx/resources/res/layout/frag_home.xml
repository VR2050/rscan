<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/ll_top"
        android:background="@color/bg_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.flyco.tablayout.SlidingTabLayout
            android:id="@+id/tabLayout"
            android:paddingBottom="5dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            app:tl_divider_color="@color/transparent"
            app:tl_iconVisible="false"
            app:tl_indicator_color="@color/white"
            app:tl_indicator_corner_radius="3dp"
            app:tl_indicator_height="4dp"
            app:tl_indicator_width="16dp"
            app:tl_tab_padding="8dp"
            app:tl_textBold="NONE"
            app:tl_textSelectColor="@color/white"
            app:tl_textSelectSize="16sp"
            app:tl_textUnselectColor="@color/color_b3ffffff"
            app:tl_textsize="16sp"/>
        <LinearLayout
            android:gravity="center"
            android:id="@+id/ll_deep_dark_tab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <com.flyco.tablayout.SlidingTabLayout
                android:id="@+id/tabLayout_deep_dark"
                android:paddingBottom="5dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                app:tl_divider_color="@color/transparent"
                app:tl_iconVisible="false"
                app:tl_indicator_color="@color/white"
                app:tl_indicator_corner_radius="3dp"
                app:tl_indicator_height="4dp"
                app:tl_indicator_width="16dp"
                app:tl_tab_padding="8dp"
                app:tl_textBold="NONE"
                app:tl_textSelectColor="@color/white"
                app:tl_textSelectSize="16sp"
                app:tl_textUnselectColor="@color/color_b3ffffff"
                app:tl_textsize="16sp"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.viewpager.widget.ViewPager
            android:id="@+id/vp_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"/>
        <LinearLayout
            android:gravity="center"
            android:id="@+id/ll_nodata"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textColor="@color/color_666666"
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前页面暂无内容~"
                android:drawableTop="@drawable/ic_data_empty"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
