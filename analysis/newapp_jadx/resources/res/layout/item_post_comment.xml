<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingLeft="8dp"
    android:paddingTop="10dp"
    android:paddingRight="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.jbzd.media.movecartoons.view.image.CircleImageView
            android:id="@+id/iv_post_comment_userheder"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginRight="8dp"
            android:src="@drawable/ic_place_holder_circle_51"
            android:layout_centerInParent="true"
            app:border_color="@color/line_default_color"
            app:border_width="0dp"/>
        <LinearLayout
            android:gravity="top"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:gravity="center_vertical"
                    android:id="@+id/tv_post_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="萝卜保卫"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:id="@+id/tv_post_comment_content"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dp"
                    android:text="身材还是略略略瘦 不过瘦的完美哟 哈哈"/>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/black40"
                        android:id="@+id/tv_post_comment_time"
                        android:paddingRight="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2023-4-11"
                        android:layout_centerVertical="true"/>
                    <com.jbzd.media.movecartoons.view.text.ImageTextView
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:id="@+id/itv_postcomment_likes"
                        android:padding="5dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点赞"
                        android:drawableLeft="@drawable/style_comment_love"
                        android:drawablePadding="3dp"
                        android:layout_alignParentRight="true"
                        app:drawable_height="14dp"
                        app:drawable_width="15dp"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="14sp"
                            android:textColor="@color/bgPrice"
                            android:gravity="center_vertical"
                            android:id="@+id/tv_post_comment_reply"
                            android:padding="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="回复"/>
                    </LinearLayout>
                </RelativeLayout>
                <TextView
                    android:background="@color/black12"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.5"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
