<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:layout_width="58dp"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/rl_headBg"
        android:background="@drawable/creator_head_bg"
        android:layout_width="match_parent"
        android:layout_height="58dp">
        <com.jbzd.media.movecartoons.view.image.CircleImageView
            android:id="@+id/iv_head"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:scaleType="centerCrop"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            app:border_color="@color/white"
            app:border_color_inside="?attr/my_image_circle_bg"
            app:border_width="0.5dp"/>
        <ImageView
            android:id="@+id/iv_add"
            android:visibility="visible"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginRight="4dp"
            android:layout_marginBottom="4dp"
            android:src="@drawable/home_add_icon"
            android:scaleType="fitCenter"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="13sp"
        android:textColor="?attr/my_txt_color"
        android:ellipsize="end"
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:maxLines="1"/>
</LinearLayout>
