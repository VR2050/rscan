<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="5dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    app:cardBackgroundColor="@color/black"
    app:cardCornerRadius="6dp"
    app:cardElevation="3dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/ll_microtanot_userrow"
        android:background="@drawable/bg_item_style"
        android:paddingLeft="10dp"
        android:paddingTop="5dp"
        android:paddingRight="5dp"
        android:paddingBottom="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.jbzd.media.movecartoons.view.image.CircleImageView
            android:id="@+id/iv_posttopic_left_avatar"
            android:visibility="gone"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_place_holder_circle_51"
            android:layout_centerInParent="true"
            app:border_color="@color/line_default_color"
            app:border_width="0dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:layout_weight="1">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/black"
                android:ellipsize="end"
                android:id="@+id/tv_posttopic_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_marginRight="2dp"
                android:text="#伦理之爱"
                android:maxLines="1"
                android:includeFontPadding="false"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:id="@+id/tv_post_toptics_number"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="2.5千个帖子"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:id="@+id/tv_post_toptics_times"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="9508.5万浏览"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:gravity="right"
                    android:id="@+id/tv_post_toptics_followers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="156.5万关注"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/iv_select"
            android:visibility="gone"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/selector_check1"
            android:scaleType="fitXY"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <RelativeLayout
            android:id="@+id/rl_wantsee"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textSize="13sp"
                android:textColor="#ffffff"
                android:gravity="center_vertical"
                android:id="@+id/itv_microtanot_wantsee"
                android:paddingLeft="10dp"
                android:paddingTop="5dp"
                android:paddingRight="10dp"
                android:paddingBottom="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="想看"
                android:drawableLeft="@drawable/movie_desc_love"
                android:drawablePadding="2dp"
                android:layout_centerInParent="true"
                app:drawable_height="16dp"
                app:drawable_width="16dp"/>
        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
