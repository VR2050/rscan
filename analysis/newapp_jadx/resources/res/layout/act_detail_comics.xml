<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:background="@drawable/bg_all_shape"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/ll_comicsdetail_bottom">
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar_layout_comicsdetail"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="0dp"
            app:layout_behavior="@string/my_appbar_fling_behavior">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_scrollFlags="exitUntilCollapsed|scroll">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/iv_comicsdetail_top"
                        android:layout_width="match_parent"
                        android:layout_height="230dp"
                        android:src="@drawable/ic_place_holder_vertical_51"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"/>
                    <LinearLayout
                        android:gravity="top|center_horizontal"
                        android:orientation="vertical"
                        android:id="@+id/ll_my_title"
                        android:background="@color/black26"
                        android:paddingTop="5dp"
                        android:paddingBottom="15dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_collapseMode="parallax">
                        <LinearLayout
                            android:gravity="top"
                            android:orientation="horizontal"
                            android:id="@+id/ll_mine_info"
                            android:paddingTop="70dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp">
                            <RelativeLayout
                                android:background="@drawable/dialog_bg"
                                android:padding="2dp"
                                android:layout_width="107dp"
                                android:layout_height="142dp">
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/iv_comicsdetail_img"
                                    android:layout_width="105dp"
                                    android:layout_height="140dp"
                                    android:src="@drawable/ic_place_holder_vertical_51"
                                    android:scaleType="centerCrop"
                                    android:adjustViewBounds="true"
                                    app:shapeAppearance="@style/RoundedStyle"/>
                                <ImageView
                                    android:id="@+id/iv_detail_novel_audio"
                                    android:visibility="gone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@drawable/icon_novel_audio"
                                    android:adjustViewBounds="true"
                                    android:layout_alignParentRight="true"/>
                            </RelativeLayout>
                            <com.jbzd.media.movecartoons.view.image.CircleImageView
                                android:id="@+id/civ_head_posthome"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:layout_marginBottom="5dp"
                                android:src="@drawable/ic_place_holder_vertical_51"
                                android:layout_centerInParent="true"
                                app:border_color="#fbc15b"
                                app:border_color_inside="#ffbe4f"
                                app:border_width="0dp"/>
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:layout_weight="1">
                                <TextView
                                    android:textSize="17sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:id="@+id/tv_comicsdetail_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:maxLines="2"
                                    android:drawablePadding="5dp"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"/>
                                <LinearLayout
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp">
                                    <TextView
                                        android:textSize="13sp"
                                        android:textColor="@color/white"
                                        android:id="@+id/tv_comicsdetail_category"
                                        android:background="@drawable/bg_tag_style"
                                        android:paddingLeft="5dp"
                                        android:paddingTop="3dp"
                                        android:paddingRight="5dp"
                                        android:paddingBottom="3dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"/>
                                    <TextView
                                        android:textSize="15sp"
                                        android:textColor="@color/white"
                                        android:id="@+id/tv_comicsdetail_chaptercount"
                                        android:paddingTop="5dp"
                                        android:paddingBottom="5dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="10dp"
                                        android:layout_marginRight="10dp"/>
                                </LinearLayout>
                                <TextView
                                    android:textColor="@color/white"
                                    android:id="@+id/tv_click_favorite"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"/>
                                <com.jbzd.media.movecartoons.view.FollowTextView
                                    android:textSize="13sp"
                                    android:textColor="@color/selector_text_color_follow"
                                    android:gravity="center"
                                    android:id="@+id/tv_comicsdetail_favorite"
                                    android:background="@drawable/state_follow_style"
                                    android:paddingTop="3dp"
                                    android:paddingBottom="3dp"
                                    android:layout_width="66dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"/>
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginRight="10dp"
                            android:layout_marginBottom="10dp">
                            <TextView
                                android:textSize="13sp"
                                android:textColor="@color/color_999999"
                                android:id="@+id/fans_posthome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:maxLines="1"/>
                            <TextView
                                android:textSize="13sp"
                                android:textColor="@color/color_999999"
                                android:id="@+id/follows_posthome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="20dp"
                                android:maxLines="1"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:textSize="14sp"
                                android:textColor="@color/transparent"
                                android:id="@+id/acc_id_posthome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawablePadding="5dp"/>
                            <ImageView
                                android:id="@+id/src_sex_leftline"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="5dp"
                                android:src="@drawable/img_line_ver"/>
                            <ImageView
                                android:textSize="@dimen/textSizeSmall"
                                android:textColor="@color/black"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/iv_sex_posthome"
                                android:visibility="gone"
                                android:layout_width="13dp"
                                android:layout_height="13dp"
                                android:layout_marginLeft="5dp"
                                android:src="@drawable/icon_sexmale"/>
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@+id/ll_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-10dp"
            app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">
            <androidx.recyclerview.widget.RecyclerView
                android:orientation="horizontal"
                android:id="@+id/rv_tag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="15dp"
                android:layout_marginRight="10dp"
                app:layoutManager="com.google.android.flexbox.FlexboxLayoutManager"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/black"
                android:ellipsize="end"
                android:id="@+id/tv_comicsdetail_description"
                android:paddingLeft="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="5"/>
            <TextView
                android:background="#f7f9fc"
                android:layout_width="match_parent"
                android:layout_height="10dp"/>
            <LinearLayout
                android:gravity="center"
                android:paddingLeft="@dimen/dp_10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                app:layout_scrollFlags="exitUntilCollapsed|scroll">
                <com.flyco.tablayout.SlidingTabLayout
                    android:id="@+id/tablayout_comicsdetail"
                    android:layout_width="140dp"
                    android:layout_height="35dp"
                    app:tl_divider_color="@color/transparent"
                    app:tl_iconVisible="false"
                    app:tl_indicator_color="@color/color_gold_main"
                    app:tl_indicator_corner_radius="2dp"
                    app:tl_indicator_height="4dp"
                    app:tl_indicator_width="12dp"
                    app:tl_tab_space_equal="true"
                    app:tl_textBold="NONE"
                    app:tl_textSelectColor="@color/black"
                    app:tl_textSelectSize="16sp"
                    app:tl_textUnselectColor="@color/black39"
                    app:tl_textsize="16sp"/>
            </LinearLayout>
            <androidx.viewpager.widget.ViewPager
                android:id="@+id/vp_comicsdetail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/ll_comicsdetail_bottom"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:gravity="center"
            android:id="@+id/ll_comicsdetailbottom_favorite"
            android:background="@drawable/style_comicsbottom_favorite"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_weight="1">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/black"
                android:id="@+id/tv_comicsdetailbottom_favorite"
                android:padding="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="收藏"
                android:drawableTop="@drawable/style_botton_favorite"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:id="@+id/ll_comicsdetailbottom_startview"
            android:background="@drawable/btn_orange_style"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dp_10">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/black"
                android:id="@+id/tv_read_start"
                android:padding="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始阅读"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/ll_comicsdetailbottom_comment_input"
        android:background="@color/white"
        android:paddingRight="5dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true">
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="11sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/itv_favorite"
            android:paddingLeft="2dp"
            android:paddingTop="5dp"
            android:paddingRight="2dp"
            android:paddingBottom="5dp"
            android:visibility="gone"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:scaleType="fitCenter"
            android:text="已收藏"
            android:maxLines="1"
            android:drawableTop="@drawable/style_botton_favorite"
            app:drawable_height="14dp"
            app:drawable_width="14dp"/>
        <androidx.appcompat.widget.AppCompatEditText
            android:textSize="14dp"
            android:textColor="@color/black"
            android:textColorHint="@color/black40"
            android:gravity="center_vertical"
            android:id="@+id/ed_input_comment_comics"
            android:background="@drawable/bg_input_comment"
            android:paddingLeft="18dp"
            android:paddingTop="8dp"
            android:paddingRight="18dp"
            android:paddingBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="5dp"
            android:hint="留下您的精彩评论吧..."
            android:layout_weight="1"
            android:imeOptions="actionDone"/>
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="12sp"
            android:id="@+id/itv_confirm_post"
            android:background="@drawable/bg_back_play_list"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="3dp"
            android:scaleType="fitCenter"
            android:drawableRight="@drawable/icon_input_send"
            android:drawablePadding="2dp"/>
    </LinearLayout>
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/title_layout_comicsdetailtop"
        android:background="@color/transparent"
        android:paddingTop="30dp"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentTop="true">
        <RelativeLayout
            android:id="@+id/btn_titleBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentLeft="true">
            <ImageView
                android:id="@+id/iv_titleLeftIcon"
                android:background="@drawable/bg_back_play_list"
                android:padding="8dp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:src="@drawable/ic_btn_icon_white"
                android:scaleType="fitCenter"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="#ffdba5"
            android:gravity="center"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text=""
            android:maxLines="1"
            android:layout_centerHorizontal="true"/>
        <RelativeLayout
            android:id="@+id/btn_titleRight"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/white"
                android:id="@+id/tv_titleRight"
                android:background="@drawable/bg_back_play_list"
                android:padding="8dp"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginRight="10dp"
                android:text=""
                android:drawableRight="@drawable/icon_share_comics"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/btn_titleRightIcon"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true">
            <ImageView
                android:id="@+id/iv_titleRightIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="fitCenter"
                android:maxHeight="20dp"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <View
            android:id="@+id/title_divider"
            android:background="#0cffffff"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_height"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
</RelativeLayout>
