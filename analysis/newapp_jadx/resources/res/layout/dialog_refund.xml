<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_notice_nickname"
        android:layout_width="280dp"
        android:layout_height="184dp">
        <TextView
            android:textColor="@color/mine_text_gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:text="账号找回成功"
            app:layout_constraintBottom_toTopOf="@+id/view2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/close"
            android:background="@drawable/notice_close"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="3dp"
            android:layout_marginEnd="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <View
            android:id="@+id/view2"
            android:background="@color/mine_notice_bg"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@+id/close"/>
        <TextView
            android:textColor="@color/black"
            android:id="@+id/itv_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="请到个人中心刷新页面\10或关掉进程后重新打开app"
            app:layout_constraintEnd_toEndOf="@+id/btn_submit_aichangeface_video"
            app:layout_constraintStart_toStartOf="@+id/btn_submit_aichangeface_video"
            app:layout_constraintTop_toTopOf="@+id/view2"/>
        <com.jbzd.media.movecartoons.view.GradientRoundCornerButton
            android:textSize="@dimen/textSizeSmall"
            android:id="@+id/btn_submit_aichangeface_video"
            android:layout_width="128dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:text="提交"
            app:gradientBg="@drawable/mine_rect_bg_all"
            app:gradientCornerRadius="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/itv_nickname"
            app:txtColor="@color/black"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
