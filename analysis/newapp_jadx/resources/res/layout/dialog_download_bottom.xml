<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/outside_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <RelativeLayout
        android:background="@drawable/share_bottom_dialog_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:id="@+id/rl_downlod"
                android:layout_width="240dp"
                android:layout_height="35dp">
                <ProgressBar
                    android:id="@+id/pb_progress"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:progress="0"
                    android:progressDrawable="@drawable/download_progress_bg"
                    android:layout_weight="1"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
                <com.jbzd.media.movecartoons.view.text.ImageTextView
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:gravity="center_vertical"
                    android:id="@+id/itv_progressTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="下载中 0%"
                    android:drawableLeft="@drawable/icon_dialog_download"
                    android:drawablePadding="12dp"
                    android:layout_centerInParent="true"
                    app:drawable_height="17dp"
                    app:drawable_width="17dp"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:id="@+id/tv_goPhotos"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="去相册查看 &gt;"/>
            </RelativeLayout>
            <View
                android:background="#7fbcfc"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="25dp"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:id="@+id/tv_cancel"
                android:paddingBottom="15dp"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="取消"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
