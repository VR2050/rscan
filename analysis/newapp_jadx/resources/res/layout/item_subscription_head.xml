<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/black"
    android:layout_width="60dp"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_width="50dp"
        android:layout_height="50dp">
        <com.jbzd.media.movecartoons.view.image.CircleImageView
            android:id="@+id/civ_head"
            android:background="@drawable/btn_submit_style"
            android:padding="2dp"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_place_holder_circle_51"
            android:layout_centerInParent="true"
            app:border_color="@color/color_gold_main"
            app:border_width="10dp"/>
        <ImageView
            android:id="@+id/iv_subheader_vip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:src="@drawable/icon_vip_small"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="11sp"
        android:textColor="@color/select_text_blogger"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_nickname"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"/>
</LinearLayout>
