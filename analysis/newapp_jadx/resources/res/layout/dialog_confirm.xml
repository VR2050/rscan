<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_notice_nickname"
        android:layout_width="280dp"
        android:layout_height="180dp">
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/mine_text_gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="提示"
            app:layout_constraintBottom_toTopOf="@+id/view2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/close"
            android:background="@drawable/notice_close"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="3dp"
            android:layout_marginEnd="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <View
            android:id="@+id/view2"
            android:background="@color/mine_notice_bg"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="3dp"
            app:layout_constraintTop_toBottomOf="@+id/close"/>
        <TextView
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/itv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="..."
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/view2"/>
        <com.jbzd.media.movecartoons.view.GradientRoundCornerButton
            android:textSize="@dimen/textSizeSmall"
            android:id="@+id/btn_submit_aichangeface_video"
            android:layout_width="208dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:text="确认"
            app:gradientBg="@drawable/btn_submit_style"
            app:gradientCornerRadius="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/itv_title"
            app:txtColor="@color/black"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
