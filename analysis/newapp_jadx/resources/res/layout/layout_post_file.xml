<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/img_community_single"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearance="@style/RoundedStyle"/>
    <ImageView
        android:id="@+id/iv_pause"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/icon_community_video"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="20sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/txt_count"
        android:background="@drawable/shape_white_cover_translucent"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/img_community_single"
        app:layout_constraintEnd_toEndOf="@+id/img_community_single"
        app:layout_constraintStart_toStartOf="@+id/img_community_single"
        app:layout_constraintTop_toTopOf="@+id/img_community_single"/>
    <ImageView
        android:id="@+id/img_icon_money"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:src="@drawable/icon_coin_balance_left"
        android:layout_marginEnd="6dp"
        app:layout_constraintEnd_toEndOf="@+id/img_community_single"
        app:layout_constraintTop_toTopOf="@+id/img_community_single"/>
    <TextView
        android:textSize="11sp"
        android:id="@+id/txt_post_vip"
        android:background="@drawable/selector_btn_follow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:text="@string/video_type_vip"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:layout_marginStart="6dp"
        app:layout_constraintStart_toStartOf="@+id/img_community_single"
        app:layout_constraintTop_toTopOf="@+id/img_community_single"/>
</androidx.constraintlayout.widget.ConstraintLayout>
