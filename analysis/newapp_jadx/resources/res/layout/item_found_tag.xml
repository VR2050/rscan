<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@drawable/item_found_tag_bg"
    android:paddingLeft="8dp"
    android:layout_width="145dp"
    android:layout_height="75dp"
    android:layout_margin="4dp">
    <ImageView
        android:layout_width="33.5dp"
        android:layout_height="44dp"
        android:src="@drawable/found_tag_icon"
        app:tint="?attr/my_txt_color4"/>
    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="3dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="15sp"
            android:textColor="?attr/my_txt_color"
            android:id="@+id/tv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="5dp"
            android:text="性教育科普"/>
        <TextView
            android:textSize="13sp"
            android:textColor="?attr/my_txt_color4"
            android:id="@+id/tv_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="456 个作品"/>
    </LinearLayout>
</LinearLayout>
