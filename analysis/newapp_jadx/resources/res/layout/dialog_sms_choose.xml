<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/content_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="@drawable/sheet_bottom_dialog_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.github.mmin18.widget.RealtimeBlurView
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:realtimeOverlayColor="?attr/my_sheet_bottom_dialog_bg"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <ImageView
                android:id="@+id/iv_close"
                android:padding="10dp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/home_icon_expand2"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                app:tint="?attr/my_txt_color"/>
            <TextView
                android:textSize="14sp"
                android:textColor="?attr/my_txt_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择喜欢的口味, 获得专属你的内容"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <LinearLayout
            android:gravity="center"
            android:background="@drawable/selected_tags_bg"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:layout_width="match_parent"
            android:layout_height="90dp">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_selected"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="4"/>
        </LinearLayout>
        <com.qunidayede.supportlibrary.widget.ClearEditText
            android:textSize="13sp"
            android:textColor="@color/black"
            android:textColorHint="@color/white70"
            android:gravity="center"
            android:id="@+id/cet_num"
            android:background="@drawable/bg_normal_edit"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:hint="输入口味关键词进行过滤"
            android:singleLine="true"/>
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_tags"
                    android:paddingLeft="4.5dp"
                    android:paddingTop="12dp"
                    android:paddingRight="4.5dp"
                    android:paddingBottom="12dp"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:overScrollMode="never"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="4"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <TextView
            android:textSize="13sp"
            android:textColor="?attr/my_press_btn_txt_color"
            android:gravity="center"
            android:id="@+id/itv_confirm_post"
            android:background="?attr/my_press_btn_bg"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="15dp"
            android:text="确认"/>
    </LinearLayout>
</RelativeLayout>
