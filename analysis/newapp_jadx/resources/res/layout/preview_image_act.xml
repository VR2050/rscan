<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/bgBlack"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.jbzd.media.movecartoons.view.SlideCloseLayout
        android:id="@+id/slide_close_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.jbzd.media.movecartoons.view.HackyViewPager
            android:orientation="horizontal"
            android:id="@+id/vp_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </com.jbzd.media.movecartoons.view.SlideCloseLayout>
    <TextView
        android:textSize="18sp"
        android:textColor="@color/black"
        android:gravity="center_horizontal"
        android:layout_gravity="bottom"
        android:id="@+id/tv_index"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>
    <RelativeLayout
        android:paddingTop="22dp"
        android:layout_width="match_parent"
        android:layout_height="72dp">
        <RelativeLayout
            android:id="@+id/btn_titleBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/iv_titleLeftIcon"
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_btn_icon_black"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </RelativeLayout>
</FrameLayout>
