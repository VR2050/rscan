<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/frame_layout"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_player"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <FrameLayout
                    android:id="@+id/flVideo"
                    android:background="@color/white"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.jbzd.media.movecartoons.view.video.ListPlayerView
                        android:id="@+id/video_player"
                        android:background="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <include
                        android:layout_gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        layout="@layout/dialog_video_disable"/>
                </FrameLayout>
                <LinearLayout
                    android:gravity="bottom"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/ll_videoMsg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true">
                        <LinearLayout
                            android:gravity="bottom"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <LinearLayout
                                    android:gravity="bottom"
                                    android:orientation="vertical"
                                    android:id="@+id/ll_bottom_item"
                                    android:background="@drawable/bg_bottom_item"
                                    android:layout_width="match_parent"
                                    android:layout_height="300dp"
                                    android:layout_alignParentBottom="true">
                                    <LinearLayout
                                        android:orientation="vertical"
                                        android:id="@+id/ll_bottom_content"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">
                                        <LinearLayout
                                            android:orientation="vertical"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginRight="60dp">
                                            <TextView
                                                android:textSize="10sp"
                                                android:textColor="@color/white"
                                                android:gravity="center"
                                                android:id="@+id/tv_buy"
                                                android:background="@drawable/style_openvip"
                                                android:paddingLeft="8dp"
                                                android:paddingTop="4dp"
                                                android:paddingRight="8dp"
                                                android:paddingBottom="4dp"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:layout_marginLeft="12dp"
                                                android:layout_marginRight="12dp"
                                                android:layout_marginBottom="3dp"
                                                android:text="开通VIP 观看完整版"/>
                                            <RelativeLayout
                                                android:id="@+id/ll_mine_info"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_marginLeft="12dp"
                                                android:layout_marginTop="6dp"
                                                android:layout_marginRight="12dp"
                                                android:layout_marginBottom="6dp">
                                                <com.jbzd.media.movecartoons.view.image.CircleImageView
                                                    android:id="@+id/civ_head"
                                                    android:layout_width="39dp"
                                                    android:layout_height="39dp"
                                                    android:src="@drawable/ic_place_holder_circle_51"
                                                    android:layout_alignParentLeft="true"
                                                    android:layout_centerInParent="true"
                                                    app:border_color="#fbc15b"
                                                    app:border_color_inside="@color/white"
                                                    app:border_width="1dp"/>
                                                <TextView
                                                    android:textSize="15sp"
                                                    android:textColor="@color/white"
                                                    android:id="@+id/tv_username_upper"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:layout_marginLeft="10dp"
                                                    android:layout_marginRight="10dp"
                                                    android:text="这是用户名"
                                                    android:layout_toRightOf="@+id/civ_head"
                                                    android:layout_centerVertical="true"/>
                                                <com.jbzd.media.movecartoons.view.FollowTextView
                                                    android:textSize="13sp"
                                                    android:textColor="@color/selector_text_color_follow"
                                                    android:gravity="center"
                                                    android:id="@+id/iv_userFollow"
                                                    android:background="@drawable/state_follow_style"
                                                    android:paddingTop="5dp"
                                                    android:paddingBottom="5dp"
                                                    android:layout_width="66dp"
                                                    android:layout_height="wrap_content"
                                                    android:text="+关注"
                                                    android:layout_toRightOf="@+id/tv_username_upper"
                                                    android:layout_centerVertical="true"/>
                                                <ImageView
                                                    android:padding="5dp"
                                                    android:visibility="gone"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:layout_marginTop="10dp"
                                                    android:src="@drawable/icon_follow"/>
                                            </RelativeLayout>
                                            <TextView
                                                android:textSize="14sp"
                                                android:textColor="@color/main_f2f2f2"
                                                android:id="@+id/etv_name"
                                                android:paddingTop="4dp"
                                                android:paddingBottom="4dp"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_marginLeft="12dp"
                                                android:layout_marginRight="12dp"
                                                android:maxLines="3"/>
                                            <androidx.recyclerview.widget.RecyclerView
                                                android:orientation="horizontal"
                                                android:id="@+id/rv_tag"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_marginLeft="12dp"
                                                android:layout_marginRight="12dp"
                                                app:layoutManager="com.google.android.flexbox.FlexboxLayoutManager"/>
                                        </LinearLayout>
                                        <LinearLayout
                                            android:gravity="center_vertical"
                                            android:orientation="horizontal"
                                            android:id="@+id/ll_progressBar"
                                            android:layout_width="match_parent"
                                            android:layout_height="30dp"
                                            android:layout_marginBottom="8dp">
                                            <TextView
                                                android:textSize="12sp"
                                                android:textColor="#ffffff"
                                                android:id="@+id/tv_curDuration"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:layout_marginLeft="15dp"
                                                android:text="00:00"/>
                                            <SeekBar
                                                android:id="@+id/progress_foreground"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:maxHeight="4dp"
                                                android:max="100"
                                                android:progress="20"
                                                android:progressDrawable="@drawable/seek_sutopage_default"
                                                android:minHeight="4dp"
                                                android:thumb="@drawable/seekbar_comicschapter"
                                                android:layout_weight="1"
                                                android:paddingStart="6dp"
                                                android:paddingEnd="6dp"
                                                android:splitTrack="false"/>
                                            <TextView
                                                android:textSize="12sp"
                                                android:textColor="#ffffff"
                                                android:id="@+id/tv_totalDuration"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:layout_marginRight="12dp"
                                                android:text="00:00"/>
                                            <ImageView
                                                android:id="@+id/iv_video_fullscreen"
                                                android:padding="5dp"
                                                android:focusable="true"
                                                android:visibility="gone"
                                                android:clickable="true"
                                                android:layout_width="24dp"
                                                android:layout_height="24dp"
                                                android:layout_marginRight="12dp"
                                                android:src="@drawable/ic_video_fullscreen"
                                                android:layout_weight="0.01"/>
                                        </LinearLayout>
                                    </LinearLayout>
                                </LinearLayout>
                                <LinearLayout
                                    android:gravity="right"
                                    android:orientation="vertical"
                                    android:paddingBottom="15dp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="-260dp"
                                    android:layout_above="@+id/ll_bottom_item">
                                    <LinearLayout
                                        android:gravity="center_horizontal"
                                        android:orientation="vertical"
                                        android:id="@+id/ll_bottom_tool"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content">
                                        <com.jbzd.media.movecartoons.view.text.ImageTextView
                                            android:textSize="12sp"
                                            android:textColor="?attr/my_txt_color6"
                                            android:gravity="center_horizontal"
                                            android:id="@+id/itv_favorite"
                                            android:paddingLeft="10dp"
                                            android:paddingRight="10dp"
                                            android:visibility="gone"
                                            android:layout_width="50dp"
                                            android:layout_height="wrap_content"
                                            android:text="收藏"
                                            android:drawableTop="@drawable/movie_desc_love"
                                            android:drawablePadding="3dp"
                                            app:drawable_height="20dp"
                                            app:drawable_width="20dp"/>
                                        <com.jbzd.media.movecartoons.view.text.ImageTextView
                                            android:textSize="12sp"
                                            android:textColor="?attr/my_txt_color6"
                                            android:gravity="center_horizontal"
                                            android:id="@+id/itv_love"
                                            android:paddingLeft="10dp"
                                            android:paddingRight="10dp"
                                            android:layout_width="50dp"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="16dp"
                                            android:text="点赞"
                                            android:drawableTop="@drawable/style_likeshort"
                                            android:drawablePadding="3dp"
                                            app:drawable_height="20dp"
                                            app:drawable_width="20dp"/>
                                        <com.jbzd.media.movecartoons.view.text.ImageTextView
                                            android:textSize="12sp"
                                            android:textColor="?attr/my_txt_color6"
                                            android:gravity="center_horizontal"
                                            android:id="@+id/itv_download"
                                            android:paddingLeft="10dp"
                                            android:paddingRight="10dp"
                                            android:layout_width="50dp"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="16dp"
                                            android:text="缓存"
                                            android:drawableTop="@drawable/video_detail_download_selector"
                                            android:drawablePadding="3dp"
                                            app:drawable_height="16dp"
                                            app:drawable_width="20dp"
                                            app:layout_constraintEnd_toStartOf="@+id/itv_share"
                                            app:layout_constraintTop_toTopOf="parent"/>
                                        <com.jbzd.media.movecartoons.view.text.ImageTextView
                                            android:textSize="12sp"
                                            android:textColor="?attr/my_txt_color6"
                                            android:gravity="center_horizontal"
                                            android:id="@+id/itv_share"
                                            android:paddingLeft="10dp"
                                            android:paddingRight="10dp"
                                            android:layout_width="50dp"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="16dp"
                                            android:text="分享"
                                            android:drawableTop="@drawable/ic_share_shortvideo"
                                            android:drawablePadding="3dp"
                                            app:drawable_height="20dp"
                                            app:drawable_width="20dp"
                                            app:layout_constraintRight_toRightOf="parent"
                                            app:layout_constraintTop_toTopOf="parent"/>
                                        <com.jbzd.media.movecartoons.view.text.ImageTextView
                                            android:textSize="12sp"
                                            android:textColor="?attr/my_txt_color6"
                                            android:gravity="center_horizontal"
                                            android:id="@+id/tv_spinner_short"
                                            android:layout_width="50dp"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="16dp"
                                            android:text="线路"
                                            android:maxLines="1"
                                            android:drawableTop="@drawable/video_detail_icon_line"
                                            android:drawablePadding="3dp"
                                            app:drawable_height="20dp"
                                            app:drawable_width="20dp"
                                            app:layout_constraintEnd_toStartOf="@+id/itv_share"
                                            app:layout_constraintTop_toTopOf="parent"/>
                                    </LinearLayout>
                                    <com.jbzd.media.movecartoons.view.text.ImageTextView
                                        android:textSize="12sp"
                                        android:textColor="?attr/my_txt_color6"
                                        android:gravity="center_horizontal"
                                        android:id="@+id/tv_showorhiden"
                                        android:paddingLeft="10dp"
                                        android:paddingTop="16dp"
                                        android:paddingRight="10dp"
                                        android:layout_width="60dp"
                                        android:layout_height="wrap_content"
                                        android:text=""
                                        android:drawableTop="@drawable/icon_state_style"
                                        android:drawablePadding="3dp"
                                        app:drawable_height="15dp"
                                        app:drawable_width="20dp"
                                        app:layout_constraintEnd_toStartOf="@+id/itv_share"
                                        app:layout_constraintTop_toTopOf="parent"/>
                                </LinearLayout>
                            </RelativeLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                <ImageView
                    android:id="@+id/iv_clearScreen"
                    android:padding="4dp"
                    android:visibility="gone"
                    android:layout_width="22dp"
                    android:layout_height="21dp"
                    android:layout_marginRight="15dp"
                    android:layout_marginBottom="70dp"
                    android:src="@drawable/short_video_hide"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentBottom="true"/>
            </RelativeLayout>
        </LinearLayout>
        <RelativeLayout
            android:id="@+id/rl_ad"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/iv_ad"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"/>
            <LinearLayout
                android:orientation="vertical"
                android:paddingLeft="10dp"
                android:paddingTop="15dp"
                android:paddingRight="10dp"
                android:paddingBottom="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true">
                <TextView
                    android:textSize="10sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/short_ad_bg"
                    android:paddingLeft="5dp"
                    android:paddingRight="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="18dp"
                    android:text="广告"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:id="@+id/tv_adName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>
                <com.jbzd.media.movecartoons.view.ProgressButton
                    android:id="@+id/pb_goKnown"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    app:pb_background="@drawable/short_ad_btn"
                    app:pb_text="了解一下"
                    app:pb_textColor="@color/white"
                    app:pb_textSize="16"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
</FrameLayout>
