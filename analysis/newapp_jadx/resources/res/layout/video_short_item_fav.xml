<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
        android:id="@+id/item_parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:scale_height="155dp"
        app:scale_width="98dp">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            app:shapeAppearance="@style/RoundedStyle"/>
        <com.jbzd.media.movecartoons.view.text.ImageTextView
            android:textSize="@dimen/priceTextSize"
            android:textColor="@color/price"
            android:gravity="center"
            android:id="@+id/itv_price"
            android:background="@drawable/home_diamond_flag_bg"
            android:layout_width="30dp"
            android:layout_height="20dp"
            android:layout_margin="2dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentRight="true"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/black"
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:maxLines="1"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/layout_item_bottom_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp">
                <ImageView
                    android:layout_width="12sp"
                    android:layout_height="match_parent"
                    android:src="@drawable/icon_collect"
                    android:contentDescription="@string/app_name"
                    android:layout_marginEnd="3dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:id="@+id/like"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp">
            <include layout="@layout/video_item_cover"/>
        </RelativeLayout>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/main_f2f2f2"
            android:gravity="center"
            android:id="@+id/tv_isPlaying"
            android:background="@drawable/playing_bg"
            android:visibility="gone"
            android:layout_width="60dp"
            android:layout_height="17dp"
            android:text="当前播放"
            android:layout_centerInParent="true"/>
    </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_name"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent">
        <TextView
            android:id="@+id/tv_desc"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="12sp"
            android:textColor="?attr/my_txt_color4"
            android:id="@+id/tv_tag"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rl_coverOption"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <include
                android:visibility="gone"
                layout="@layout/video_item_cover_love"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/video_check_view"
                android:background="@drawable/bg_normal_btn_black_translucent"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/checkbox_del"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/uncheck_icon"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>
    </RelativeLayout>
</FrameLayout>
