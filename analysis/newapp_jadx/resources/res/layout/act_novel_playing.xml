<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/music_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/ic_logo"
        android:scaleType="centerCrop"/>
    <com.github.mmin18.widget.RealtimeBlurView
        android:id="@+id/blur_view_playing"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0"
        app:realtimeOverlayColor="@color/black40"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@color/black80"
        android:paddingBottom="@dimen/activity_vertical_margin"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:orientation="vertical"
            android:id="@+id/title_layout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/title_bar_height">
            <RelativeLayout
                android:id="@+id/btn_titleBack"
                android:layout_width="wrap_content"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/iv_titleLeftIcon"
                    android:background="@drawable/style_icon_all"
                    android:padding="6dp"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp"
                    android:src="@drawable/ic_btn_icon_white"
                    android:scaleType="fitCenter"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/tv_voicenovel_name"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:maxLines="1"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp"
                android:layout_toStartOf="@+id/btn_titleRight"
                android:layout_toEndOf="@+id/btn_titleBack"/>
            <RelativeLayout
                android:id="@+id/btn_titleRight"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentRight="true">
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:id="@+id/tv_titleRight"
                    android:background="@drawable/style_icon_all"
                    android:padding="8dp"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginRight="10dp"
                    android:text=""
                    android:drawableRight="@drawable/icon_share_comics"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
        </RelativeLayout>
        <FrameLayout
            android:id="@+id/album_layout"
            android:visibility="visible"
            android:layout_width="240dp"
            android:layout_height="240dp">
            <View
                android:layout_gravity="center"
                android:visibility="invisible"
                android:layout_width="240dp"
                android:layout_height="240dp"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/music_turntable"
                android:visibility="invisible"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/music_turntable"/>
            <com.jbzd.media.movecartoons.view.image.CircleImageView
                android:layout_gravity="center"
                android:id="@+id/music_album"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:src="@drawable/ic_logo"
                app:border_width="0dp"/>
            <ImageView
                android:layout_gravity="end|top"
                android:id="@+id/music_pointer"
                android:visibility="gone"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:layout_marginTop="5dp"
                android:src="@drawable/music_pointer_open"
                android:scaleType="fitCenter"/>
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="center"
            android:id="@+id/album_layout_big"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dp_10"
            android:layout_marginRight="@dimen/dp_10">
            <View
                android:layout_gravity="center"
                android:visibility="invisible"
                android:layout_width="400dp"
                android:layout_height="400dp"/>
        </FrameLayout>
        <FrameLayout
            android:orientation="horizontal"
            android:paddingTop="30dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <com.qunidayede.supportlibrary.widget.MarqueeTextView
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center_vertical"
                android:id="@+id/tv_novelchapter_name"
                android:paddingLeft="5dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginRight="20dp"
                android:singleLine="true"
                android:drawablePadding="5dp"
                android:marqueeRepeatLimit="marquee_forever"/>
            <TextView
                android:layout_gravity="right"
                android:background="@drawable/bg_playing_textright"
                android:visibility="gone"
                android:layout_width="160dp"
                android:layout_height="60dp"/>
        </FrameLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/play_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/itv_voicenovel_timer"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="定时"
                android:drawableTop="@drawable/icon_timer"
                android:drawablePadding="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/firstView"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:id="@+id/firstView"
                android:background="@color/transparent"
                android:layout_width="1dp"
                android:layout_height="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/itv_voicenovel_read_speed"
                app:layout_constraintStart_toEndOf="@+id/itv_voicenovel_timer"
                app:layout_constraintTop_toTopOf="parent"/>
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/itv_voicenovel_read_speed"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="语速 x2.0"
                android:drawableTop="@drawable/icon_speed_read"
                android:drawablePadding="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/itv_voicenovel_chapter_list"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toEndOf="@+id/firstView"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:id="@+id/secView"
                android:background="@color/transparent"
                android:layout_width="1dp"
                android:layout_height="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/itv_voicenovel_chapter_list"
                app:layout_constraintStart_toEndOf="@+id/itv_voicenovel_read_speed"
                app:layout_constraintTop_toTopOf="parent"/>
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/itv_voicenovel_chapter_list"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="章节目录"
                android:drawableTop="@drawable/icon_list_chapter"
                android:drawablePadding="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/itv_voicenovel_read_speed"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp">
            <TextView
                android:textColor="@color/white"
                android:id="@+id/tv_voicenovel_time_cur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <SeekBar
                android:id="@+id/progress_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:layout_marginRight="6dp"
                android:maxHeight="4dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/seek_sutopage_default"
                android:minHeight="4dp"
                android:thumb="@drawable/seekbar_comicschapter"
                android:layout_weight="1"
                android:paddingStart="10dp"
                android:paddingEnd="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/tv_voicenovel_time_end"
                app:layout_constraintStart_toEndOf="@+id/tv_voicenovel_time_cur"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textColor="@color/white"
                android:id="@+id/tv_voicenovel_time_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:paddingLeft="@dimen/dp_10"
            android:paddingRight="@dimen/dp_10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/btn_play_pause"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:src="@drawable/play_bar_play_start"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:layout_gravity="center"
                android:id="@+id/circle_view"
                android:visibility="gone"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/loading_progress_bar"
                android:visibility="gone"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/color_gold_main"
                android:backgroundTint="@color/color_gold_main"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/iv_voicenovel_play_last"
                android:background="@drawable/bg_back_play_list"
                android:padding="@dimen/dp_10"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginRight="30dp"
                android:src="@drawable/play_bar_play_previous_light"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btn_play_pause"
                app:layout_constraintStart_toEndOf="@+id/itv_voicenovel_back_fifiteen"
                app:layout_constraintTop_toTopOf="parent"/>
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textColor="@color/black"
                android:id="@+id/itv_voicenovel_back_fifiteen"
                android:padding="@dimen/dp_10"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:drawableLeft="@drawable/play_bar_play_back_light"
                android:drawablePadding="3dp"
                android:layout_marginStart="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/iv_voicenovel_play_last"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/iv_voicenovel_play_next"
                android:background="@drawable/bg_back_play_list"
                android:padding="@dimen/dp_10"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginLeft="30dp"
                android:src="@drawable/play_bar_play_next_light"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/itv_voicenovel_fast_fifiteen"
                app:layout_constraintStart_toEndOf="@+id/btn_play_pause"
                app:layout_constraintTop_toTopOf="parent"/>
            <com.jbzd.media.movecartoons.view.text.ImageTextView
                android:textColor="@color/black"
                android:gravity="right"
                android:id="@+id/itv_voicenovel_fast_fifiteen"
                android:padding="@dimen/dp_10"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:drawableRight="@drawable/play_bar_play_forward_light"
                android:drawablePadding="3dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/iv_voicenovel_play_next"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <View
        android:id="@+id/overlay_view"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</FrameLayout>
