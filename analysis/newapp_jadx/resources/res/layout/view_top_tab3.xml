<?xml version="1.0" encoding="utf-8"?>
<com.flyco.tablayout.SlidingTabLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center_horizontal"
    android:id="@+id/tabLayout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginBottom="2dp"
    app:tl_divider_color="@color/transparent"
    app:tl_iconVisible="false"
    app:tl_indicator_color="?attr/my_home_top_tab_txt_color_ed"
    app:tl_indicator_corner_radius="2dp"
    app:tl_indicator_height="0dp"
    app:tl_indicator_width="0dp"
    app:tl_tab_padding="10dp"
    app:tl_tab_width="100sp"
    app:tl_textBold="NONE"
    app:tl_textSelectColor="?attr/my_home_top_tab_txt_color_ed"
    app:tl_textSelectSize="20sp"
    app:tl_textUnselectColor="?attr/my_home_top_tab_txt_color_ed"
    app:tl_textsize="16sp"/>
