<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include layout="@layout/title_bar_layout"/>
    <FrameLayout
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_description"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <androidx.appcompat.widget.AppCompatEditText
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/color_999999"
                        android:gravity="start|top"
                        android:id="@+id/ed_aiclear_info"
                        android:background="@drawable/bg_input_login"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="179dp"
                        android:layout_margin="@dimen/dp_10"
                        android:hint="请填写内容"
                        android:maxLines="5"
                        android:maxLength="500"
                        android:textCursorDrawable="@drawable/color_cursor"
                        app:layout_constraintStart_toStartOf="parent"/>
                    <androidx.appcompat.widget.AppCompatEditText
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/color_gold_main_near"
                        android:background="@drawable/bg_b3000000_corner_6"
                        android:padding="10dp"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:hint="请设置视频价格0～999金币，不设置则免费"
                        android:maxLines="1"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ed_aiclear_info"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:orientation="vertical"
                    android:id="@+id/cl_media"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cl_description">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:layout_marginRight="12dp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/black"
                            android:id="@+id/tv_media_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="15dp"
                            android:text="上传图片"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:textSize="14sp"
                            android:textColor="@color/color_b3ffffff"
                            android:id="@+id/iv_aiclear_max"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp"
                            android:layout_marginTop="5dp"
                            android:text="(必填，最多9张)"
                            app:layout_constraintTop_toBottomOf="@+id/tv_media_title"/>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_image"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="15dp"
                            android:layout_marginBottom="15dp"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/iv_aiclear_max"/>
                        <RadioGroup
                            android:orientation="horizontal"
                            android:id="@+id/rg_clearyifu_open_personal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            app:layout_constraintTop_toBottomOf="@+id/rv_image">
                            <RadioButton
                                android:textSize="15sp"
                                android:textColor="@color/black"
                                android:id="@+id/rb_aiclearyifu_open"
                                android:paddingLeft="10dp"
                                android:paddingRight="10dp"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:checked="false"
                                android:button="@null"
                                android:text="公开"
                                android:drawableLeft="@drawable/selector_radio"
                                android:drawablePadding="6dp"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                            <RadioButton
                                android:textSize="15sp"
                                android:textColor="@color/black"
                                android:gravity="center"
                                android:id="@+id/rb_aiclearyifu_private"
                                android:paddingLeft="10dp"
                                android:paddingRight="10dp"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:checked="true"
                                android:button="@null"
                                android:text="私密"
                                android:drawableLeft="@drawable/selector_radio"
                                android:drawablePadding="6dp"/>
                        </RadioGroup>
                        <TextView
                            android:textSize="14sp"
                            android:textColor="@color/color_gold_main"
                            android:id="@+id/tv_bottom_tips_aiclear"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="10dp"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/rg_clearyifu_open_personal"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/black"
                            android:gravity="center"
                            android:layout_gravity="bottom"
                            android:id="@+id/btn_submit_aiclear"
                            android:background="@drawable/btn_orange_style"
                            android:padding="12dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="15dp"
                            android:layout_marginBottom="15dp"
                            android:text="0金币"
                            app:layout_constraintTop_toBottomOf="@+id/tv_bottom_tips_aiclear"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>
</LinearLayout>
