<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.jbzd.media.movecartoons.view.text.ImageTextView
        android:textSize="15sp"
        android:textColor="@drawable/pb_selector_btn_text"
        android:ellipsize="end"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/text"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:singleLine="true"
        android:drawableLeft="@drawable/icon_home_change"
        android:drawablePadding="7.5dp"
        app:drawable_height="13dp"
        app:drawable_width="13dp"/>
</FrameLayout>
