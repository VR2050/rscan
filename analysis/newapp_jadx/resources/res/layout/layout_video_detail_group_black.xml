<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="@drawable/sheet_bottom_dialog_bg_black"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.github.mmin18.widget.RealtimeBlurView
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:realtimeOverlayColor="#b3232b34"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/black"
                android:id="@+id/tv_groupName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="合集"
                android:layout_centerInParent="true"/>
            <ImageView
                android:id="@+id/iv_closeGroup"
                android:padding="10dp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/home_icon_expand2"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                app:tint="@color/white"/>
        </RelativeLayout>
        <FrameLayout
            android:id="@+id/frag_group"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="40dp">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:id="@+id/tv_lookGroupMore"
                android:background="@drawable/bg_night_btn_select3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="浏览更多"
                android:layout_weight="1"/>
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:id="@+id/tv_doGroupCollect"
                android:background="@drawable/bg_night_btn_select3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="收藏口味"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
