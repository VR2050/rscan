<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/ll_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/search_layout_bar"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp">
            <RelativeLayout
                android:id="@+id/btn_titleBack"
                android:layout_width="wrap_content"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/iv_titleLeftIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginLeft="12dp"
                    android:layout_marginRight="5dp"
                    android:src="@drawable/ic_btn_icon_black"
                    android:layout_centerVertical="true"
                    app:tint="?attr/my_txt_color"/>
            </RelativeLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/ll_search"
                android:background="@drawable/search_bar_bg"
                android:paddingLeft="10dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <com.qunidayede.supportlibrary.widget.ClearEditText
                    android:textSize="13sp"
                    android:textColor="?attr/my_txt_color"
                    android:textColorHint="?attr/my_txt_color4"
                    android:id="@+id/cet_input"
                    android:background="@color/transparent"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:hint="标题/标签/番号"
                    android:singleLine="true"
                    android:layout_weight="1"
                    android:imeOptions="actionSearch"/>
            </LinearLayout>
            <TextView
                android:textSize="15sp"
                android:textColor="?attr/my_txt_color"
                android:gravity="center"
                android:id="@+id/tv_doSearch"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="搜索3"/>
        </LinearLayout>
    </LinearLayout>
    <include layout="@layout/view_sorting_tab"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">
        <include layout="@layout/view_canvas_tab2"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp">
            <TextView
                android:textSize="14sp"
                android:textColor="?attr/my_order_by_color"
                android:gravity="center"
                android:id="@+id/tv_type"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/video_type_all"/>
            <ImageView
                android:layout_width="15.5dp"
                android:layout_height="7.5dp"
                android:layout_marginLeft="1dp"
                android:src="@drawable/home_expand_icon"
                android:scaleType="fitCenter"
                app:tint="?attr/my_order_by_color"/>
        </LinearLayout>
    </LinearLayout>
    <androidx.viewpager.widget.ViewPager
        android:id="@+id/vp_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"/>
</LinearLayout>
