<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/ll_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">
        <include
            android:id="@+id/include"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            layout="@layout/title_bar_layout"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ll_mineTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/include">
            <com.jbzd.media.movecartoons.view.image.CircleImageView
                android:id="@+id/civ_head"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_place_holder_circle_51"
                android:layout_marginStart="@dimen/fab_margin"
                app:border_color="@color/white"
                app:border_color_inside="@color/white"
                app:border_width="0.5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                app:layout_constraintBottom_toBottomOf="@+id/civ_head"
                app:layout_constraintStart_toEndOf="@+id/civ_head"
                app:layout_constraintTop_toTopOf="@+id/civ_head">
                <TextView
                    android:textSize="16sp"
                    android:textColor="?attr/my_txt_color"
                    android:id="@+id/tv_postdetail_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="用户昵称"/>
                <TextView
                    android:textSize="@dimen/textSizeSmall"
                    android:textColor="@color/white70"
                    android:id="@+id/tv_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="怎舍得让她孤单寂寞"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="12dp">
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar_layout"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="0dp"
            app:layout_behavior="@string/my_appbar_fling_behavior">
            <com.flyco.tablayout.SlidingTabLayout
                android:layout_gravity="center"
                android:id="@+id/sorting_tab_layout"
                android:background="@color/black40"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                app:tl_divider_color="@color/transparent"
                app:tl_iconVisible="false"
                app:tl_indicator_color="@color/white"
                app:tl_indicator_corner_radius="2dp"
                app:tl_indicator_height="6dp"
                app:tl_indicator_margin_bottom="3dp"
                app:tl_indicator_width="12dp"
                app:tl_tab_padding="10dp"
                app:tl_tab_space_equal="false"
                app:tl_textBold="NONE"
                app:tl_textSelectColor="@color/white"
                app:tl_textSelectSize="16sp"
                app:tl_textUnselectColor="?attr/my_txt_color7"
                app:tl_textsize="15sp"/>
        </com.google.android.material.appbar.AppBarLayout>
        <androidx.viewpager.widget.ViewPager
            android:id="@+id/vp_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>
