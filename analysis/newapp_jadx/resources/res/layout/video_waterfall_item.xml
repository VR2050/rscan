<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_normal"
        android:background="@drawable/video_cover_bg"
        android:padding="0.5dp"
        android:paddingBottom="4dp"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout
            android:id="@+id/srl_cover"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.jbzd.media.movecartoons.view.viewgroup.RadiusCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:rcv_topLeftRadiu="5dp"
                app:rcv_topRightRadiu="5dp">
                <ImageView
                    android:id="@+id/iv_img"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"/>
                <com.jbzd.media.movecartoons.view.text.ImageTextView
                    android:textSize="8sp"
                    android:textColor="@color/black"
                    android:gravity="center_vertical"
                    android:layout_gravity="bottom"
                    android:id="@+id/itv_duration"
                    android:background="@drawable/bg_duration"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="14dp"
                    android:layout_marginLeft="8dp"
                    android:layout_marginBottom="8dp"
                    android:drawableLeft="@drawable/icon_home_video_duration"
                    android:drawablePadding="3dp"
                    android:layout_alignBottom="@+id/iv_img"
                    app:drawable_height="8dp"
                    app:drawable_width="8dp"/>
                <RelativeLayout
                    android:layout_gravity="right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <include layout="@layout/layout_video_type"/>
                </RelativeLayout>
            </com.jbzd.media.movecartoons.view.viewgroup.RadiusCardView>
        </com.jbzd.media.movecartoons.view.viewgroup.ScaleRelativeLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/black"
            android:ellipsize="end"
            android:id="@+id/tv_name"
            android:paddingLeft="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"
            android:maxLines="2"/>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/rl_videoBottom"
            android:paddingLeft="10dp"
            android:paddingTop="4dp"
            android:paddingRight="10dp"
            android:paddingBottom="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <include layout="@layout/home_long_video_bottom_user"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_hotWords"
        android:paddingLeft="10dp"
        android:paddingTop="5dp"
        android:paddingRight="10dp"
        android:paddingBottom="5dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="大家都在搜"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_words"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7.5dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2"/>
    </LinearLayout>
</RelativeLayout>
