<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/title_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_bar_height">
        <FrameLayout
            android:id="@+id/btn_titleBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/iv_titleLeftIcon"
                android:background="@drawable/style_icon_all"
                android:padding="6dp"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginLeft="6dp"
                android:layout_marginRight="6dp"
                android:src="@drawable/ic_btn_icon_black"
                android:scaleType="fitCenter"
                android:layout_centerVertical="true"/>
        </FrameLayout>
        <TextView
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/tv_title"
            android:paddingLeft="50dp"
            android:paddingRight="50dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <FrameLayout
            android:id="@+id/btn_titleRight"
            android:clipChildren="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/black"
                android:layout_gravity="center"
                android:id="@+id/tv_titleRight"
                android:paddingLeft="10dp"
                android:paddingTop="4dp"
                android:paddingRight="10dp"
                android:paddingBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableLeft="@drawable/icon_post_left"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/btn_titleRightIcon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/iv_titleRightIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="fitCenter"
                android:maxHeight="20dp"/>
        </FrameLayout>
        <View
            android:id="@+id/title_divider"
            android:background="#0cffffff"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_height"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar_layout"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="0dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:orientation="vertical"
                android:background="@drawable/shape_post_header_background"
                android:paddingTop="30dp"
                android:paddingBottom="30dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/app_content_margin"
                app:layout_scrollFlags="enterAlways|scroll">
                <androidx.constraintlayout.widget.Guideline
                    android:orientation="vertical"
                    android:id="@+id/guideLine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintGuide_percent="0.5"/>
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/tv_wallet_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前余额"
                    android:fontFamily="@font/number"
                    app:layout_constraintEnd_toEndOf="@+id/guideLine"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/white"
                    android:id="@+id/tv_wallet_income"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="累计收益"
                    android:layout_weight="1"
                    android:fontFamily="@font/number"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/guideLine"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/txt_current_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/app_content_margin"
                    android:text="¥0.00"
                    app:layout_constraintEnd_toEndOf="@+id/guideLine"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tv_wallet_balance"/>
                <TextView
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/txt_total_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/app_content_margin"
                    android:text="¥0.00"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/guideLine"
                    app:layout_constraintTop_toBottomOf="@+id/tv_wallet_income"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_ff6a00"
                    android:id="@+id/tv_wallet_withdraw"
                    android:background="@drawable/post_income_bg"
                    android:paddingLeft="35dp"
                    android:paddingTop="7dp"
                    android:paddingRight="35dp"
                    android:paddingBottom="7dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/app_content_margin"
                    android:text="@string/post_withdraw_immediately"
                    app:layout_constraintEnd_toEndOf="@+id/guideLine"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txt_current_balance"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_ff6a00"
                    android:id="@+id/tv_wallet_incomedetail"
                    android:background="@drawable/post_income_bg"
                    android:paddingLeft="35dp"
                    android:paddingTop="7dp"
                    android:paddingRight="35dp"
                    android:paddingBottom="7dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/app_content_margin"
                    android:text="@string/post_revenue_details"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/guideLine"
                    app:layout_constraintTop_toBottomOf="@+id/txt_total_count"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@+id/ll_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">
            <com.flyco.tablayout.SlidingTabLayout
                android:id="@+id/tablayout_post_child"
                android:layout_width="match_parent"
                android:layout_height="35dp"
                app:tl_divider_color="@color/transparent"
                app:tl_iconVisible="false"
                app:tl_indicator_color="@color/color_gold_main"
                app:tl_indicator_corner_radius="2dp"
                app:tl_indicator_height="4dp"
                app:tl_indicator_width="12dp"
                app:tl_tab_space_equal="true"
                app:tl_textBold="NONE"
                app:tl_textSelectColor="@color/black"
                app:tl_textSelectSize="16sp"
                app:tl_textUnselectColor="@color/black39"
                app:tl_textsize="16sp"/>
            <androidx.viewpager.widget.ViewPager
                android:id="@+id/vp_content_postchild"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior"/>
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>
