<?xml version="1.0" encoding="utf-8"?>
<com.flyco.tablayout.SlidingTabLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:id="@+id/sorting_tab_layout"
    android:layout_width="match_parent"
    android:layout_height="32dp"
    android:layout_marginBottom="8dp"
    app:tl_divider_color="@color/transparent"
    app:tl_iconVisible="false"
    app:tl_indicator_color="?attr/sorting_tab_text_selected_color"
    app:tl_indicator_corner_radius="2dp"
    app:tl_indicator_height="2dp"
    app:tl_indicator_width="12dp"
    app:tl_tab_padding="10dp"
    app:tl_tab_space_equal="false"
    app:tl_textBold="NONE"
    app:tl_textSelectColor="?attr/sorting_tab_text_selected_color"
    app:tl_textSelectSize="16sp"
    app:tl_textUnselectColor="?attr/my_txt_color7"
    app:tl_textsize="15sp"/>
